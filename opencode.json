{
    "$schema": "https://opencode.ai/config.json",
    "instructions": [
        ".github/copilot-instructions.md"
    ],
    "provider": {
        "go": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Go (via Headroom)",
            "options": {
                "baseURL": "http://127.0.0.1:8787/v1",
                "apiKey": "{env:GO_PROVIDER_API_KEY}"
            }
        }
    },
    "mcp": {
        "serena": {
            "type": "local",
            "command": [
                "uvx",
                "--from",
                "git+https://github.com/oraios/serena",
                "serena",
                "start-mcp-server",
                "--project-from-cwd",
                "--context",
                "agent"
            ]
        }
    }
}