@page
@model SauronSheet.Frontend.Pages.ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="max-w-xl mx-auto mt-16 bg-white rounded-xl shadow-sm border border-gray-100 p-10 text-center" role="alert" aria-live="assertive">
    <div class="text-6xl mb-4">🚨</div>
    <h1 class="text-2xl font-bold text-gray-900 mb-3">Something went wrong</h1>
    <p class="text-gray-500 mb-8">An unexpected error occurred. Please try again or contact support if the problem persists.</p>
    <button onclick="window.location.href='/'" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-brand-600 rounded-lg hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500 transition-colors shadow-sm">
        &larr; Back to Home
    </button>
</div>

