@page
@model SauronSheet.Frontend.Pages.ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="mx-auto mt-5" style="max-width:520px">
    <div class="card border-0 shadow-sm p-5 text-center" role="alert" aria-live="assertive" x-transition.opacity>
        <div class="fs-1 mb-3">🚨</div>
        <h1 class="h4 fw-bold mb-3">Something went wrong</h1>
        <p class="text-muted mb-4">An unexpected error occurred. Please try again or contact support if the problem persists.</p>
        <div>
            <button @@click="window.location.href='/'" class="btn btn-brand">&larr; Back to Home</button>
        </div>
    </div>
</div>

