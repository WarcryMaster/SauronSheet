@page
@model SauronSheet.Frontend.Pages.ErrorModel
@inject IStringLocalizer<SharedResources> Localizer
@{
    ViewData["Title"] = Localizer["Error.PageTitle"];
}

<div class="mx-auto mt-5" style="max-width:520px">
    <div class="card border-0 shadow-sm p-5 text-center" role="alert" aria-live="assertive" x-transition.opacity>
        <div class="fs-1 mb-3">🚨</div>
        <h1 class="h4 fw-bold mb-3">@Localizer["Error.Title"]</h1>
        <p class="text-muted mb-4">@Localizer["Error.Description"]</p>
        <div>
            <button @@click="window.location.href='/'" class="btn btn-brand" data-testid="error-back-home">&larr; @Localizer["Error.BackToHome"]</button>
        </div>
    </div>
</div>
