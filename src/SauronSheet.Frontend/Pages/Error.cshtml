@page
@model SauronSheet.Frontend.Pages.ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="max-w-xl mx-auto mt-16 bg-white rounded-lg shadow p-8 text-center" role="alert" aria-live="assertive">
    <h1 class="text-3xl font-bold text-red-600 mb-4">Oops! Something went wrong.</h1>
    <p class="text-gray-700 mb-6">An unexpected error occurred. Please try again or contact support if the problem persists.</p>
    <button onclick="window.location.href='/'" class="btn-primary">Go to Home</button>
</div>
<script>
    // Show toast if error message is available (global error handling)
    if (window.showToast && '@Model.ErrorMessage' && '@Model.ErrorMessage'.length > 0) {
        showToast('@Model.ErrorMessage', 'error');
    }
</script>
