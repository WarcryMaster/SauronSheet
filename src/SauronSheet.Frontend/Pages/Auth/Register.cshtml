@page "/auth/register"
@model RegisterModel

@{
    ViewData["Title"] = "Create Account";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="w-100" style="max-width: 450px;">
        <div class="card border-0 shadow-lg rounded-4 p-4 p-sm-5">
            <!-- Header -->
            <div class="text-center mb-4">
                <img src="~/img/sauron-sheet-logo.svg" asp-append-version="true" alt="SauronSheet" class="mb-3" height="56" />
                <h3 class="h3 fw-bold mb-1">Create your account</h3>
                <p class="text-muted small">Start tracking your finances for free</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger rounded-3" role="alert">
                    @Model.ErrorMessage
                </div>
            }

            <form method="post" id="registerForm">
                <div class="mb-3">
                    <label for="email" class="form-label fw-semibold">Email address</label>
                    <input id="email" name="Input.Email" type="email" required autofocus
                           class="form-control rounded-3"
                           value="@Model.Input.Email" />
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label fw-semibold">
                        Password <span class="text-muted fw-normal">(minimum 8 characters)</span>
                    </label>
                    <input id="password" name="Input.Password" type="password" required minlength="8"
                           class="form-control rounded-3" />
                </div>

                <div class="mb-4">
                    <label for="confirmPassword" class="form-label fw-semibold">Confirm password</label>
                    <input id="confirmPassword" name="Input.ConfirmPassword" type="password" required
                           class="form-control rounded-3" />
                </div>

                <button type="submit" id="registerBtn" class="btn btn-brand w-100 rounded-3 fw-bold">
                    <span id="registerBtnText">Create account</span>
                    <span id="registerSpinner" class="spinner-border spinner-border-sm ms-2 d-none" role="status" aria-hidden="true"></span>
                </button>
            </form>

            <p class="text-center text-muted small mt-4 mb-0">
                Already have an account?
                <a href="/auth/login" class="text-brand fw-semibold">Sign in</a>
            </p>
        </div>
    </div>
</div>

<script>
    document.getElementById('registerForm').addEventListener('submit', function () {
        var btn = document.getElementById('registerBtn');
        var text = document.getElementById('registerBtnText');
        var spinner = document.getElementById('registerSpinner');
        btn.disabled = true;
        text.textContent = 'Creating...';
        spinner.classList.remove('d-none');
    });
</script>
