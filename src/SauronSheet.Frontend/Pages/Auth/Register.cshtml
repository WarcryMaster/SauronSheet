@page "/auth/register"
@model RegisterModel
@inject IStringLocalizer<SharedResources> Localizer

@{
    ViewData["Title"] = Localizer["Auth.CreateAccountTitle"];
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="w-100" style="max-width: 450px;">
        <div class="card border-0 shadow-lg rounded-4 p-4 p-sm-5">
            <!-- Header -->
            <div class="text-center mb-4">
                <img src="~/img/sauron-sheet-logo.svg" asp-append-version="true" alt="SauronSheet" class="mb-3" height="56" />
                <h3 class="h3 fw-bold mb-1">@Localizer["Auth.RegisterHeading"]</h3>
                <p class="text-muted small">@Localizer["Auth.RegisterSubtitle"]</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger rounded-3" role="alert" x-transition.opacity data-testid="register-error">
                    @Model.ErrorMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="alert alert-success rounded-3" role="status" x-transition.opacity data-testid="register-success">
                    @Model.SuccessMessage
                </div>
            }

            <form method="post" id="registerForm"
                  x-data="{ loading: false }"
                  @@submit="loading = true">
                <div class="mb-3">
                    <label for="email" class="form-label fw-semibold">@Localizer["Auth.EmailLabel"]</label>
                    <input id="email" name="Input.Email" type="email" required autofocus
                           class="form-control rounded-3"
                           value="@Model.Input.Email"
                           data-testid="register-email" />
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label fw-semibold">
                        @Localizer["Auth.PasswordLabel"] <span class="text-muted fw-normal">@Localizer["Auth.PasswordHint"]</span>
                    </label>
                    <input id="password" name="Input.Password" type="password" required minlength="8"
                           class="form-control rounded-3"
                           data-testid="register-password" />
                </div>

                <div class="mb-4">
                    <label for="confirmPassword" class="form-label fw-semibold">@Localizer["Auth.ConfirmPasswordLabel"]</label>
                    <input id="confirmPassword" name="Input.ConfirmPassword" type="password" required
                           class="form-control rounded-3"
                           data-testid="register-confirm-password" />
                </div>

                <button type="submit" id="registerBtn" class="btn btn-brand w-100 rounded-3 fw-bold" :disabled="loading" data-testid="register-submit">
                    <span x-show="!loading">@Localizer["Auth.RegisterSubmit"]</span>
                    <span x-show="loading">@Localizer["Auth.RegisterSubmitLoading"]</span>
                    <span x-show="loading" class="spinner-border spinner-border-sm ms-2" role="status" aria-hidden="true"></span>
                </button>
            </form>

            @if (Model.ShowResendConfirmation)
            {
                <div class="mt-3 pt-2 border-top">
                    <p class="text-muted small mb-2">@Localizer["Auth.ResendConfirmationPrompt"]</p>
                    <form method="post" asp-page-handler="ResendConfirmation" class="d-flex gap-2 align-items-start">
                        @Html.AntiForgeryToken()
                        <input type="email"
                               name="resendEmail"
                               class="form-control form-control-sm"
                               placeholder="@Localizer["Auth.ResendEmailPlaceholder"]"
                               value="@Model.Input.Email"
                               required
                               data-testid="resend-email-input" />
                        <button type="submit" class="btn btn-outline-secondary btn-sm text-nowrap" data-testid="resend-confirmation-btn">
                            @Localizer["Auth.ResendConfirmationButton"]
                        </button>
                    </form>
                </div>
            }

            <p class="text-center text-muted small mt-4 mb-0">
                @Localizer["Auth.AlreadyHaveAccount"]
                <a href="/auth/login" class="text-brand fw-semibold" data-testid="register-signin-link">@Localizer["Auth.SignInLink"]</a>
            </p>
        </div>
    </div>
</div>
