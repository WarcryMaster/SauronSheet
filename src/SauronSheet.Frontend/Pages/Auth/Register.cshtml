@page "/auth/register"
@model RegisterModel

@{
    ViewData["Title"] = "Create Account";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="w-100" style="max-width: 450px;">
        <div class="card border-0 shadow-lg rounded-4 p-4 p-sm-5">
            <!-- Header -->
            <div class="text-center mb-4">
                <img src="~/img/sauron-sheet-logo.svg" asp-append-version="true" alt="SauronSheet" class="mb-3" height="56" />
                <h3 class="h3 fw-bold mb-1">Create your account</h3>
                <p class="text-muted small">Start tracking your finances for free</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger rounded-3" role="alert" x-transition.opacity>
                    @Model.ErrorMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                <div class="alert alert-success rounded-3" role="status" x-transition.opacity>
                    @Model.SuccessMessage
                </div>
            }

            <form method="post" id="registerForm"
                  x-data="{ loading: false }"
                  @@submit="loading = true">
                <div class="mb-3">
                    <label for="email" class="form-label fw-semibold">Email address</label>
                    <input id="email" name="Input.Email" type="email" required autofocus
                           class="form-control rounded-3"
                           value="@Model.Input.Email" />
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label fw-semibold">
                        Password <span class="text-muted fw-normal">(minimum 8 characters)</span>
                    </label>
                    <input id="password" name="Input.Password" type="password" required minlength="8"
                           class="form-control rounded-3" />
                </div>

                <div class="mb-4">
                    <label for="confirmPassword" class="form-label fw-semibold">Confirm password</label>
                    <input id="confirmPassword" name="Input.ConfirmPassword" type="password" required
                           class="form-control rounded-3" />
                </div>

                <button type="submit" id="registerBtn" class="btn btn-brand w-100 rounded-3 fw-bold" :disabled="loading">
                    <span x-show="!loading">Create account</span>
                    <span x-show="loading">Creating...</span>
                    <span x-show="loading" class="spinner-border spinner-border-sm ms-2" role="status" aria-hidden="true"></span>
                </button>
            </form>

            @if (Model.ShowResendConfirmation)
            {
                <div class="mt-3 pt-2 border-top">
                    <p class="text-muted small mb-2">Didn't receive the confirmation email?</p>
                    <form method="post" asp-page-handler="ResendConfirmation" class="d-flex gap-2 align-items-start">
                        @Html.AntiForgeryToken()
                        <input type="email"
                               name="resendEmail"
                               class="form-control form-control-sm"
                               placeholder="Email"
                               value="@Model.Input.Email"
                               required />
                        <button type="submit" class="btn btn-outline-secondary btn-sm text-nowrap" data-testid="resend-confirmation-btn">
                            Resend confirmation
                        </button>
                    </form>
                </div>
            }

            <p class="text-center text-muted small mt-4 mb-0">
                Already have an account?
                <a href="/auth/login" class="text-brand fw-semibold">Sign in</a>
            </p>
        </div>
    </div>
</div>
