@page "/Auth/Login"
@model LoginModel

@{
    ViewData["Title"] = "Sign In - SauronSheet";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 75vh;">
    <div class="w-100" style="max-width: 440px;">

        <!-- Card -->
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

            <!-- Decorative top strip -->
            <div style="height: 5px; background: linear-gradient(90deg, var(--brand-light, #7c4dff), var(--brand, #651fff), var(--brand-dark, #4a148c));"></div>

            <div class="card-body px-4 px-sm-5 pt-4 pb-5">

                <!-- Logo + Title -->
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-3 mb-3"
                         style="width:64px; height:64px; background-color: rgba(101,31,255,0.1);">
                        <img src="/img/sauron-sheet-logo-64x64.png" alt="SauronSheet" width="40" height="40" />
                    </div>
                    <h1 class="h4 fw-bold text-dark mb-1">Welcome back</h1>
                    <p class="text-muted small mb-0">Sign in to continue to your dashboard</p>
                </div>

                <!-- Error alert -->
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger d-flex align-items-start gap-2 rounded-3 py-2 px-3" role="alert" aria-live="polite">
                        <i class="fas fa-exclamation-circle mt-1"></i>
                        <div>
                            <p class="mb-0 fw-semibold small">Authentication failed</p>
                            <p class="mb-0 small">@Model.ErrorMessage</p>
                        </div>
                    </div>
                }

                <!-- Form -->
                <form method="post" autocomplete="off" id="loginForm">

                    <!-- Email input (MDB style) -->
                    <div data-mdb-input-init class="form-outline mb-4">
                        <input type="email"
                               id="loginEmail"
                               name="Input.Email"
                               class="form-control"
                               value="@Model.Input.Email"
                               required
                               autofocus
                               tabindex="1" />
                        <label class="form-label" for="loginEmail">Email address</label>
                    </div>

                    <!-- Password input (MDB style) -->
                    <div data-mdb-input-init class="form-outline mb-3">
                        <input type="password"
                               id="loginPassword"
                               name="Input.Password"
                               class="form-control"
                               required
                               autocomplete="current-password"
                               tabindex="2" />
                        <label class="form-label" for="loginPassword">Password</label>
                    </div>

                    <!-- Remember me + Toggle password row -->
                    <div class="row mb-4">
                        <div class="col d-flex justify-content-start">
                            <div class="form-check">
                                <input class="form-check-input"
                                       type="checkbox"
                                       id="rememberMe"
                                       name="Input.RememberMe"
                                       tabindex="3" />
                                <label class="form-check-label small" for="rememberMe">Remember me</label>
                            </div>
                        </div>
                        <div class="col text-end">
                            <a href="#" class="small"
                               onclick="togglePassword(event)"
                               tabindex="4"
                               id="togglePwdLink">
                                <span id="eyeIcon">👁</span> Show password
                            </a>
                        </div>
                    </div>

                    <!-- Submit button (MDB style) -->
                    <button type="submit"
                            data-mdb-button-init
                            data-mdb-ripple-init
                            class="btn btn-primary btn-block mb-4 text-uppercase fw-bold"
                            id="loginBtn"
                            tabindex="5">
                        <span id="loginBtnText">Sign in</span>
                        <span id="loginSpinner"
                              class="spinner-border spinner-border-sm ms-2 d-none"
                              role="status"
                              aria-hidden="true"></span>
                    </button>
                </form>

                <!-- Divider -->
                <div class="text-center">
                    <p class="text-muted small mb-3">Not a member?
                        <a href="/Auth/Register" class="fw-semibold">Create a free account</a>
                    </p>
                </div>

            </div>
        </div>

        <p class="mt-3 text-center small text-muted">
            Protected with secure authentication · SauronSheet &copy; 2026
        </p>
    </div>
</div>

<script>
    function togglePassword(e) {
        if (e) e.preventDefault();
        const input = document.getElementById('loginPassword');
        const icon = document.getElementById('eyeIcon');
        const link = document.getElementById('togglePwdLink');
        if (input.type === 'password') {
            input.type = 'text';
            link.innerHTML = '<span id="eyeIcon">🙈</span> Hide password';
        } else {
            input.type = 'password';
            link.innerHTML = '<span id="eyeIcon">👁</span> Show password';
        }
    }

    document.getElementById('loginForm').addEventListener('submit', function () {
        const btn = document.getElementById('loginBtn');
        const text = document.getElementById('loginBtnText');
        const spinner = document.getElementById('loginSpinner');
        btn.disabled = true;
        text.textContent = 'Signing in…';
        spinner.classList.remove('d-none');
    });

    // Re-initialize MDB inputs (needed when value is pre-filled by server)
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('[data-mdb-input-init]').forEach(function (el) {
            new mdb.Input(el);
        });
    });
</script>