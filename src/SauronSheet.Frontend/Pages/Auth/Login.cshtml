@page "/auth/login"
@model LoginModel

@{
    ViewData["Title"] = "Sign In - SauronSheet";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="w-100" style="max-width: 450px;">

        <!-- Card -->
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

            <!-- Decorative top strip -->
            <div style="height: 5px; background: linear-gradient(90deg, var(--brand-light, #f4f7ee), var(--brand, #556B2F), var(--brand-dark, #435425));"></div>

            <div class="card-body px-4 px-sm-5 pt-4 pb-5">

                <!-- Logo + Title -->
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-3 mb-3"
                         style="width:64px; height:64px; background-color: rgba(85, 107, 47, 0.1);">
                        <img src="~/img/sauron-sheet-logo.svg" asp-append-version="true" alt="SauronSheet" width="40" height="40" />
                    </div>
                    <h1 class="h4 fw-bold mb-1">Welcome back</h1>
                    <p class="text-muted small mb-0">Sign in to continue to your dashboard</p>
                </div>

                <!-- Success alert (e.g. registration confirmation) -->
                @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                {
                    <div class="alert alert-success d-flex align-items-start gap-2 rounded-3 py-2 px-3" role="status">
                        <i class="fas fa-check-circle mt-1"></i>
                        <div>
                            <p class="mb-0 fw-semibold small">Success</p>
                            <p class="mb-0 small">@Model.SuccessMessage</p>
                        </div>
                    </div>
                }

                <!-- Error alert -->
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger d-flex align-items-start gap-2 rounded-3 py-2 px-3" role="alert" aria-live="polite">
                        <i class="fas fa-exclamation-circle mt-1"></i>
                        <div>
                            <p class="mb-0 fw-semibold small">Authentication failed</p>
                            <p class="mb-0 small">@Model.ErrorMessage</p>
                        </div>
                    </div>
                }

                <!-- Form -->
                <form method="post" autocomplete="off" id="loginForm"
                      x-data="{ loading: false, showPassword: false }"
                      @@submit="loading = true; setTimeout(() => { if (loading) loading = false; }, 10000)">
                    @Html.AntiForgeryToken()

                    <!-- Email input (label always above) -->
                    <div class="mb-4">
                        <label for="loginEmail" class="form-label fw-semibold">Email address</label>
                        <input type="email"
                               id="loginEmail"
                               name="Input.Email"
                               class="form-control"
                               value="@(Model.Input.Email ?? "")"
                               required
                               autofocus
                               tabindex="1" />
                    </div>

                    <!-- Password input (label always above) -->
                    <div class="mb-3">
                        <label for="loginPassword" class="form-label fw-semibold">Password</label>
                        <input type="password"
                               x-ref="loginPwd"
                               id="loginPassword"
                               name="Input.Password"
                               class="form-control"
                               value="@(Model.Input.Password ?? "")"
                               required
                               autocomplete="current-password"
                               tabindex="2" />
                    </div>

                    <!-- Remember me + Toggle password row -->
                    <div class="row mb-4">
                        <div class="col d-flex justify-content-start">
                            <div class="form-check">
                                <input class="form-check-input"
                                       type="checkbox"
                                       id="rememberMe"
                                       name="Input.RememberMe"
                                       tabindex="3" />
                                <label class="form-check-label small" for="rememberMe">Remember me</label>
                            </div>
                        </div>
                        <div class="col text-end">
                            <a href="#" class="small"
                               @@click.prevent="showPassword = !showPassword; $refs.loginPwd.type = showPassword ? 'text' : 'password'"
                               tabindex="4"
                               id="togglePwdLink">
                                <span x-show="!showPassword">👁 Show password</span>
                                <span x-show="showPassword">🙈 Hide password</span>
                            </a>
                        </div>
                    </div>

                    <!-- Submit button -->
                    <button type="submit"
                            data-mdb-ripple-init
                            class="btn btn-brand btn-block mb-4 text-uppercase fw-bold"
                            id="loginBtn"
                            :disabled="loading"
                            tabindex="5">
                        <span x-show="!loading">Sign in</span>
                        <span x-show="loading">Signing in…</span>
                        <span x-show="loading"
                              class="spinner-border spinner-border-sm ms-2"
                              role="status"
                              aria-hidden="true"></span>
                    </button>
                </form>

                <div class="mt-3 pt-2 border-top">
                    <p class="text-muted small mb-2">Haven't confirmed your account yet?</p>
                    <form method="post" asp-page-handler="ResendConfirmation" class="d-flex gap-2 align-items-start">
                        @Html.AntiForgeryToken()
                        <input type="email"
                               name="resendEmail"
                               class="form-control form-control-sm"
                               placeholder="Email for confirmation resend"
                               value="@(Model.Input.Email ?? "")"
                               required />
                        <button type="submit" class="btn btn-outline-secondary btn-sm text-nowrap">
                            Resend confirmation
                        </button>
                    </form>
                </div>

                <!-- Divider -->
                <div class="text-center">
                    <p class="text-muted small mb-3">Not a member?
                        <a href="/auth/register" class="fw-semibold">Create a free account</a>
                    </p>
                </div>

            </div>
        </div>

        <p class="mt-3 text-center small text-muted">
            Protected with secure authentication · SauronSheet &copy; 2026
        </p>
    </div>
</div>
