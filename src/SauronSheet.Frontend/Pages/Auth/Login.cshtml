@page "/auth/login"
@model LoginModel
@inject IStringLocalizer<SharedResources> Localizer

@{
    ViewData["Title"] = $"{Localizer["Login.Title"]} - SauronSheet";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 70vh;">
    <div class="w-100" style="max-width: 450px;">

        <!-- Card -->
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

            <!-- Decorative top strip -->
            <div style="height: 5px; background: linear-gradient(90deg, var(--brand-light, #f4f7ee), var(--brand, #556B2F), var(--brand-dark, #435425));"></div>

            <div class="card-body px-4 px-sm-5 pt-4 pb-5">

                <!-- Logo + Title -->
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-3 mb-3"
                         style="width:64px; height:64px; background-color: rgba(85, 107, 47, 0.1);">
                        <img src="~/img/sauron-sheet-logo.svg" asp-append-version="true" alt="SauronSheet" width="40" height="40" />
                    </div>
                    <h1 class="h4 fw-bold mb-1">@Localizer["Login.Title"]</h1>
                    <p class="text-muted small mb-0">@Localizer["Login.Subtitle"]</p>
                </div>

                <!-- Success alert (e.g. registration confirmation) -->
                @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                {
                    <div class="alert alert-success d-flex align-items-start gap-2 rounded-3 py-2 px-3" role="status" data-testid="login-success">
                        <i class="fas fa-check-circle mt-1"></i>
                        <div>
                            <p class="mb-0 fw-semibold small">@Localizer["Login.SuccessTitle"]</p>
                            <p class="mb-0 small">@Model.SuccessMessage</p>
                        </div>
                    </div>
                }

                <!-- Error alert -->
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger d-flex align-items-start gap-2 rounded-3 py-2 px-3" role="alert" aria-live="polite" data-testid="login-error">
                        <i class="fas fa-exclamation-circle mt-1"></i>
                        <div>
                            <p class="mb-0 fw-semibold small">@Localizer["Login.ErrorTitle"]</p>
                            <p class="mb-0 small">@Model.ErrorMessage</p>
                        </div>
                    </div>
                }

                <!-- Form -->
                <form method="post" autocomplete="off" id="loginForm"
                      x-data="{ loading: false, showPassword: false }"
                      @@submit="loading = true; setTimeout(() => { if (loading) loading = false; }, 10000)">
                    @Html.AntiForgeryToken()

                    <!-- Email input (label always above) -->
                    <div class="mb-4">
                        <label for="loginEmail" class="form-label fw-semibold">@Localizer["Login.EmailLabel"]</label>
                        <input type="email"
                               id="loginEmail"
                               name="Input.Email"
                               class="form-control"
                               value="@(Model.Input.Email ?? "")"
                               required
                               autofocus
                               tabindex="1"
                               data-testid="login-email" />
                    </div>

                    <!-- Password input (label always above) -->
                    <div class="mb-3">
                        <label for="loginPassword" class="form-label fw-semibold">@Localizer["Login.PasswordLabel"]</label>
                        <input type="password"
                               x-ref="loginPwd"
                               id="loginPassword"
                               name="Input.Password"
                               class="form-control"
                               value="@(Model.Input.Password ?? "")"
                               required
                               autocomplete="current-password"
                               tabindex="2"
                               data-testid="login-password" />
                    </div>

                    <!-- Remember me + Toggle password row -->
                    <div class="row mb-4">
                        <div class="col d-flex justify-content-start">
                            <div class="form-check">
                                <input class="form-check-input"
                                       type="checkbox"
                                       id="rememberMe"
                                       name="Input.RememberMe"
                                       tabindex="3" />
                                <label class="form-check-label small" for="rememberMe">@Localizer["Login.RememberMe"]</label>
                            </div>
                        </div>
                        <div class="col text-end">
                            <a href="#" class="small"
                               @@click.prevent="showPassword = !showPassword; $refs.loginPwd.type = showPassword ? 'text' : 'password'"
                               tabindex="4"
                               id="togglePwdLink">
                                <span x-show="!showPassword">👁 @Localizer["Login.ShowPassword"]</span>
                                <span x-show="showPassword">🙈 @Localizer["Login.HidePassword"]</span>
                            </a>
                        </div>
                    </div>

                    <!-- Submit button -->
                    <button type="submit"
                            data-mdb-ripple-init
                            class="btn btn-brand btn-block mb-4 text-uppercase fw-bold"
                            id="loginBtn"
                            :disabled="loading"
                            tabindex="5"
                            data-testid="login-submit">
                        <span x-show="!loading">@Localizer["Login.Submit"]</span>
                        <span x-show="loading">@Localizer["Login.SubmitLoading"]</span>
                        <span x-show="loading"
                              class="spinner-border spinner-border-sm ms-2"
                              role="status"
                              aria-hidden="true"></span>
                    </button>
                </form>

                <!-- Divider -->
                <div class="text-center">
                    <p class="text-muted small mb-3">@Localizer["Login.RegisterPrompt"]
                        <a href="/auth/register" class="fw-semibold" data-testid="login-register-link">@Localizer["Login.RegisterLink"]</a>
                    </p>
                </div>

            </div>
        </div>

        <p class="mt-3 text-center small text-muted">
            @Localizer["Login.FooterProtected"]
        </p>
    </div>
</div>
