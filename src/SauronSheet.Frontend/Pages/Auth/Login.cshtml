@page "/Auth/Login"
@model LoginModel

@{
    ViewData["Title"] = "Sign In - SauronSheet";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 75vh;">
    <div class="w-100" style="max-width: 440px;">

        <!-- Card -->
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

            <!-- Decorative top strip -->
            <div style="height: 5px; background: linear-gradient(90deg, var(--brand-light), var(--brand), var(--brand-dark));"></div>

            <div class="card-body px-4 px-sm-5 pt-4 pb-5">

                <!-- Logo + Title -->
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-3 bg-brand-light mb-4" style="width:64px; height:64px;">
                        <img src="/img/sauron-sheet-logo-64x64.png" alt="SauronSheet" width="40" height="40" />
                    </div>
                    <h1 class="h3 fw-bold text-dark">Welcome back</h1>
                    <p class="text-muted small">Sign in to continue to your dashboard</p>
                </div>

                <!-- Error alert -->
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger d-flex align-items-start gap-2 rounded-3" role="alert" aria-live="polite">
                        <span class="fw-bold">!</span>
                        <div>
                            <p class="mb-0 fw-semibold">Authentication failed</p>
                            <p class="mb-0 small">@Model.ErrorMessage</p>
                        </div>
                    </div>
                }

                <!-- Form -->
                <form method="post" autocomplete="off" id="loginForm">

                    <!-- Email -->
                    <div class="mb-3">
                        <label for="email" class="form-label small fw-semibold text-uppercase text-muted">Email address</label>
                        <input id="email" name="Input.Email" type="email" required autofocus tabindex="1"
                               value="@Model.Input.Email" placeholder="you@example.com"
                               class="form-control rounded-3" />
                    </div>

                    <!-- Password -->
                    <div class="mb-4">
                        <label for="password" class="form-label small fw-semibold text-uppercase text-muted">Password</label>
                        <div class="input-group">
                            <input type="password" id="password" name="Input.Password" required tabindex="2"
                                   autocomplete="current-password" placeholder="••••••••"
                                   class="form-control rounded-start-3" />
                            <button type="button" class="btn btn-outline-secondary rounded-end-3"
                                    onclick="togglePassword()" aria-label="Toggle password visibility" tabindex="3">
                                <span id="eyeIcon">👁</span>
                            </button>
                        </div>
                    </div>

                    <!-- Submit -->
                    <button type="submit" tabindex="4" id="loginBtn"
                            class="btn btn-brand w-100 rounded-3 fw-bold text-uppercase">
                        <span id="loginBtnText">Sign in</span>
                        <span id="loginSpinner" class="spinner-border spinner-border-sm ms-2 d-none" role="status" aria-hidden="true"></span>
                    </button>
                </form>

                <!-- Divider -->
                <div class="d-flex align-items-center my-4">
                    <hr class="flex-grow-1" />
                    <span class="px-3 small text-muted text-uppercase">or</span>
                    <hr class="flex-grow-1" />
                </div>

                <!-- Register link -->
                <div class="text-center">
                    <p class="text-muted small mb-2">Don't have an account yet?</p>
                    <a href="/Auth/Register" class="btn btn-outline-secondary rounded-3 px-4">
                        Create a free account
                    </a>
                </div>
            </div>
        </div>

        <p class="mt-3 text-center small text-muted">
            Protected with secure authentication · SauronSheet &copy; 2026
        </p>
    </div>
</div>

<script>
    function togglePassword() {
        var input = document.getElementById('password');
        var icon = document.getElementById('eyeIcon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.textContent = '🙈';
        } else {
            input.type = 'password';
            icon.textContent = '👁';
        }
    }

    document.getElementById('loginForm').addEventListener('submit', function () {
        var btn = document.getElementById('loginBtn');
        var text = document.getElementById('loginBtnText');
        var spinner = document.getElementById('loginSpinner');
        btn.disabled = true;
        text.textContent = 'Signing in…';
        spinner.classList.remove('d-none');
    });
</script>