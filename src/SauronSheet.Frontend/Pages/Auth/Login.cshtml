@page "/Auth/Login"
@model LoginModel

@{
    ViewData["Title"] = "Sign In - SauronSheet";
}

<div class="flex items-center justify-center min-h-[75vh] px-4 py-12 sm:px-6 lg:px-8">
    <div class="w-full max-w-sm sm:max-w-md">

        <!-- Card -->
        <div class="relative overflow-hidden bg-white border border-gray-200 shadow-xl rounded-3xl">

            <!-- Franja decorativa -->
            <div class="h-1.5 bg-gradient-to-r from-brand-400 via-brand-600 to-brand-800"></div>

            <div class="px-6 pt-8 pb-10 sm:px-10">

                <!-- Logo + Título -->
                <div class="text-center mb-10">
                    <div class="inline-flex items-center justify-center w-16 h-16 mx-auto mb-5 rounded-2xl bg-brand-50 ring-1 ring-brand-200 shadow-sm">
                        <img src="/img/sauron-sheet-logo-64x64.png"
                             alt="SauronSheet"
                             width="40"
                             height="40"
                             class="w-10 h-10 block" />
                    </div>
                    <h1 class="text-2xl font-extrabold tracking-tight text-gray-900 sm:text-3xl">
                        Welcome back
                    </h1>
                    <p class="mt-2 text-sm leading-relaxed text-gray-500">
                        Sign in to continue to your dashboard
                    </p>
                </div>

                <!-- Error alert -->
                <div x-data="{ show: @((!string.IsNullOrEmpty(Model.ErrorMessage)).ToString().ToLower()) }"
                     x-show="show"
                     x-transition
                     role="alert"
                     aria-live="polite"
                     class="flex items-start gap-3 p-4 mb-8 border rounded-xl bg-red-50 border-red-200"
                     style="display:none">
                    <span class="flex-shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-full bg-red-100 text-red-600 text-sm font-bold">!</span>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-semibold text-red-800">Authentication failed</p>
                        <p class="mt-0.5 text-sm text-red-600">@Model.ErrorMessage</p>
                    </div>
                    <button type="button" x-on:click="show = false"
                            class="flex-shrink-0 ml-auto p-1 rounded-lg text-red-400 hover:text-red-600 hover:bg-red-100 transition text-lg leading-none">
                        &times;
                    </button>
                </div>

                <!-- Formulario -->
                <form method="post"
                      class="space-y-6"
                      autocomplete="off"
                      x-data="{ showPassword: false, isSubmitting: false }"
                      x-on:submit="isSubmitting = true">

                    <!-- Email -->
                    <div class="space-y-1.5">
                        <label for="email"
                               class="block text-xs font-semibold tracking-wide text-gray-600 uppercase">
                            Email address
                        </label>
                        <input id="email"
                               name="Input.Email"
                               type="email"
                               required
                               autofocus
                               tabindex="1"
                               value="@Model.Input.Email"
                               placeholder="you@example.com"
                               :disabled="isSubmitting"
                               class="block w-full py-3 px-4 text-sm text-gray-900 placeholder-gray-400 bg-gray-50 border border-gray-300 rounded-xl focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 disabled:opacity-50 disabled:cursor-not-allowed transition duration-200" />
                    </div>

                    <!-- Password -->
                    <div class="space-y-1.5">
                        <label for="password"
                               class="block text-xs font-semibold tracking-wide text-gray-600 uppercase">
                            Password
                        </label>
                        <div class="relative">
                            <input :type="showPassword ? 'text' : 'password'"
                                   id="password"
                                   name="Input.Password"
                                   required
                                   tabindex="2"
                                   autocomplete="current-password"
                                   placeholder="••••••••"
                                   :disabled="isSubmitting"
                                   class="block w-full py-3 pl-4 pr-12 text-sm text-gray-900 placeholder-gray-400 bg-gray-50 border border-gray-300 rounded-xl focus:bg-white focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 disabled:opacity-50 disabled:cursor-not-allowed transition duration-200" />
                            <button type="button"
                                    tabindex="3"
                                    x-on:click="showPassword = !showPassword"
                                    :aria-label="showPassword ? 'Hide password' : 'Show password'"
                                    class="absolute inset-y-0 right-0 flex items-center justify-center w-12 text-gray-400 hover:text-brand-600 focus:outline-none transition-colors duration-200">
                                <span x-show="!showPassword" class="text-lg leading-none select-none">👁</span>
                                <span x-show="showPassword" class="text-lg leading-none select-none" style="display:none">🙈</span>
                            </button>
                        </div>
                    </div>

                    <!-- Submit -->
                    <div class="pt-1">
                        <button type="submit"
                                tabindex="4"
                                :disabled="isSubmitting"
                                :class="isSubmitting ? 'opacity-70 cursor-not-allowed' : 'hover:bg-brand-700 hover:shadow-lg active:scale-[0.98]'"
                                class="flex items-center justify-center w-full gap-2 px-4 py-3 text-sm font-bold tracking-wide text-white uppercase rounded-xl bg-brand-600 shadow-md focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 transition-all duration-200">
                            <span x-show="isSubmitting" style="display:none" class="inline-block w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"></span>
                            <span x-show="!isSubmitting">Sign in</span>
                            <span x-show="isSubmitting" style="display:none">Signing in…</span>
                        </button>
                    </div>
                </form>

                <!-- Divider -->
                <div class="flex items-center my-8">
                    <div class="flex-1 border-t border-gray-200"></div>
                    <span class="px-4 text-xs font-medium text-gray-400 uppercase">or</span>
                    <div class="flex-1 border-t border-gray-200"></div>
                </div>

                <!-- Link registro -->
                <div class="text-center">
                    <p class="text-sm text-gray-500">Don't have an account yet?</p>
                    <a href="/Auth/Register"
                       class="inline-flex items-center gap-1.5 mt-3 px-5 py-2.5 text-sm font-semibold text-brand-700 bg-brand-50 border border-brand-200 rounded-xl hover:bg-brand-100 hover:border-brand-300 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 transition-all duration-200">
                        Create a free account
                    </a>
                </div>
            </div>
        </div>

        <!-- Texto inferior -->
        <p class="mt-6 text-xs text-center text-gray-400">
            Protected with secure authentication · SauronSheet &copy; 2026
        </p>
    </div>
</div>