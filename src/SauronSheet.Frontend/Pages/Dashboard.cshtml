@page "/Dashboard"
@model DashboardModel
@using System.Text.Json

@{
    ViewData["Title"] = "Dashboard";
    ViewData["DateFilter"] = Model.DateFilter;
    ViewData["CustomFromDate"] = Model.CustomFromDate?.ToString("yyyy-MM-dd");
    ViewData["CustomToDate"] = Model.CustomToDate?.ToString("yyyy-MM-dd");
}

<div class="space-y-6">
    <!-- Date Range Filter -->
    <form method="get" action="/Dashboard">
        <partial name="Shared/Components/_DateRangeFilter" />
    </form>

    @if (Model.Summary?.TransactionCount == 0)
    {
        <!-- Empty State -->
        <div class="bg-white rounded-lg shadow p-8 text-center">
            <p class="text-xl text-gray-500 mb-4">📊 No spending data yet.</p>
            <p class="text-gray-400 mb-6">Import a PDF or add transactions to see analytics.</p>
            <div class="flex justify-center gap-4">
                <a href="/Transactions/Upload" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">📄 Upload PDF</a>
                <a href="/Transactions/Add" class="px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700">➕ Add Transaction</a>
            </div>
        </div>
    }
    else
    {
        <!-- Summary Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="bg-white rounded-lg shadow p-6">
                <div class="text-sm font-medium text-gray-500">📈 Total Income</div>
                <div class="mt-2 text-2xl font-bold text-green-600">€@Model.Summary?.TotalIncome.ToString("N2")</div>
            </div>
            <div class="bg-white rounded-lg shadow p-6">
                <div class="text-sm font-medium text-gray-500">📉 Total Expenses</div>
                <div class="mt-2 text-2xl font-bold text-red-600">€@Model.Summary?.TotalExpenses.ToString("N2")</div>
            </div>
            <div class="bg-white rounded-lg shadow p-6">
                <div class="text-sm font-medium text-gray-500">💰 Net Amount</div>
                <div class="mt-2 text-2xl font-bold @(Model.Summary?.NetAmount >= 0 ? "text-green-600" : "text-red-600")">
                    €@Model.Summary?.NetAmount.ToString("N2")
                </div>
            </div>
            <div class="bg-white rounded-lg shadow p-6">
                <div class="text-sm font-medium text-gray-500">📊 Transactions</div>
                <div class="mt-2 text-2xl font-bold text-blue-600">@Model.Summary?.TransactionCount</div>
            </div>
        </div>

        <!-- Charts -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="bg-white rounded-lg shadow p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Spending by Category</h3>
                @if (Model.SpendingByCategory.Any())
                {
                    <canvas id="categoryPieChart"></canvas>
                }
                else
                {
                    <p class="text-gray-400 text-center py-8">No expense data for this period.</p>
                }
            </div>
            <div class="bg-white rounded-lg shadow p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Monthly Trends</h3>
                <canvas id="monthlyTrendsChart"></canvas>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Year over Year Comparison</h3>
            <canvas id="yearlyComparisonChart"></canvas>
        </div>

        <!-- Recent Transactions -->
        <div class="bg-white rounded-lg shadow p-6">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-semibold text-gray-900">Recent Transactions</h3>
                <a href="/Transactions" class="text-blue-600 hover:text-blue-800 text-sm">View all transactions →</a>
            </div>
            @if (Model.RecentTransactions.Any())
            {
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Description</th>
                                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Amount</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Category</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            @foreach (var tx in Model.RecentTransactions)
                            {
                                <tr>
                                    <td class="px-4 py-3 text-sm text-gray-600">@tx.Date.ToString("MMM dd, yyyy")</td>
                                    <td class="px-4 py-3 text-sm text-gray-900">@tx.Description</td>
                                    <td class="px-4 py-3 text-sm text-right font-medium @(tx.Amount >= 0 ? "text-green-600" : "text-red-600")">
                                        €@tx.Amount.ToString("N2")
                                    </td>
                                    <td class="px-4 py-3 text-sm text-gray-600">@(tx.CategoryName ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-gray-400 text-center py-4">No recent transactions.</p>
            }
        </div>
    }
</div>

<script src="~/js/charts.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var categoryData = @Html.Raw(Json.Serialize(Model.SpendingByCategory));
        var monthlyData = @Html.Raw(Json.Serialize(Model.MonthlyTrends));
        var yearlyData = @Html.Raw(Json.Serialize(Model.YearlyComparison));

        initCategoryPieChart('categoryPieChart', categoryData);
        initMonthlyTrendsChart('monthlyTrendsChart', monthlyData);
        initYearlyComparisonChart('yearlyComparisonChart', yearlyData, '@(DateTime.UtcNow.Year - 1)', '@DateTime.UtcNow.Year');
    });
</script>
