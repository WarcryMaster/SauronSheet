@page "/Dashboard"
@model DashboardModel
@using System.Text.Json

@{
    ViewData["Title"] = "Dashboard";
    ViewData["DateFilter"] = Model.DateFilter;
    ViewData["CustomFromDate"] = Model.CustomFromDate?.ToString("yyyy-MM-dd");
    ViewData["CustomToDate"] = Model.CustomToDate?.ToString("yyyy-MM-dd");
}

<div class="space-y-6">
    <!-- Date Range Filter -->
    <form method="get" action="/Dashboard">
        <partial name="Shared/Components/_DateRangeFilter" />
    </form>

    @if (Model.Summary?.TransactionCount == 0)
    {
        <!-- Empty State -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-12 text-center">
            <div class="text-5xl mb-4">📊</div>
            <p class="text-xl font-semibold text-gray-700 mb-2">No spending data yet</p>
            <p class="text-gray-400 mb-8">Import a PDF or add transactions to see analytics.</p>
            <div class="flex justify-center gap-4">
                <a href="/Transactions/Upload" class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-white bg-brand-600 rounded-lg hover:bg-brand-700 transition-colors duration-200 shadow-sm">📄 Upload PDF</a>
                <a href="/Transactions/Add" class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors duration-200">➕ Add Transaction</a>
            </div>
        </div>
    }
    else
    {
        <!-- Summary Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">📈 Total Income</div>
                <div class="mt-1 text-2xl font-bold text-brand-600">€@Model.Summary?.TotalIncome.ToString("N2")</div>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">📉 Total Expenses</div>
                <div class="mt-1 text-2xl font-bold text-red-500">€@Model.Summary?.TotalExpenses.ToString("N2")</div>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">💰 Net Amount</div>
                <div class="mt-1 text-2xl font-bold @(Model.Summary?.NetAmount >= 0 ? "text-brand-600" : "text-red-500")">
                    €@Model.Summary?.NetAmount.ToString("N2")
                </div>
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">📊 Transactions</div>
                <div class="mt-1 text-2xl font-bold text-gray-700">@Model.Summary?.TransactionCount</div>
            </div>
        </div>

        <!-- Charts -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h3 class="text-base font-semibold text-gray-800 mb-4">Spending by Category</h3>
                @if (Model.SpendingByCategory.Any())
                {
                    <canvas id="categoryPieChart"></canvas>
                }
                else
                {
                    <p class="text-gray-400 text-center py-8">No expense data for this period.</p>
                }
            </div>
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
                <h3 class="text-base font-semibold text-gray-800 mb-4">Monthly Trends</h3>
                <canvas id="monthlyTrendsChart"></canvas>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <h3 class="text-base font-semibold text-gray-800 mb-4">Year over Year Comparison</h3>
            <canvas id="yearlyComparisonChart"></canvas>
        </div>

        <!-- Recent Transactions -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-base font-semibold text-gray-800">Recent Transactions</h3>
                <a href="/Transactions" class="text-sm font-medium text-brand-600 hover:text-brand-700">View all →</a>
            </div>
            @if (Model.RecentTransactions.Any())
            {
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Description</th>
                                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Amount</th>
                                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Category</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-100">
                            @foreach (var tx in Model.RecentTransactions)
                            {
                                <tr class="hover:bg-gray-50 transition-colors">
                                    <td class="px-4 py-3 text-sm text-gray-500">@tx.Date.ToString("MMM dd, yyyy")</td>
                                    <td class="px-4 py-3 text-sm text-gray-900">@tx.Description</td>
                                    <td class="px-4 py-3 text-sm text-right font-semibold @(tx.Amount >= 0 ? "text-brand-600" : "text-red-500")">
                                        €@tx.Amount.ToString("N2")
                                    </td>
                                    <td class="px-4 py-3 text-sm text-gray-500">@(tx.CategoryName ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-gray-400 text-center py-4">No recent transactions.</p>
            }
        </div>

        <!-- Budget Status Widget -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-base font-semibold text-gray-800">💰 Budget Status</h3>
                <a href="/Budgets" class="text-sm font-medium text-brand-600 hover:text-brand-700">Manage &rarr;</a>
            </div>
            @if (Model.BudgetSummary == null || Model.BudgetSummary.TotalBudgets == 0)
            {
                <p class="text-gray-500 text-sm">No budgets set.
                   <a href="/Budgets/Create" class="text-brand-600 hover:text-brand-700 font-medium">
                      Create budgets to track spending.
                   </a>
                </p>
            }
            else
            {
                <p class="text-sm text-gray-600 mb-3">
                    @Model.BudgetSummary.OnTrackCount of @Model.BudgetSummary.TotalBudgets budgets on track
                    @if (Model.BudgetSummary.OverBudgetCount > 0)
                    {
                        <span class="text-red-600 font-medium">
                            — @Model.BudgetSummary.OverBudgetCount over limit
                        </span>
                    }
                </p>
                @foreach (var budget in Model.BudgetSummary.Budgets)
                {
                    <div class="mb-3">
                        <div class="flex justify-between text-sm mb-1">
                            <a href="/Budgets/Detail/@budget.Id" class="hover:underline">
                                @budget.CategoryName
                            </a>
                            <span>€@budget.CurrentSpend.ToString("N2") / €@budget.LimitAmount.ToString("N2")</span>
                        </div>
                        <partial name="Shared/_BudgetProgressBar" model="budget" />
                    </div>
                }
            }
        </div>
    }
</div>

<script src="~/js/charts.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var categoryData = @Html.Raw(Json.Serialize(Model.SpendingByCategory));
        var monthlyData = @Html.Raw(Json.Serialize(Model.MonthlyTrends));
        var yearlyData = @Html.Raw(Json.Serialize(Model.YearlyComparison));

        initCategoryPieChart('categoryPieChart', categoryData);
        initMonthlyTrendsChart('monthlyTrendsChart', monthlyData);
        initYearlyComparisonChart('yearlyComparisonChart', yearlyData, '@(DateTime.UtcNow.Year - 1)', '@DateTime.UtcNow.Year');
    });
</script>
