@page "/dashboard"
@model DashboardModel
@using System.Text.Json
@using SauronSheet.Frontend.Helpers

@{
    ViewData["Title"] = "Dashboard";
    ViewData["DateFilter"] = Model.DateFilter;
    ViewData["CustomFromDate"] = Model.CustomFromDate?.ToString("yyyy-MM-dd");
    ViewData["CustomToDate"] = Model.CustomToDate?.ToString("yyyy-MM-dd");
}

<div class="d-flex flex-column gap-4">
    <!-- Date Range Filter -->
    <form method="get" action="/dashboard">
        <partial name="Shared/Components/_DateRangeFilter" />
    </form>

    @if (Model.Summary?.TransactionCount == 0)
    {
        <!-- Empty State -->
        <div class="card border-0 shadow-sm p-5 text-center">
            <div class="fs-1 mb-3">📊</div>
            <p class="h5 fw-semibold mb-2">No spending data yet</p>
            <p class="text-muted mb-4">Import a bank statement or add transactions to see analytics.</p>
            <div class="d-flex justify-content-center gap-3">
                <a href="/transactions/upload" class="btn btn-brand">📊 Upload Statement</a>
                <a href="/transactions/add" class="btn btn-outline-secondary">➕ Add Transaction</a>
            </div>
        </div>
    }
    else
    {
        <!-- Summary Cards -->
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-3">
            <div class="col">
                <div class="card border-0 shadow-sm h-100 p-3">
                    <div class="small fw-semibold text-muted text-uppercase mb-1">Total Income</div>
                    <div class="h4 fw-bold text-success mb-0">€@Model.Summary?.TotalIncome.ToString("N2")</div>
                </div>
            </div>
            <div class="col">
                <div class="card border-0 shadow-sm h-100 p-3">
                    <div class="small fw-semibold text-muted text-uppercase mb-1">Total Expenses</div>
                    <div class="h4 fw-bold text-danger mb-0">€@Model.Summary?.TotalExpenses.ToString("N2")</div>
                </div>
            </div>
            <div class="col">
                <div class="card border-0 shadow-sm h-100 p-3">
                    <div class="small fw-semibold text-muted text-uppercase mb-1">Net Amount</div>
                    <div class="h4 fw-bold mb-0 @(Model.Summary?.NetAmount >= 0 ? "text-success" : "text-danger")">
                        €@Model.Summary?.NetAmount.ToString("N2")
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card border-0 shadow-sm h-100 p-3">
                    <div class="small fw-semibold text-muted text-uppercase mb-1">Transactions</div>
                    <div class="h4 fw-bold text-dark mb-0">@Model.Summary?.TransactionCount</div>
                </div>
            </div>
        </div>

        <!-- Charts -->
        <div class="row g-4">
            <div class="col-12 col-lg-6">
                <div class="card border-0 shadow-sm p-4 h-100 d-flex flex-column">
                    <h3 class="h6 fw-semibold mb-3">Spending by Category</h3>
                    <div class="chart-wrapper flex-grow-1">
                        @if (Model.MonthlySpendingByCategory.Any())
                        {
                            <canvas id="categoryStackedChart"></canvas>
                        }
                        else
                        {
                            <p class="text-muted text-center py-4">No expense data for this period.</p>
                        }
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-6">
                <div class="card border-0 shadow-sm p-4 h-100 d-flex flex-column">
                    <h3 class="h6 fw-semibold mb-3">Monthly Trends</h3>
                    <div class="chart-wrapper flex-grow-1">
                        <canvas id="monthlyTrendsChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm p-4">
            <h3 class="h6 fw-semibold mb-3">Year over Year Comparison</h3>
            <div class="chart-wrapper" style="height: 320px;">
                <canvas id="yearlyComparisonChart"></canvas>
            </div>
        </div>

        <!-- Recent Transactions -->
        <div class="card border-0 shadow-sm p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3 class="h6 fw-semibold mb-0">Recent Transactions</h3>
                <a href="/transactions" class="small text-brand">View all →</a>
            </div>
            @if (Model.RecentTransactions.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="text-uppercase small fw-semibold text-muted">Date</th>
                                <th class="text-uppercase small fw-semibold text-muted">Description</th>
                                <th class="text-uppercase small fw-semibold text-muted text-end">Amount</th>
                                <th class="text-uppercase small fw-semibold text-muted">Category</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tx in Model.RecentTransactions)
                            {
                                <tr>
                                    <td class="text-muted small">@tx.Date.ToString("dd/MM/yyyy")</td>
                                    <td class="small">@tx.Description</td>
                                    <td class="small text-end fw-semibold @(tx.Amount >= 0 ? "text-success" : "text-danger")">
                                        €@tx.Amount.ToString("N2")
                                    </td>
                                    <td>
                                        <partial name="Shared/_CategoryBadge" model="TransactionCategoryDisplayHelper.BuildBadge(tx)" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted text-center py-3">No recent transactions.</p>
            }
        </div>

        <!-- Budget Status Widget -->
        <div class="card border-0 shadow-sm p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3 class="h6 fw-semibold mb-0">Budget Status</h3>
                <a href="/budgets" class="small text-brand">Manage &rarr;</a>
            </div>
            @if (!Model.BudgetMetrics.Any())
            {
                <p class="text-muted small">No budgets set.
                   <a href="/budgets/create" class="text-brand fw-semibold">Create budgets to track spending.</a>
                </p>
            }
            else
            {
                <!-- Overall summary line -->
                <p class="small text-muted mb-3">
                    @Model.BudgetMetrics.Count budget(s) this month
                    —
                    <span class="fw-semibold @(Model.BudgetTotalPercentageUsed > 100 ? "text-danger" : Model.BudgetTotalPercentageUsed >= 75 ? "text-warning" : "text-success")">
                        @Model.BudgetTotalPercentageUsed.ToString("N1")% consumed
                    </span>
                </p>

                <!-- Status count chips -->
                <div class="d-flex flex-wrap gap-2 mb-3">
                    @if (Model.BudgetGreenCount > 0)
                    {
                        <span class="badge bg-success rounded-pill">@Model.BudgetGreenCount On Track</span>
                    }
                    @if (Model.BudgetYellowCount > 0)
                    {
                        <span class="badge bg-warning text-dark rounded-pill">@Model.BudgetYellowCount Warning</span>
                    }
                    @if (Model.BudgetRedCount > 0)
                    {
                        <span class="badge bg-danger rounded-pill">@Model.BudgetRedCount Near Limit</span>
                    }
                    @if (Model.BudgetOverageCount > 0)
                    {
                        <span class="badge bg-danger rounded-pill">@Model.BudgetOverageCount Over</span>
                    }
                </div>

                <!-- Per-budget progress bars -->
                @foreach (var metric in Model.BudgetMetrics)
                {
                    var pct = Math.Min(metric.PercentageUsed, 100);
                    var barColor = metric.StatusLevel switch
                    {
                        "Green" => "bg-success",
                        "Yellow" => "bg-warning",
                        "Red" => "bg-danger",
                        "Overage" => "bg-danger",
                        _ => "bg-secondary"
                    };

                    <div class="mb-3">
                        <div class="d-flex justify-content-between small mb-1">
                            <a href="/budgets/metrics" class="text-decoration-none">
                                <span class="fw-medium">@metric.CategoryName</span>
                            </a>
                            <span>&euro;@metric.Spent.ToString("N0") / &euro;@metric.AccumulatedLimit.ToString("N0")</span>
                        </div>
                        <div class="progress rounded-pill" style="height:10px" role="progressbar"
                             aria-valuenow="@((int)pct)" aria-valuemin="0" aria-valuemax="100">
                            <div class="progress-bar @barColor transition" style="width:@(pct)%"></div>
                        </div>
                        <div class="d-flex justify-content-between small text-muted mt-1">
                            <span>                            @Math.Round(metric.PercentageUsed, 1)% used</span>
                            <span class="@(metric.Remaining >= 0 ? "text-success" : "text-danger")">
                                &euro;@metric.Remaining.ToString("N0") left
                            </span>
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>

<script type="application/json" id="dashboard-category-data">
    @Json.Serialize(Model.SpendingByCategory)
</script>
<script type="application/json" id="dashboard-monthly-category-data">
    @Json.Serialize(Model.MonthlySpendingByCategory)
</script>
<script type="application/json" id="dashboard-monthly-trends">
    @Json.Serialize(Model.MonthlyTrends)
</script>
<script type="application/json" id="dashboard-yearly-comparison">
    @Json.Serialize(Model.YearlyComparison)
</script>

<script src="~/js/charts.js" asp-append-version="true"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Read pre-serialized JSON from <script type="application/json"> blocks above.
        // See docs/adr/0002-safe-json-data-passing.md for the rationale.
        const readJson = (id) => JSON.parse(document.getElementById(id).textContent);
        const categoryData = readJson('dashboard-category-data');
        const monthlyCategoryData = readJson('dashboard-monthly-category-data');
        const monthlyData = readJson('dashboard-monthly-trends');
        const yearlyData = readJson('dashboard-yearly-comparison');

        initCategoryStackedChart('categoryStackedChart', monthlyCategoryData);
        initMonthlyTrendsChart('monthlyTrendsChart', monthlyData);
        initYearlyComparisonChart('yearlyComparisonChart', yearlyData, '@(Model.AnalyticsYear - 1)', '@Model.AnalyticsYear');
    });
</script>
