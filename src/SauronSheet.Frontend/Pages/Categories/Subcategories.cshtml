@page "{categoryId:guid?}"
@model SauronSheet.Frontend.Pages.Categories.SubcategoriesModel
@using Microsoft.Extensions.Localization
@using SauronSheet.Application.Resources
@inject IStringLocalizer<SharedResources> Localizer
@{
    ViewData["Title"] = string.Format(Localizer["Categories.Subcategories.Title"], Model.ParentCategory?.Name);
}

<div class="d-flex flex-column gap-4" x-data x-init="setupEventListeners()">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Categories">@Localizer["Categories.Subcategories.Breadcrumb"]</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.ParentCategory?.Name</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h3 class="h3 fw-bold mb-2">@string.Format(Localizer["Categories.Subcategories.Heading"], Model.ParentCategory?.Name)</h3>
            <p class="text-muted mb-0">@Localizer["Categories.Subcategories.Description"]</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/Categories" class="btn btn-outline-secondary" aria-label="@Localizer["Categories.Subcategories.Back"]">
                &larr; @Localizer["Categories.Subcategories.Back"]
            </a>
            <button type="button" class="btn btn-brand" @@click="openCreateModal()" aria-label="@Localizer["Categories.Subcategories.AddNewSubcategory"]" data-testid="add-subcategory-btn">
                + @Localizer["Categories.Subcategories.AddNewSubcategory"]
            </button>
        </div>
    </div>

    <div class="list-group" role="region" aria-label="@Localizer["Categories.Subcategories.ListAriaLabel"]">
        @if (Model.Subcategories.Any())
        {
            @foreach (var subcategory in Model.Subcategories.OrderBy(s => s.Name))
            {
                <div class="list-group-item d-flex justify-content-between align-items-center" role="listitem">
                    <div class="d-flex align-items-center gap-2">
                        <span class="fw-bold">@subcategory.Name</span>
                        @if (subcategory.IsAutoCreated)
                        {
                            <span class="badge bg-light text-info border">@Localizer["Categories.Index.AutoCreated"]</span>
                        }
                    </div>
                    <div>
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary me-2 js-edit-subcategory"
                                data-subcategory-id="@subcategory.Id"
                                data-subcategory-name="@subcategory.Name"
                                @@click="openEditModal({ id: $el.dataset.subcategoryId, name: $el.dataset.subcategoryName })"
                                aria-label="@string.Format(Localizer["Categories.Subcategories.EditAriaLabel"], subcategory.Name)"
                                data-testid="edit-subcategory-btn">
                            @Localizer["Common.Edit"]
                        </button>
                        <button type="button"
                                class="btn btn-sm btn-outline-danger js-delete-subcategory"
                                data-subcategory-id="@subcategory.Id"
                                data-subcategory-name="@subcategory.Name"
                                @@click="showDeleteConfirm($el.dataset.subcategoryId, $el.dataset.subcategoryName)"
                                aria-label="@string.Format(Localizer["Categories.Subcategories.DeleteAriaLabel"], subcategory.Name)"
                                data-testid="delete-subcategory-btn">
                            @Localizer["Common.Delete"]
                        </button>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-muted text-center py-3">@Localizer["Categories.Subcategories.Empty"]</div>
        }
    </div>
</div>

<!-- Create Subcategory Modal -->
<div class="modal fade" id="createSubcategoryModal" tabindex="-1" aria-labelledby="createSubcategoryLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createSubcategoryLabel">@Localizer["Categories.Modal.Create.SubcategoryTitle"]</h5>
                <button type="button" class="btn-close" @@click="closeModal('createSubcategoryModal')" aria-label="@Localizer["Common.Close"]"></button>
            </div>
            <form id="createForm" method="post" asp-page-handler="Create" asp-route-categoryId="@Model.ParentCategory?.Id" @@submit.prevent="validateCreateForm($event)">
                <div class="modal-body">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="createName" class="form-label fw-semibold">@Localizer["Categories.Modal.Create.SubcategoryNameLabel"] <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="createName" name="CreateForm.Name" maxlength="50" required
                               aria-describedby="nameError" aria-required="true"
                               @@input="updateCharCounter('charCounter', $el.value.length); $el.classList.remove('is-invalid'); validateCreateForm()" />
                        <div id="nameError" class="invalid-feedback">@Localizer["Categories.Modal.Create.SubcategoryNameRequired"]</div>
                        <div class="form-text text-end">@Html.Raw(string.Format(Localizer["Categories.Modal.Create.CharCount"].Value, "<span id=\"charCounter\">0</span>"))</div>
                    </div>

                    <div id="createError" class="alert alert-danger rounded-3 d-none" role="alert" aria-live="polite" aria-atomic="true"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @@click="closeModal('createSubcategoryModal')">@Localizer["Common.Cancel"]</button>
                    <button type="submit" class="btn btn-brand" id="createSubmitBtn" disabled>@Localizer["Categories.Modal.Create.SaveSubcategory"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Subcategory Modal -->
<div class="modal fade" id="editSubcategoryModal" tabindex="-1" aria-labelledby="editSubcategoryLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editSubcategoryLabel">@Localizer["Categories.Modal.Edit.SubcategoryTitle"]</h5>
                <button type="button" class="btn-close" @@click="closeModal('editSubcategoryModal')" aria-label="@Localizer["Common.Close"]"></button>
            </div>
            <form id="editForm" method="post" asp-page-handler="Update" @@submit.prevent="validateEditForm($event)">
                <div class="modal-body">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="editSubcategoryId" name="EditForm.SubcategoryId" />

                    <div class="mb-3">
                        <label for="editName" class="form-label fw-semibold">@Localizer["Categories.Modal.Create.SubcategoryNameLabel"] <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="editName" name="EditForm.Name" maxlength="50" required aria-required="true"
                               @@input="updateCharCounter('editCharCounter', $el.value.length)" />
                        <div class="form-text text-end">@Html.Raw(string.Format(Localizer["Categories.Modal.Create.CharCount"].Value, "<span id=\"editCharCounter\">0</span>"))</div>
                    </div>

                    <div id="editError" class="alert alert-danger rounded-3 d-none" role="alert" aria-live="polite" aria-atomic="true"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @@click="closeModal('editSubcategoryModal')">@Localizer["Common.Cancel"]</button>
                    <button type="submit" class="btn btn-brand" id="editSubmitBtn">@Localizer["Categories.Modal.Edit.UpdateSubcategory"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-labelledby="deleteConfirmLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteConfirmLabel">@Localizer["Categories.Modal.Delete.SubcategoryTitle"]</h5>
                <button type="button" class="btn-close" @@click="closeModal('deleteConfirmModal')" aria-label="@Localizer["Common.Close"]"></button>
            </div>
            <div class="modal-body">
                <p>@Html.Raw(string.Format(Localizer["Categories.Modal.Delete.SubcategoryConfirm"], "<strong id=\"deleteSubcategoryName\"></strong>"))</p>
                <p class="text-muted small">@Localizer["Categories.Modal.Delete.Warning"]</p>
                <div id="deleteError" class="alert alert-danger rounded-3 d-none" role="alert" aria-live="polite"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @@click="closeModal('deleteConfirmModal')">@Localizer["Common.Cancel"]</button>
                <button type="button" class="btn btn-danger" id="deleteConfirmBtn" @@click="performDelete()">@Localizer["Common.Delete"]</button>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus,
    .form-select:focus {
        outline: 2px solid var(--brand);
        outline-offset: 2px;
    }

    .btn:focus {
        outline: 2px solid var(--brand);
        outline-offset: 2px;
    }

    .form-text.text-end {
        font-size: 0.75rem;
        color: var(--muted);
        margin-top: 0.25rem;
    }

    .invalid-feedback {
        margin-bottom: 0.25rem;
    }
</style>

<script>
    const subcategoryI18n = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
    {
        errorGeneric = Localizer["Categories.Error.Generic"].Value,
        errorRequestFailed = Localizer["Categories.Error.RequestFailed"].Value
    }));

    let currentDeleteSubcategoryId = null;

    function openCreateModal() {
        const modal = new mdb.Modal(document.getElementById('createSubcategoryModal'));
        modal.show();
    }

    function openEditModal(subcategory) {
        loadEditForm(subcategory);
        const modal = new mdb.Modal(document.getElementById('editSubcategoryModal'));
        modal.show();
    }

    function closeModal(modalId) {
        mdb.Modal.getInstance(document.getElementById(modalId))?.hide();
    }

    // setupEventListeners() is called from Alpine.js x-init on the wrapper div.

    function setupEventListeners() {
        const createModal = document.getElementById('createSubcategoryModal');

        let lastFocusedElement = null;
        const focusableSelectors = 'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])';

        function setupModalFocusTrap(modalElement, initialFocusId) {
            modalElement.addEventListener('shown.bs.modal', function() {
                lastFocusedElement = document.activeElement;
                const initialFocus = document.getElementById(initialFocusId);
                if (initialFocus) initialFocus.focus();

                const focusableElements = modalElement.querySelectorAll(focusableSelectors);
                if (focusableElements.length > 0) {
                    const firstElement = focusableElements[0];
                    const lastElement = focusableElements[focusableElements.length - 1];

                    modalElement.addEventListener('keydown', function(e) {
                        if (e.key === 'Tab') {
                            if (e.shiftKey) {
                                if (document.activeElement === firstElement) {
                                    lastElement.focus();
                                    e.preventDefault();
                                }
                            } else {
                                if (document.activeElement === lastElement) {
                                    firstElement.focus();
                                    e.preventDefault();
                                }
                            }
                        }
                        if (e.key === 'Escape') {
                            mdb.Modal.getInstance(modalElement)?.hide();
                        }
                    });
                }
            });

            modalElement.addEventListener('hidden.bs.modal', function() {
                if (lastFocusedElement) {
                    lastFocusedElement.focus();
                    lastFocusedElement = null;
                }
            });
        }

        if (createModal) {
            setupModalFocusTrap(createModal, 'createName');
        }

        const editModal = document.getElementById('editSubcategoryModal');
        if (editModal) {
            setupModalFocusTrap(editModal, 'editName');
        }

        const deleteConfirmModalEl = document.getElementById('deleteConfirmModal');
        if (deleteConfirmModalEl) {
            setupModalFocusTrap(deleteConfirmModalEl, 'deleteConfirmBtn');
        }
    }

    function updateCharCounter(elementId, length) {
        const element = document.getElementById(elementId);
        if (element) {
            element.textContent = length;
        }
    }

    function validateCreateForm(event) {
        const name = document.getElementById('createName').value.trim();
        const submitBtn = document.getElementById('createSubmitBtn');

        const isValid = name.length > 0;
        submitBtn.disabled = !isValid;

        if (event && event.submitter === submitBtn) {
            if (!isValid) {
                const nameInput = document.getElementById('createName');
                nameInput.classList.add('is-invalid');
                return false;
            }

            submitCreateForm(event);
            return false;
        }

        return isValid;
    }

    function submitCreateForm(event) {
        event.preventDefault();
        const form = document.getElementById('createForm');
        const formData = new FormData(form);

        fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: {
                'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]')?.value || ''
            }
        })
        .then(r => {
            const contentType = r.headers.get('content-type') || '';
            const isJson = contentType.includes('application/json');

            if (!r.ok) {
                if (typeof Sentry !== 'undefined') {
                    Sentry.captureMessage('Subcategory create request failed with HTTP error', {
                        level: 'error',
                        tags: { operation: 'subcategory-create', http_status: String(r.status) }
                    });
                }
                return isJson ? r.json().then(body => ({ ok: false, body }))
                              : Promise.resolve({ ok: false, body: null });
            }
            return r.json().then(body => ({ ok: true, body }));
        })
        .then(payload => {
            const data = payload.body;
            if (data && data.success) {
                mdb.Modal.getInstance(document.getElementById('createSubcategoryModal'))?.hide();
                location.reload();
            } else {
                document.getElementById('createError').textContent =
                    (data && data.error) || subcategoryI18n.errorGeneric;
                document.getElementById('createError').classList.remove('d-none');
                if (payload.ok && typeof Sentry !== 'undefined') {
                    Sentry.captureMessage('Subcategory create returned success:false', {
                        level: 'warning',
                        tags: { operation: 'subcategory-create' }
                    });
                }
            }
        })
        .catch(err => {
            document.getElementById('createError').textContent = subcategoryI18n.errorRequestFailed;
            document.getElementById('createError').classList.remove('d-none');
            if (typeof Sentry !== 'undefined') {
                Sentry.captureException(
                    err instanceof Error ? err : new Error('Subcategory create fetch failed'),
                    { tags: { operation: 'subcategory-create', source: 'fetch-catch' } }
                );
            }
        });
    }

    function validateEditForm(event) {
        const name = document.getElementById('editName').value.trim();
        const submitBtn = document.getElementById('editSubmitBtn');

        if (!name) {
            event.preventDefault();
            return false;
        }

        submitEditForm(event);
        return false;
    }

    function submitEditForm(event) {
        event.preventDefault();
        const form = document.getElementById('editForm');
        const formData = new FormData(form);

        fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: {
                'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]')?.value || ''
            }
        })
        .then(r => {
            const contentType = r.headers.get('content-type') || '';
            const isJson = contentType.includes('application/json');

            if (!r.ok) {
                if (typeof Sentry !== 'undefined') {
                    Sentry.captureMessage('Subcategory update request failed with HTTP error', {
                        level: 'error',
                        tags: { operation: 'subcategory-update', http_status: String(r.status) }
                    });
                }
                return isJson ? r.json().then(body => ({ ok: false, body }))
                              : Promise.resolve({ ok: false, body: null });
            }
            return r.json().then(body => ({ ok: true, body }));
        })
        .then(payload => {
            const data = payload.body;
            if (data && data.success) {
                mdb.Modal.getInstance(document.getElementById('editSubcategoryModal'))?.hide();
                location.reload();
            } else {
                document.getElementById('editError').textContent =
                    (data && data.error) || subcategoryI18n.errorGeneric;
                document.getElementById('editError').classList.remove('d-none');
                if (payload.ok && typeof Sentry !== 'undefined') {
                    Sentry.captureMessage('Subcategory update returned success:false', {
                        level: 'warning',
                        tags: { operation: 'subcategory-update' }
                    });
                }
            }
        })
        .catch(err => {
            document.getElementById('editError').textContent = subcategoryI18n.errorRequestFailed;
            document.getElementById('editError').classList.remove('d-none');
            if (typeof Sentry !== 'undefined') {
                Sentry.captureException(
                    err instanceof Error ? err : new Error('Subcategory update fetch failed'),
                    { tags: { operation: 'subcategory-update', source: 'fetch-catch' } }
                );
            }
        });
    }

    function loadEditForm(subcategory) {
        document.getElementById('editSubcategoryId').value = subcategory.id;
        document.getElementById('editName').value = subcategory.name;
        document.getElementById('editError').classList.add('d-none');
        updateCharCounter('editCharCounter', subcategory.name.length);
    }

    function showDeleteConfirm(subcategoryId, subcategoryName) {
        currentDeleteSubcategoryId = subcategoryId;
        document.getElementById('deleteSubcategoryName').textContent = subcategoryName;
        document.getElementById('deleteError').classList.add('d-none');
        const modal = new mdb.Modal(document.getElementById('deleteConfirmModal'));
        modal.show();
    }

    function performDelete() {
        if (!currentDeleteSubcategoryId) return;

        fetch(`?handler=Delete&subcategoryId=${currentDeleteSubcategoryId}`, {
            method: 'POST',
            headers: {
                'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]')?.value || ''
            }
        })
        .then(r => {
            const contentType = r.headers.get('content-type') || '';
            const isJson = contentType.includes('application/json');

            if (!r.ok) {
                if (typeof Sentry !== 'undefined') {
                    Sentry.captureMessage('Subcategory delete request failed with HTTP error', {
                        level: 'error',
                        tags: { operation: 'subcategory-delete', http_status: String(r.status) }
                    });
                }
                return isJson ? r.json().then(body => ({ ok: false, body }))
                              : Promise.resolve({ ok: false, body: null });
            }
            return r.json().then(body => ({ ok: true, body }));
        })
        .then(payload => {
            const data = payload.body;
            if (data && data.success) {
                mdb.Modal.getInstance(document.getElementById('deleteConfirmModal'))?.hide();
                location.reload();
            } else {
                document.getElementById('deleteError').textContent =
                    (data && data.error) || subcategoryI18n.errorGeneric;
                document.getElementById('deleteError').classList.remove('d-none');
                if (payload.ok && typeof Sentry !== 'undefined') {
                    Sentry.captureMessage('Subcategory delete returned success:false', {
                        level: 'warning',
                        tags: { operation: 'subcategory-delete' }
                    });
                }
            }
        })
        .catch(err => {
            document.getElementById('deleteError').textContent = subcategoryI18n.errorRequestFailed;
            document.getElementById('deleteError').classList.remove('d-none');
            if (typeof Sentry !== 'undefined') {
                Sentry.captureException(
                    err instanceof Error ? err : new Error('Subcategory delete fetch failed'),
                    { tags: { operation: 'subcategory-delete', source: 'fetch-catch' } }
                );
            }
        });
    }
</script>
