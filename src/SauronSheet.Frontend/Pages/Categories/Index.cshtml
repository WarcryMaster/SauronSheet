@page
@model SauronSheet.Frontend.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "Categories";
}

<div class="d-flex flex-column gap-4">
    <h1 class="h3 fw-bold mb-0">Categories</h1>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success d-flex align-items-center gap-2" role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" class="flex-shrink-0" width="20" height="20" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            <span>@Model.SuccessMessage</span>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger d-flex align-items-center gap-2" role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" class="flex-shrink-0" width="20" height="20" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-10.707a1 1 0 00-1.414-1.414L10 8.586 7.707 6.293a1 1 0 00-1.414 1.414L8.586 10l-2.293 2.293a1 1 0 001.414 1.414L10 11.414l2.293 2.293a1 1 0 001.414-1.414L11.414 10l2.293-2.293z" clip-rule="evenodd"/></svg>
            <span>@Model.ErrorMessage</span>
        </div>
    }

    <!-- Create Category Form -->
    <div class="card border-0 shadow-sm p-4">
        <h2 class="h6 fw-semibold mb-3">Create New Category</h2>
        <form method="post" asp-page-handler="Create">
            <div class="row g-3 mb-3">
                <div class="col-12 col-sm-4">
                    <label for="NewCategory_Name" class="form-label small fw-semibold text-muted text-uppercase">Name</label>
                    <input type="text" id="NewCategory_Name" name="NewCategory.Name" asp-for="NewCategory.Name"
                           class="form-control form-control-sm" placeholder="e.g., Entertainment" required />
                </div>
                <div class="col-12 col-sm-4">
                    <label for="NewCategory_Color" class="form-label small fw-semibold text-muted text-uppercase">Color <span class="text-muted fw-normal">(optional)</span></label>
                    <input type="color" id="NewCategory_Color" name="NewCategory.Color" asp-for="NewCategory.Color"
                           class="form-control form-control-sm form-control-color w-100" />
                </div>
                <div class="col-12 col-sm-4">
                    <label for="NewCategory_Icon" class="form-label small fw-semibold text-muted text-uppercase">Icon <span class="text-muted fw-normal">(optional)</span></label>
                    <input type="text" id="NewCategory_Icon" name="NewCategory.Icon" asp-for="NewCategory.Icon"
                           class="form-control form-control-sm" placeholder="e.g., 🎬" />
                </div>
            </div>
            <button type="submit" class="btn btn-brand btn-sm">+ Create Category</button>
        </form>
    </div>

    <!-- Categories List -->
    @if (!Model.Categories.Any())
    {
        <div class="card border-0 shadow-sm p-5 text-center" role="status" aria-live="polite">
            <div class="fs-1 mb-3">🏷️</div>
            <p class="h5 fw-semibold mb-2">No categories yet</p>
            <p class="text-muted">Create a category above to organize your transactions.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <ul class="list-group list-group-flush">
                @foreach (var category in Model.Categories)
                {
                    <li class="list-group-item d-flex align-items-center justify-content-between gap-3 px-4 py-3">
                        <div class="d-flex align-items-center gap-2 min-w-0">
                            @if (!string.IsNullOrEmpty(category.Icon))
                            {
                                <span class="fs-5 flex-shrink-0">@category.Icon</span>
                            }
                            @if (!string.IsNullOrEmpty(category.Color))
                            {
                                <span class="flex-shrink-0 d-inline-block rounded-circle" style="width:14px;height:14px;background-color:@category.Color"></span>
                            }
                            <div class="min-w-0">
                                <p class="mb-0 small fw-semibold d-flex align-items-center gap-1">
                                    @if (category.IsSystemDefault)
                                    {
                                        <span class="text-muted" title="System default">🔒</span>
                                    }
                                    @category.Name
                                </p>
                                <p class="mb-0 small text-muted">@category.TransactionCount transaction@(category.TransactionCount != 1 ? "s" : "")</p>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2 flex-shrink-0">
                            @if (!category.IsSystemDefault)
                            {
                                <form method="post" asp-page-handler="Rename" asp-route-categoryId="@category.Id" class="d-flex align-items-center gap-1">
                                    <input type="text" name="newName" placeholder="New name" required
                                           class="form-control form-control-sm" style="width:110px" />
                                    <button type="submit" class="btn btn-warning btn-sm">Rename</button>
                                </form>
                                @if (category.TransactionCount == 0)
                                {
                                    <form method="post" asp-page-handler="Delete" asp-route-categoryId="@category.Id">
                                        <button type="submit" onclick="return confirm('Delete this category?')"
                                                class="btn btn-danger btn-sm">Delete</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="small text-muted fst-italic">has transactions</span>
                                }
                            }
                            else
                            {
                                <span class="small text-muted fst-italic">System default</span>
                            }
                        </div>
                    </li>
                }
            </ul>
        </div>
    }
</div>
