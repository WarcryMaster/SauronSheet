@page
@model SauronSheet.Frontend.Pages.Categories.IndexModel
@using SauronSheet.Domain.ValueObjects
@using Microsoft.Extensions.Localization
@using SauronSheet.Application.Resources
@inject IStringLocalizer<SharedResources> Localizer
@{
    ViewData["Title"] = Localizer["Categories.Index.Title"];

    string GetDisplayName(SauronSheet.Application.Features.Categories.DTOs.CategoryDto category)
    {
        if (!category.IsSystemDefault || string.IsNullOrWhiteSpace(category.SystemSlug))
        {
            return category.Name;
        }

        string key = $"category.system.{category.SystemSlug}";
        LocalizedString localized = Localizer[key];
        return localized.ResourceNotFound ? category.Name : localized.Value;
    }
}

<script>
    // i18n data for Alpine.js — defined outside x-data to avoid JSON-in-HTML-attribute quoting issues
    window.__categoryI18n = {
        errorGeneric: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Categories.Error.Generic"].Value)),
        errorRequestFailed: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Categories.Error.RequestFailed"].Value)),
        charCount: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Categories.Modal.Create.CharCount"].Value))
    };
</script>

<div class="d-flex flex-column gap-4" x-data="{
    currentDeleteCategoryId: null,
    deleteCategoryName: '',
    createName: '',
    createType: '',
    createIcon: '',
    createColor: '#3498DB',
    createError: '',
    createCharCount: 0,
    editCategoryId: '',
    editName: '',
    editColor: '',
    editIcon: '',
    editError: '',
    editCharCount: 0,
    deleteError: '',
    categoryI18n: window.__categoryI18n,

    get createValid() {
        return this.createName.trim() && this.createType && this.createIcon;
    },
    get editValid() {
        return this.editName.trim();
    },

    openCreateModal() {
        this.createName = '';
        this.createType = '';
        this.createColor = '#3498DB';
        this.createIcon = '';
        this.createError = '';
        this.createCharCount = 0;
        new mdb.Modal(document.getElementById('createCategoryModal')).show();
    },

    openEditModal(category) {
        this.editCategoryId = category.id;
        this.editName = category.name;
        this.editColor = category.color;
        this.editIcon = category.iconName;
        this.editError = '';
        this.editCharCount = category.name.length;
        new mdb.Modal(document.getElementById('editCategoryModal')).show();
    },

    closeModal(modalId) {
        mdb.Modal.getInstance(document.getElementById(modalId))?.hide();
    },

    showDeleteConfirm(categoryId, categoryName) {
        this.currentDeleteCategoryId = categoryId;
        this.deleteCategoryName = categoryName;
        this.deleteError = '';
        new mdb.Modal(document.getElementById('deleteConfirmModal')).show();
    },

    async submitCreateForm(event) {
        event.preventDefault();
        if (!this.createValid) return;
        const form = document.getElementById('createForm');
        const formData = new FormData(form);
        const csrfToken = document.querySelector(`[name='__RequestVerificationToken']`)?.value || '';

        try {
            const r = await fetch(form.action, {
                method: 'POST',
                body: formData,
                headers: { 'RequestVerificationToken': csrfToken }
            });
            const contentType = r.headers.get('content-type') || '';
            const isJson = contentType.includes('application/json');

            if (!r.ok) {
                if (typeof Sentry !== 'undefined') {
                    Sentry.captureMessage('Category create request failed with HTTP error', {
                        level: 'error',
                        tags: { operation: 'category-create', http_status: String(r.status) }
                    });
                }
                const body = isJson ? await r.json() : null;
                this.createError = (body && body.error) || this.categoryI18n.errorGeneric;
                return;
            }
            const data = await r.json();
            if (data && data.success) {
                mdb.Modal.getInstance(document.getElementById('createCategoryModal'))?.hide();
                location.reload();
            } else {
                this.createError = (data && data.error) || this.categoryI18n.errorGeneric;
                if (typeof Sentry !== 'undefined') {
                    Sentry.captureMessage('Category create returned success:false', {
                        level: 'warning',
                        tags: { operation: 'category-create' }
                    });
                }
            }
        } catch (err) {
            this.createError = this.categoryI18n.errorRequestFailed;
            if (typeof Sentry !== 'undefined') {
                Sentry.captureException(
                    err instanceof Error ? err : new Error('Category create fetch failed'),
                    { tags: { operation: 'category-create', source: 'fetch-catch' } }
                );
            }
        }
    },

    async submitEditForm(event) {
        event.preventDefault();
        if (!this.editValid) return;
        const form = document.getElementById('editForm');
        const formData = new FormData(form);
        const csrfToken = document.querySelector(`[name='__RequestVerificationToken']`)?.value || '';

        try {
            const r = await fetch(form.action, {
                method: 'POST',
                body: formData,
                headers: { 'RequestVerificationToken': csrfToken }
            });
            const contentType = r.headers.get('content-type') || '';
            const isJson = contentType.includes('application/json');

            if (!r.ok) {
                if (typeof Sentry !== 'undefined') {
                    Sentry.captureMessage('Category update request failed with HTTP error', {
                        level: 'error',
                        tags: { operation: 'category-update', http_status: String(r.status) }
                    });
                }
                const body = isJson ? await r.json() : null;
                this.editError = (body && body.error) || this.categoryI18n.errorGeneric;
                return;
            }
            const data = await r.json();
            if (data && data.success) {
                mdb.Modal.getInstance(document.getElementById('editCategoryModal'))?.hide();
                location.reload();
            } else {
                this.editError = (data && data.error) || this.categoryI18n.errorGeneric;
                if (typeof Sentry !== 'undefined') {
                    Sentry.captureMessage('Category update returned success:false', {
                        level: 'warning',
                        tags: { operation: 'category-update' }
                    });
                }
            }
        } catch (err) {
            this.editError = this.categoryI18n.errorRequestFailed;
            if (typeof Sentry !== 'undefined') {
                Sentry.captureException(
                    err instanceof Error ? err : new Error('Category update fetch failed'),
                    { tags: { operation: 'category-update', source: 'fetch-catch' } }
                );
            }
        }
    },

    async performDelete() {
        if (!this.currentDeleteCategoryId) return;
        const csrfToken = document.querySelector(`[name='__RequestVerificationToken']`)?.value || '';

        try {
            const r = await fetch(`?handler=Delete&categoryId=${encodeURIComponent(this.currentDeleteCategoryId)}`, {
                method: 'POST',
                headers: { 'RequestVerificationToken': csrfToken }
            });
            const contentType = r.headers.get('content-type') || '';
            const isJson = contentType.includes('application/json');

            if (!r.ok) {
                if (typeof Sentry !== 'undefined') {
                    Sentry.captureMessage('Category delete request failed with HTTP error', {
                        level: 'error',
                        tags: { operation: 'category-delete', http_status: String(r.status) }
                    });
                }
                const body = isJson ? await r.json() : null;
                this.deleteError = (body && body.error) || this.categoryI18n.errorGeneric;
                return;
            }
            const data = await r.json();
            if (data && data.success) {
                mdb.Modal.getInstance(document.getElementById('deleteConfirmModal'))?.hide();
                location.reload();
            } else {
                this.deleteError = (data && data.error) || this.categoryI18n.errorGeneric;
                if (typeof Sentry !== 'undefined') {
                    Sentry.captureMessage('Category delete returned success:false', {
                        level: 'warning',
                        tags: { operation: 'category-delete' }
                    });
                }
            }
        } catch (err) {
            this.deleteError = this.categoryI18n.errorRequestFailed;
            if (typeof Sentry !== 'undefined') {
                Sentry.captureException(
                    err instanceof Error ? err : new Error('Category delete fetch failed'),
                    { tags: { operation: 'category-delete', source: 'fetch-catch' } }
                );
            }
        }
    }
}" x-init="setupModalFocusTraps()">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h3 class="h3 fw-bold mb-2">@Localizer["Categories.Index.Title"]</h3>
            <p class="text-muted mb-0">@Localizer["Categories.Index.Description"]</p>
        </div>
        <button type="button" class="btn btn-brand" @@click="openCreateModal()" aria-label="@Localizer["Categories.Index.AddCategory"]" data-testid="add-category-btn">
            + @Localizer["Categories.Index.AddCategory"]
        </button>
    </div>

    <!-- Category List by Type -->
    <div class="row">
        <div class="col-lg-6 mb-4">
            <h3 class="h5 fw-bold mb-3">@Localizer["Categories.Index.IncomeCategories"]</h3>
            <div class="list-group" role="region" aria-label="@Localizer["Categories.Index.IncomeCategories"]">
                @{
                    var incomeCategories = Model.Categories.Where(c => c.Type == "Income").OrderBy(c => c.Name).ToList();
                }
                @if (incomeCategories.Any())
                {
                    @foreach (var category in incomeCategories)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center" role="listitem">
                            <div class="d-flex align-items-center gap-3">
                                <div class="category-color-chip" style="background-color: @category.Color; width: 24px; height: 24px; border-radius: 4px;" aria-label="Category color @category.Color"></div>
                                <div>
                                    <div class="fw-bold" data-testid="@(category.IsSystemDefault && !string.IsNullOrWhiteSpace(category.SystemSlug) ? "system-category-name" : "custom-category-name")" data-system-slug="@(category.SystemSlug ?? string.Empty)">@GetDisplayName(category)</div>
                                    @if (category.IsAutoCreated)
                                    {
                                        <span class="badge bg-light text-muted border">@Localizer["Categories.Index.AutoCreated"]</span>
                                    }
                                </div>
                            </div>
                            <div>
                                <a href="/Categories/Subcategories?categoryId=@category.Id"
                                   class="btn btn-sm btn-outline-secondary me-2"
                                   aria-label="@Localizer["Categories.Index.Subcategories"] @category.Name">
                                    @Localizer["Categories.Index.Subcategories"]
                                </a>
                                <button type="button"
                                        class="btn btn-sm btn-outline-secondary me-2 js-edit-category"
                                        data-category-id="@category.Id"
                                        data-category-name="@category.Name"
                                        data-category-color="@category.Color"
                                        data-category-icon="@category.IconName"
                                        @@click="openEditModal({ id: $el.dataset.categoryId, name: $el.dataset.categoryName, color: $el.dataset.categoryColor, iconName: $el.dataset.categoryIcon })"
                                        aria-label="@Localizer["Categories.Index.Edit"] @category.Name"
                                        data-testid="edit-category-btn">
                                    @Localizer["Categories.Index.Edit"]
                                </button>
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger js-delete-category"
                                        data-category-id="@category.Id"
                                        data-category-name="@category.Name"
                                        @@click="showDeleteConfirm($el.dataset.categoryId, $el.dataset.categoryName)"
                                        aria-label="@Localizer["Categories.Index.Delete"] @category.Name"
                                        data-testid="delete-category-btn">
                                    @Localizer["Categories.Index.Delete"]
                                </button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-muted text-center py-3">@Localizer["Categories.Index.NoIncomeCategories"]</div>
                }
            </div>
        </div>

        <div class="col-lg-6 mb-4">
            <h3 class="h5 fw-bold mb-3">@Localizer["Categories.Index.ExpenseCategories"]</h3>
            <div class="list-group" role="region" aria-label="@Localizer["Categories.Index.ExpenseCategories"]">
                @{
                    var expenseCategories = Model.Categories.Where(c => c.Type == "Expense").OrderBy(c => c.Name).ToList();
                }
                @if (expenseCategories.Any())
                {
                    @foreach (var category in expenseCategories)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center" role="listitem">
                            <div class="d-flex align-items-center gap-3">
                                <div class="category-color-chip" style="background-color: @category.Color; width: 24px; height: 24px; border-radius: 4px;" aria-label="Category color @category.Color"></div>
                                <div>
                                    <div class="fw-bold" data-testid="@(category.IsSystemDefault && !string.IsNullOrWhiteSpace(category.SystemSlug) ? "system-category-name" : "custom-category-name")" data-system-slug="@(category.SystemSlug ?? string.Empty)">@GetDisplayName(category)</div>
                                    @if (category.IsAutoCreated)
                                    {
                                        <span class="badge bg-light text-muted border">@Localizer["Categories.Index.AutoCreated"]</span>
                                    }
                                </div>
                            </div>
                            <div>
                                <a href="/Categories/Subcategories?categoryId=@category.Id"
                                   class="btn btn-sm btn-outline-secondary me-2"
                                   aria-label="@Localizer["Categories.Index.Subcategories"] @category.Name">
                                    @Localizer["Categories.Index.Subcategories"]
                                </a>
                                <button type="button"
                                        class="btn btn-sm btn-outline-secondary me-2 js-edit-category"
                                        data-category-id="@category.Id"
                                        data-category-name="@category.Name"
                                        data-category-color="@category.Color"
                                        data-category-icon="@category.IconName"
                                        @@click="openEditModal({ id: $el.dataset.categoryId, name: $el.dataset.categoryName, color: $el.dataset.categoryColor, iconName: $el.dataset.categoryIcon })"
                                        aria-label="@Localizer["Categories.Index.Edit"] @category.Name"
                                        data-testid="edit-category-btn">
                                    @Localizer["Categories.Index.Edit"]
                                </button>
                                <button type="button"
                                        class="btn btn-sm btn-outline-danger js-delete-category"
                                        data-category-id="@category.Id"
                                        data-category-name="@category.Name"
                                        @@click="showDeleteConfirm($el.dataset.categoryId, $el.dataset.categoryName)"
                                        aria-label="@Localizer["Categories.Index.Delete"] @category.Name"
                                        data-testid="delete-category-btn">
                                    @Localizer["Categories.Index.Delete"]
                                </button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-muted text-center py-3">@Localizer["Categories.Index.NoExpenseCategories"]</div>
                }
            </div>
        </div>
    </div>

<!-- Create Category Modal -->
<div class="modal fade" id="createCategoryModal" tabindex="-1" aria-labelledby="createCategoryLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createCategoryLabel">@Localizer["Categories.Modal.Create.Title"]</h5>
                <button type="button" class="btn-close" @@click="closeModal('createCategoryModal')" aria-label="@Localizer["Common.Close"]"></button>
            </div>
            <form id="createForm" method="post" asp-page-handler="Create" @@submit.prevent="submitCreateForm($event)">
                <div class="modal-body">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="createName" class="form-label fw-semibold">@Localizer["Categories.Modal.Create.NameLabel"] <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="createName" name="CreateForm.Name" maxlength="50" required
                               aria-describedby="nameError" aria-required="true"
                               x-model="createName"
                               @@input="createCharCount = $el.value.length"
                               :class="{ 'is-invalid': createError && !createName.trim() }" />
                        <div id="nameError" class="invalid-feedback">@Localizer["Categories.Modal.Create.NameRequired"]</div>
                        <div class="form-text text-end"><span x-text="categoryI18n.charCount.replace('{0}', createCharCount)">@Localizer["Categories.Modal.Create.CharCount", 0]</span></div>
                    </div>

                    <div class="mb-3">
                        <label for="createType" class="form-label fw-semibold">@Localizer["Categories.Modal.Create.TypeLabel"] <span class="text-danger">*</span></label>
                        <select class="form-select" id="createType" name="CreateForm.Type" required aria-required="true"
                                x-model="createType">
                            <option value="">@Localizer["Categories.Modal.Create.SelectType"]</option>
                            <option value="0">@Localizer["Categories.Modal.Create.TypeIncome"]</option>
                            <option value="1">@Localizer["Categories.Modal.Create.TypeExpense"]</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="createColor" class="form-label fw-semibold">@Localizer["Categories.Modal.Create.ColorLabel"] <span class="text-danger">*</span></label>
                        <div class="d-flex gap-2 align-items-center">
                            <input type="color" class="form-control form-control-color" id="createColor" name="CreateForm.Color" value="#3498DB" required
                                   style="width: 60px;" aria-label="@Localizer["Categories.Modal.Create.ColorLabel"]"
                                   x-model="createColor" />
                            <span class="badge" :style="'background-color: ' + createColor" x-text="createColor"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="createIcon" class="form-label fw-semibold">@Localizer["Categories.Modal.Create.IconLabel"] <span class="text-danger">*</span></label>
                        <select class="form-select" id="createIcon" name="CreateForm.IconName" required aria-required="true"
                                x-model="createIcon">
                            <option value="">@Localizer["Categories.Modal.Create.SelectIcon"]</option>
                            @foreach (var icon in Model.AvailableIcons)
                            {
                                <option value="@icon">@icon</option>
                            }
                        </select>
                    </div>

                    <div id="createError" class="alert alert-danger rounded-3" x-show="createError" x-text="createError" role="alert" aria-live="polite" aria-atomic="true"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @@click="closeModal('createCategoryModal')">@Localizer["Common.Cancel"]</button>
                    <button type="submit" class="btn btn-brand" id="createSubmitBtn" :disabled="!createValid">@Localizer["Categories.Modal.Create.Submit"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Category Modal -->
<div class="modal fade" id="editCategoryModal" tabindex="-1" aria-labelledby="editCategoryLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editCategoryLabel">@Localizer["Categories.Modal.Edit.Title"]</h5>
                <button type="button" class="btn-close" @@click="closeModal('editCategoryModal')" aria-label="@Localizer["Common.Close"]"></button>
            </div>
            <form id="editForm" method="post" asp-page-handler="Update" @@submit.prevent="submitEditForm($event)">
                <div class="modal-body">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="editCategoryId" name="EditForm.CategoryId" x-model="editCategoryId" />

                    <div class="mb-3">
                        <label for="editName" class="form-label fw-semibold">@Localizer["Categories.Modal.Create.NameLabel"] <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="editName" name="EditForm.Name" maxlength="50" required aria-required="true"
                               x-model="editName"
                               @@input="editCharCount = $el.value.length"
                               :class="{ 'is-invalid': editError && !editName.trim() }" />
                        <div class="form-text text-end"><span x-text="categoryI18n.charCount.replace('{0}', editCharCount)">@Localizer["Categories.Modal.Create.CharCount", 0]</span></div>
                    </div>

                    <div class="mb-3">
                        <label for="editColor" class="form-label fw-semibold">@Localizer["Categories.Modal.Create.ColorLabel"] <span class="text-danger">*</span></label>
                        <div class="d-flex gap-2 align-items-center">
                            <input type="color" class="form-control form-control-color" id="editColor" name="EditForm.Color" required
                                   style="width: 60px;" aria-label="@Localizer["Categories.Modal.Create.ColorLabel"]"
                                   x-model="editColor" />
                            <span class="badge" :style="'background-color: ' + editColor" x-text="editColor"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="editIcon" class="form-label fw-semibold">@Localizer["Categories.Modal.Create.IconLabel"] <span class="text-danger">*</span></label>
                        <select class="form-select" id="editIcon" name="EditForm.IconName" required aria-required="true"
                                x-model="editIcon">
                            @foreach (var icon in Model.AvailableIcons)
                            {
                                <option value="@icon">@icon</option>
                            }
                        </select>
                    </div>

                    <div id="editError" class="alert alert-danger rounded-3" x-show="editError" x-text="editError" role="alert" aria-live="polite" aria-atomic="true"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @@click="closeModal('editCategoryModal')">@Localizer["Common.Cancel"]</button>
                    <button type="submit" class="btn btn-brand" id="editSubmitBtn" :disabled="!editValid">@Localizer["Categories.Modal.Edit.Submit"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-labelledby="deleteConfirmLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteConfirmLabel">@Localizer["Categories.Modal.Delete.Title"]</h5>
                <button type="button" class="btn-close" @@click="closeModal('deleteConfirmModal')" aria-label="@Localizer["Common.Close"]"></button>
            </div>
            <div class="modal-body">
                <p>@Html.Raw(Localizer["Categories.Modal.Delete.Confirm", "<strong x-text=\"deleteCategoryName\"></strong>"])</p>
                <p class="text-muted small">@Localizer["Categories.Modal.Delete.Warning"]</p>
                <div id="deleteError" class="alert alert-danger rounded-3" x-show="deleteError" x-text="deleteError" role="alert" aria-live="polite"></div>
            </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @@click="closeModal('deleteConfirmModal')">@Localizer["Common.Cancel"]</button>
                    <button type="button" class="btn btn-danger" id="deleteConfirmBtn" @@click="performDelete()">@Localizer["Categories.Modal.Delete.Submit"]</button>
                </div>
        </div>
    </div>
</div>
</div>

<style>
    .category-color-chip {
        border: 1px solid var(--hairline);
    }

    .form-control:focus,
    .form-select:focus,
    .form-control-color:focus {
        outline: 2px solid var(--brand);
        outline-offset: 2px;
    }

    .btn:focus {
        outline: 2px solid var(--brand);
        outline-offset: 2px;
    }

    /* Character counter styling */
    .form-text.text-end {
        font-size: 0.75rem;
        color: var(--muted);
        margin-top: 0.25rem;
    }

    /* Ensure proper spacing between error and counter */
    .invalid-feedback {
        margin-bottom: 0.25rem;
    }
</style>

<script>
    function setupModalFocusTraps() {
        const focusableSelectors = 'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])';
        let lastFocusedElement = null;

        function trapFocus(modalElement, initialFocusId) {
            modalElement.addEventListener('shown.bs.modal', function() {
                lastFocusedElement = document.activeElement;
                const initialFocus = document.getElementById(initialFocusId);
                if (initialFocus) initialFocus.focus();

                const focusableElements = modalElement.querySelectorAll(focusableSelectors);
                if (focusableElements.length > 0) {
                    const firstElement = focusableElements[0];
                    const lastElement = focusableElements[focusableElements.length - 1];

                    modalElement.addEventListener('keydown', function(e) {
                        if (e.key === 'Tab') {
                            if (e.shiftKey) {
                                if (document.activeElement === firstElement) {
                                    lastElement.focus();
                                    e.preventDefault();
                                }
                            } else {
                                if (document.activeElement === lastElement) {
                                    firstElement.focus();
                                    e.preventDefault();
                                }
                            }
                        }
                        if (e.key === 'Escape') {
                            mdb.Modal.getInstance(modalElement)?.hide();
                        }
                    });
                }
            });

            modalElement.addEventListener('hidden.bs.modal', function() {
                if (lastFocusedElement) {
                    lastFocusedElement.focus();
                    lastFocusedElement = null;
                }
            });
        }

        const createModal = document.getElementById('createCategoryModal');
        if (createModal) trapFocus(createModal, 'createName');

        const editModal = document.getElementById('editCategoryModal');
        if (editModal) trapFocus(editModal, 'editName');

        const deleteConfirmModal = document.getElementById('deleteConfirmModal');
        if (deleteConfirmModal) trapFocus(deleteConfirmModal, 'deleteConfirmBtn');
    }
</script>
