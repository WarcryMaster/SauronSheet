@page
@model SauronSheet.Frontend.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "Categories";
}

<div>
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold text-gray-900">Categories</h1>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="rounded-md bg-green-50 p-4 mb-6">
            <p class="text-sm text-green-700">@Model.SuccessMessage</p>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="rounded-md bg-red-50 p-4 mb-6">
            <p class="text-sm text-red-700">@Model.ErrorMessage</p>
        </div>
    }

    <!-- Create Category Form -->
    <div class="bg-white shadow sm:rounded-lg p-6 mb-6">
        <h2 class="text-lg font-medium text-gray-900 mb-4">Create New Category</h2>
        <form method="post" asp-page-handler="Create" class="space-y-4">
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
                <div>
                    <label for="NewCategory_Name" class="block text-sm font-medium text-gray-700">Name</label>
                    <input type="text" id="NewCategory_Name" name="NewCategory.Name" asp-for="NewCategory.Name"
                        class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2" 
                        placeholder="e.g., Entertainment" required />
                </div>
                <div>
                    <label for="NewCategory_Color" class="block text-sm font-medium text-gray-700">Color (optional)</label>
                    <input type="color" id="NewCategory_Color" name="NewCategory.Color" asp-for="NewCategory.Color"
                        class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-1 h-10" />
                </div>
                <div>
                    <label for="NewCategory_Icon" class="block text-sm font-medium text-gray-700">Icon (optional)</label>
                    <input type="text" id="NewCategory_Icon" name="NewCategory.Icon" asp-for="NewCategory.Icon"
                        class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2" 
                        placeholder="e.g., 🎬" />
                </div>
            </div>
            <button type="submit" class="btn-primary">
                Create Category
            </button>
        </form>
    </div>

    <!-- Categories List -->
    <div class="bg-white shadow overflow-hidden sm:rounded-lg">
        <ul class="divide-y divide-gray-200">
            @foreach (var category in Model.Categories)
            {
                    @if (!Model.Categories.Any())
                    {
                        <div class="bg-white rounded-lg shadow p-8 text-center" role="status" aria-live="polite">
                            <p class="text-xl text-gray-500 mb-4">No categories defined yet.</p>
                            <p class="text-gray-400 mb-6">Create a category to organize your transactions.</p>
                            <a href="#NewCategory_Name" class="btn-primary">+ Create Category</a>
                        </div>
                    }
                    else
                    {
                        <li class="px-6 py-4 flex items-center gap-4">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center space-x-3">
                                    @if (!string.IsNullOrEmpty(category.Icon))
                                    {
                                        <span class="text-2xl">@category.Icon</span>
                                    }
                                    @if (!string.IsNullOrEmpty(category.Color))
                                    {
                                        <span class="inline-block w-4 h-4 rounded-full" style="background-color: @category.Color"></span>
                                    }
                                    <div>
                                        <p class="text-sm font-medium text-gray-900">
                                            @if (category.IsSystemDefault)
                                            {
                                                <span class="text-gray-500">🔒</span>
                                            }
                                            @category.Name
                                        </p>
                                        <p class="text-sm text-gray-500">
                                            @category.TransactionCount transaction@(category.TransactionCount != 1 ? "s" : "")
                                        </p>
                                    </div>
                                </div>
                                <div class="flex items-center space-x-2">
                                    @if (!category.IsSystemDefault)
                                    {
                                        <form method="post" asp-page-handler="Rename" asp-route-categoryId="@category.Id" style="display: inline;">
                                            <input type="text" name="newName" placeholder="New name" required class="px-2 py-1 border border-gray-300 rounded text-sm" />
                                            <button type="submit" class="px-3 py-1 bg-yellow-600 text-white rounded text-sm hover:bg-yellow-700">Rename</button>
                                        </form>
                                        @if (category.TransactionCount == 0)
                                        {
                                            <form method="post" asp-page-handler="Delete" asp-route-categoryId="@category.Id" style="display: inline;">
                                                <button type="submit" class="px-3 py-1 bg-red-600 text-white rounded text-sm hover:bg-red-700" onclick="return confirm('Are you sure you want to delete this category?')">Delete</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-xs text-gray-500">(has transactions)</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-xs text-gray-500 italic">System default</span>
                                    }
                                </div>
                            </div>
                        </li>
                    }
            }
        </ul>
    </div>
</div>
