@page
@model SauronSheet.Frontend.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "Categories";
}

<div class="space-y-6">
    <h1 class="text-2xl font-bold text-gray-900">Categories</h1>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="rounded-xl bg-brand-50 border border-brand-200 p-4 flex items-start gap-3">
            <svg class="h-5 w-5 text-brand-600 flex-shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            <p class="text-sm text-brand-700">@Model.SuccessMessage</p>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="rounded-xl bg-red-50 border border-red-200 p-4 flex items-start gap-3">
            <svg class="h-5 w-5 text-red-500 flex-shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-10.707a1 1 0 00-1.414-1.414L10 8.586 7.707 6.293a1 1 0 00-1.414 1.414L8.586 10l-2.293 2.293a1 1 0 001.414 1.414L10 11.414l2.293 2.293a1 1 0 001.414-1.414L11.414 10l2.293-2.293z" clip-rule="evenodd"/></svg>
            <p class="text-sm text-red-700">@Model.ErrorMessage</p>
        </div>
    }

    <!-- Create Category Form -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-base font-semibold text-gray-900 mb-4">Create New Category</h2>
        <form method="post" asp-page-handler="Create" class="space-y-4">
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
                <div>
                    <label for="NewCategory_Name" class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Name</label>
                    <input type="text" id="NewCategory_Name" name="NewCategory.Name" asp-for="NewCategory.Name"
                           class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                           placeholder="e.g., Entertainment" required />
                </div>
                <div>
                    <label for="NewCategory_Color" class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Color <span class="normal-case font-normal">(optional)</span></label>
                    <input type="color" id="NewCategory_Color" name="NewCategory.Color" asp-for="NewCategory.Color"
                           class="block w-full rounded-lg border border-gray-300 p-1 h-10 cursor-pointer" />
                </div>
                <div>
                    <label for="NewCategory_Icon" class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Icon <span class="normal-case font-normal">(optional)</span></label>
                    <input type="text" id="NewCategory_Icon" name="NewCategory.Icon" asp-for="NewCategory.Icon"
                           class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                           placeholder="e.g., \uD83C\uDFAC" />
                </div>
            </div>
            <div>
                <button type="submit" class="inline-flex items-center gap-2 px-5 py-2 text-sm font-semibold text-white bg-brand-600 rounded-lg hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500 transition-colors shadow-sm">
                    + Create Category
                </button>
            </div>
        </form>
    </div>

    <!-- Categories List -->
    @if (!Model.Categories.Any())
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-12 text-center" role="status" aria-live="polite">
            <div class="text-5xl mb-4">🏷️</div>
            <p class="text-lg font-semibold text-gray-700 mb-2">No categories yet</p>
            <p class="text-gray-400">Create a category above to organize your transactions.</p>
        </div>
    }
    else
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <ul class="divide-y divide-gray-100">
                @foreach (var category in Model.Categories)
                {
                    <li class="px-6 py-4 flex items-center justify-between gap-4 hover:bg-gray-50 transition-colors">
                        <div class="flex items-center gap-3 min-w-0">
                            @if (!string.IsNullOrEmpty(category.Icon))
                            {
                                <span class="text-xl flex-shrink-0">@category.Icon</span>
                            }
                            @if (!string.IsNullOrEmpty(category.Color))
                            {
                                <span class="flex-shrink-0 inline-block w-3.5 h-3.5 rounded-full" style="background-color: @category.Color"></span>
                            }
                            <div class="min-w-0">
                                <p class="text-sm font-semibold text-gray-900 flex items-center gap-1.5">
                                    @if (category.IsSystemDefault)
                                    {
                                        <span class="text-gray-400" title="System default">🔒</span>
                                    }
                                    @category.Name
                                </p>
                                <p class="text-xs text-gray-500">@category.TransactionCount transaction@(category.TransactionCount != 1 ? "s" : "")</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-2 flex-shrink-0">
                            @if (!category.IsSystemDefault)
                            {
                                <form method="post" asp-page-handler="Rename" asp-route-categoryId="@category.Id" class="flex items-center gap-1.5">
                                    <input type="text" name="newName" placeholder="New name" required
                                           class="w-28 rounded-lg border border-gray-300 px-2 py-1 text-xs focus:outline-none focus:ring-1 focus:ring-brand-500" />
                                    <button type="submit" class="px-2.5 py-1 text-xs font-medium text-white bg-amber-500 rounded-lg hover:bg-amber-600 transition-colors">Rename</button>
                                </form>
                                @if (category.TransactionCount == 0)
                                {
                                    <form method="post" asp-page-handler="Delete" asp-route-categoryId="@category.Id">
                                        <button type="submit"
                                                onclick="return confirm('Delete this category?')"
                                                class="px-2.5 py-1 text-xs font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 transition-colors">Delete</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-xs text-gray-400 italic">has transactions</span>
                                }
                            }
                            else
                            {
                                <span class="text-xs text-gray-400 italic">System default</span>
                            }
                        </div>
                    </li>
                }
            </ul>
        </div>
    }
</div>
