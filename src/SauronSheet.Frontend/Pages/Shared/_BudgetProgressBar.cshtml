@* Budget progress bar partial view.
   Model: expects BudgetStatusDto with PercentageUsed and StatusLevel. *@
@model SauronSheet.Application.Features.Budgets.DTOs.BudgetStatusDto

@{
    var percentage = Math.Min(Model.PercentageUsed * 100, 100);
    var actualPercentage = Model.PercentageUsed * 100;
    var colorClass = Model.StatusLevel switch
    {
        "Green"   => "bg-success",
        "Yellow"  => "bg-warning",
        "Red"     => "bg-danger",
        "Overage" => "bg-danger",
        _         => "bg-secondary"
    };
}

<div class="progress rounded-pill" style="height:14px" role="progressbar"
     aria-valuenow="@((int)Math.Min(actualPercentage, 100))" aria-valuemin="0" aria-valuemax="100">
    <div class="progress-bar @colorClass transition" style="width:@(percentage)%"></div>
</div>
@if (actualPercentage > 100)
{
    <span class="small text-danger fw-bold">@(Math.Round(actualPercentage, 0))%</span>
}
