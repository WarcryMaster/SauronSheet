@inject Microsoft.Extensions.Configuration.IConfiguration _config
@{
    string fontAwesomeUrl = "https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.5.1/css/all.min.css";
    string sentryDsn = _config["Sentry:Dsn"] ?? "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="htmx-config" content='{"historyCacheSize":0}'>
    <title>@ViewData["Title"] - SauronSheet</title>

    <!-- Favicon: SVG first (modern browsers), PNG fallback (legacy) -->
    <link rel="icon" type="image/svg+xml" href="~/img/sauron-sheet-logo.svg" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/img/sauron-sheet-logo-32x32.png" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="16x16" href="~/img/sauron-sheet-logo-16x16.png" asp-append-version="true" />

    <!--
        Sentry JavaScript SDK — frontend error tracking & observability.

        SUPPLY-CHAIN NOTE: This loads from the official Sentry CDN without Subresource
        Integrity (SRI) hashing because this project does not yet have an automated
        SRI-pinning pipeline. For production deploys, add an integrity="sha384-..."
        attribute with a verified hash from https://www.srihash.org/ or the Sentry
        release page, and periodically bump the version.
    -->
    <script src="https://browser.sentry-cdn.com/8.54.0/bundle.tracing.replay.min.js"
            crossorigin="anonymous"></script>
    <script>
        if (typeof Sentry !== 'undefined') {
            Sentry.init({
                dsn: "@sentryDsn",
                integrations: [
                    // Session replay: mask all inputs and text to prevent PII capture.
                    Sentry.replayIntegration({
                        maskAllText: true,
                        blockAllMedia: false,
                    }),
                    Sentry.browserTracingIntegration(),
                ],
                tracesSampleRate: 0.2,
                replaysSessionSampleRate: 0.05,
                replaysOnErrorSampleRate: 1.0,
                // Drop browser-extension errors, cross-origin script noise, and
                // other sources that are not actionable for this application.
                // Sentry SDK v8 already captures unhandled JS errors and Promise
                // rejections automatically — no manual window listeners needed.
                beforeSend(event, hint) {
                    // Inspect request URL (network events, fetch errors)
                    const url = event.request && event.request.url;
                    if (url) {
                        if (url.startsWith('chrome-extension://') ||
                            url.startsWith('moz-extension://') ||
                            url.startsWith('safari-web-extension://') ||
                            url.startsWith('ms-browser-extension://')) return null;
                    }
                    // Inspect exception stack frame filenames (JS errors injected by extensions)
                    const exceptions = event.exception && event.exception.values;
                    if (exceptions) {
                        for (const ex of exceptions) {
                            const frames = ex.stacktrace && ex.stacktrace.frames;
                            if (!frames) continue;
                            for (const frame of frames) {
                                const filename = (frame.filename || '').toLowerCase();
                                if (filename.startsWith('chrome-extension://') ||
                                    filename.startsWith('moz-extension://') ||
                                    filename.startsWith('safari-web-extension://') ||
                                    filename.startsWith('ms-browser-extension://') ||
                                    filename.indexOf('extension://') !== -1) {
                                    return null;
                                }
                            }
                        }
                    }
                    return event;
                },
            });
        }
    </script>

    <!-- MDBootstrap CSS via CDN (Cloudflare - allowed by CSP) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/9.2.0/mdb.min.css" />

    <!-- Chart.js (latest) for analytics charts via CDN — pin with SRI in production -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@latest/dist/chart.umd.min.js"></script>
    <!-- Font Awesome via CDN (jsdelivr - allowed by CSP) -->
    <link rel="stylesheet" href="@fontAwesomeUrl" />
    <!-- Flatpickr — accessible date picker (airbnb theme, Spanish locale) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/airbnb.css" />
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/es.js"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Alpine.js v3 — reactive, declarative interactivity -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>
    <!-- HTMX v2 — Ajax from HTML attributes -->
    <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.10/dist/htmx.min.js"></script>
</head>
<body class="d-flex flex-column min-vh-100 bg-light">

    <!-- Skip to content link (accessibility) -->
    <a href="#main-content"
           class="visually-hidden-focusable position-absolute top-0 start-0 m-2 btn btn-sm btn-light shadow-sm">Saltar al
        contenido principal</a>

        <!-- Navbar -->
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow" role="navigation" aria-label="Main navigation">
            <div class="container-xl px-3">
                <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                    <img src="~/img/sauron-sheet-logo.svg" asp-append-version="true" alt="SauronSheet logo" height="32" />
                    <span class="fw-bold">SauronSheet</span>
                </a>

                <button class="navbar-toggler" type="button"   data-mdb-toggle="collapse" data-mdb-target="#navMain"
                        aria-controls="navMain" aria-expanded="false" aria-label="Toggle navigation">
                    <i class="navbar-toggler-icon"></i>
                </button>

                <div class="collapse navbar-collapse" id="navMain">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item"><a class="nav-link" href="/dashboard">📊 Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" href="/transactions">💳 Transactions</a></li>
                            <li class="nav-item"><a class="nav-link" href="/transactions/search">🔍 Search</a></li>
                            <li class="nav-item"><a class="nav-link" href="/transactions/upload">📄 Upload</a></li>
                            <li class="nav-item"><a class="nav-link" href="/categories">🏷️ Categories</a></li>
                            <li class="nav-item"><a class="nav-link" href="/budgets">💰 Budgets</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Analysis/Annual">📈 Annual Analysis</a></li>
                            <li class="nav-item d-none d-lg-flex align-items-center border-start border-secondary ps-3 ms-1">
                                <small class="text-secondary text-truncate"
                                       style="max-width:140px">@User.FindFirst("email")?.Value</small>
                            </li>
                            <li class="nav-item">
                                <form method="post" asp-page="/auth/logout" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-secondary ms-lg-1">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" href="/auth/login">Sign In</a></li>
                            <li class="nav-item"><a class="btn btn-sm btn-brand ms-lg-2" href="/auth/register">Get Started</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>

        <main id="main-content" class="flex-grow-1 container-xl px-3 py-4">
            @RenderBody()
        </main>

        @await Html.PartialAsync("~/Pages/Shared/Components/_Toast.cshtml")

        <footer class="bg-white border-top border-secondary mt-auto py-3">
            <div class="container-xl px-3 d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2">
                <div class="d-flex align-items-center gap-2">
                    <img src="~/img/sauron-sheet-logo.svg" asp-append-version="true" alt="" height="16" class="opacity-50" />
                    <small class="text-muted">&copy; 2026 SauronSheet</small>
                </div>
                <small class="text-secondary">v1.2.0 — Phase 6 Polish &amp; Release</small>
            </div>
        </footer>

        <!-- MDBootstrap JS via CDN (Cloudflare - allowed by CSP) -->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/mdb-ui-kit/9.2.0/mdb.umd.min.js"></script>

        @RenderSection("Scripts", required: false)
    </body>

</html>
