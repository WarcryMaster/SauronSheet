@model SauronSheet.Frontend.Helpers.CategoryBadgeDisplay
@using Microsoft.Extensions.Localization
@using SauronSheet.Application.Resources
@inject IStringLocalizer<SharedResources> Localizer

@{
    string displayPrimaryText = Model.PrimaryText;

    if (Model.IsSystemCategory && !string.IsNullOrWhiteSpace(Model.SystemCategorySlug))
    {
        string resourceKey = $"category.system.{Model.SystemCategorySlug}";
        LocalizedString localized = Localizer[resourceKey];
        if (!localized.ResourceNotFound)
        {
            displayPrimaryText = localized.Value;
        }
    }
}

@{
    string primaryClass = Model.IsUncategorized
        ? "category-badge category-badge-primary category-badge-uncategorized"
        : Model.UsesWarningStyle
            ? "category-badge category-badge-primary category-badge-warning"
            : "category-badge category-badge-primary category-badge-brand";
}

<div class="category-badge-stack">
    <span class="@primaryClass">
        @if (!string.IsNullOrWhiteSpace(Model.AccentColor))
        {
            <span class="category-badge-dot" style="background-color:@Model.AccentColor"></span>
        }
        <span>@displayPrimaryText</span>
    </span>

    @if (!string.IsNullOrWhiteSpace(Model.SecondaryText))
    {
        <span class="category-badge category-badge-secondary">@Model.SecondaryText</span>
    }
</div>
