@* _DateRangeFilter partial view — Reusable date range filter component with Alpine.js *@
@* Phase 4: Used on Dashboard and Transaction list pages *@

<div x-data="{ showCustom: false }" class="flex flex-wrap items-end gap-4 bg-white rounded-lg shadow p-4 mb-6">
    <div>
        <label for="DateFilter" class="block text-sm font-medium text-gray-700 mb-1">Date Range</label>
        <select name="DateFilter" id="DateFilter"
                x-on:change="showCustom = ($event.target.value === 'custom')"
                class="rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border">
            <option value="this-month" selected="@(ViewData["DateFilter"]?.ToString() == "this-month" ? "selected" : null)">This Month</option>
            <option value="last-month" selected="@(ViewData["DateFilter"]?.ToString() == "last-month" ? "selected" : null)">Last Month</option>
            <option value="last-3-months" selected="@(ViewData["DateFilter"]?.ToString() == "last-3-months" ? "selected" : null)">Last 3 Months</option>
            <option value="this-year" selected="@(ViewData["DateFilter"]?.ToString() == "this-year" ? "selected" : null)">This Year</option>
            <option value="custom" selected="@(ViewData["DateFilter"]?.ToString() == "custom" ? "selected" : null)">Custom Range</option>
        </select>
    </div>

    <div x-show="showCustom" x-cloak class="flex items-end gap-2">
        <div>
            <label for="CustomFromDate" class="block text-sm font-medium text-gray-700 mb-1">From</label>
            <input type="date" name="CustomFromDate" id="CustomFromDate"
                   value="@ViewData["CustomFromDate"]"
                   class="rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border" />
        </div>
        <div>
            <label for="CustomToDate" class="block text-sm font-medium text-gray-700 mb-1">To</label>
            <input type="date" name="CustomToDate" id="CustomToDate"
                   value="@ViewData["CustomToDate"]"
                   class="rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm px-3 py-2 border" />
        </div>
    </div>

    <button type="submit"
            class="px-4 py-2 bg-blue-600 text-white text-sm rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500">
        Apply
    </button>
</div>
