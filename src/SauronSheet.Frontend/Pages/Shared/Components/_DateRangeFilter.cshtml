@inject IStringLocalizer<SharedResources> Localizer
@* _DateRangeFilter partial view - Reusable date range filter component *@
@* Phase 7: Alpine.js reactive filter — no inline onchange JS *@

<div x-data="{ period: '@(ViewData["DateFilter"]?.ToString() ?? "all")' }"
     class="d-flex flex-wrap align-items-center justify-content-between gap-2 py-1">
    <div class="d-flex flex-wrap align-items-center gap-2">
        <label for="DateFilter" class="form-label mb-0 small fw-semibold text-muted text-uppercase">@Localizer["Common.Period"]</label>
        <select name="DateFilter" id="DateFilter"
                x-model="period"
                @@change="$el.form.requestSubmit()"
                class="form-select form-select-sm" style="width: auto; min-width: 160px;"
                data-testid="date-filter-select">
            <option value="all">@Localizer["Dashboard.PeriodAllTime"]</option>
            <option value="this-month">@Localizer["Dashboard.PeriodThisMonth"]</option>
            <option value="last-month">@Localizer["Common.PeriodLastMonth"]</option>
            <option value="last-3-months">@Localizer["Dashboard.PeriodLast3Months"]</option>
            <option value="this-year">@Localizer["Dashboard.PeriodThisYear"]</option>
            <option value="custom">@Localizer["Common.PeriodCustom"]</option>
        </select>
    </div>

    <div id="dateRangeCustom" class="d-flex align-items-center gap-2"
         x-show="period === 'custom'" x-transition>
        <div>
            <label for="CustomFromDate" class="form-label mb-0 small text-muted">@Localizer["Common.From"]</label>
            <input x-data x-init="flatpickr($el, { dateFormat: 'Y-m-d', altInput: true, altFormat: 'd/m/Y', allowInput: true })"
                   type="text" name="CustomFromDate" id="CustomFromDate"
                   value="@ViewData["CustomFromDate"]"
                   class="form-control form-control-sm" placeholder="DD/MM/AAAA" autocomplete="off" />
        </div>
        <div>
            <label for="CustomToDate" class="form-label mb-0 small text-muted">@Localizer["Common.To"]</label>
            <input x-data x-init="flatpickr($el, { dateFormat: 'Y-m-d', altInput: true, altFormat: 'd/m/Y', allowInput: true })"
                   type="text" name="CustomToDate" id="CustomToDate"
                   value="@ViewData["CustomToDate"]"
                   class="form-control form-control-sm" placeholder="DD/MM/AAAA" autocomplete="off" />
        </div>
    </div>

    <button type="submit" class="btn btn-brand btn-sm" data-testid="date-filter-apply">@Localizer["Common.Apply"]</button>
</div>
