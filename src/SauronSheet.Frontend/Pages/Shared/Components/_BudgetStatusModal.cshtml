<div class="modal fade" id="budgetStatusModal" tabindex="-1" aria-labelledby="budgetStatusModalLabel" aria-hidden="true"
     x-data="budgetStatusModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form method="post" asp-page-handler="Status">
                @Html.AntiForgeryToken()
                <div class="modal-header border-0 pb-0">
                    <div>
                        <p class="text-uppercase small fw-semibold mb-1"
                           x-text="eyebrow" :class="eyebrowClass">Budget action</p>
                        <h5 class="modal-title" x-text="title">Update budget status</h5>
                    </div>
                    <button type="button" class="btn-close" data-mdb-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body pt-3">
                    <input type="hidden" name="BudgetId" x-model="budgetId" />

                    <p class="mb-2">
                        Are you sure you want to <span x-text="actionText">update</span>
                        <strong x-text="budgetName">this budget</strong>?
                    </p>
                    <p class="text-muted small mb-0">
                        Granularity: <span x-text="period">-</span>.
                        <span x-text="description">This budget will stop applying to future periods.</span>
                    </p>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary" data-mdb-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn" id="budgetStatusSubmitButton"
                            x-text="submitText" :class="submitClass" data-mdb-ripple-init>Deactivate</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener('alpine:init', () => {
        Alpine.data('budgetStatusModal', () => ({
            // State
            budgetId: '',
            budgetName: 'this budget',
            period: '-',
            actionText: 'deactivate',
            title: 'Deactivate budget',
            eyebrow: 'Budget deactivation',
            description: 'This budget will stop applying to future periods.',
            submitText: 'Deactivate',
            isActivation: false,

            // Computed
            get eyebrowClass() {
                return this.isActivation ? 'text-success' : 'text-danger';
            },
            get submitClass() {
                return this.isActivation ? 'btn-success' : 'btn-danger';
            },

            // Lifecycle
            init() {
                document.querySelectorAll('[data-budget-status-trigger="true"]').forEach((trigger) => {
                    trigger.addEventListener('click', () => this.open(trigger));
                });
            },

            // Methods
            open(trigger) {
                const action = trigger.getAttribute('data-budget-action') ?? 'Deactivate';
                this.budgetId = trigger.getAttribute('data-budget-id') ?? '';
                this.budgetName = trigger.getAttribute('data-budget-name') ?? 'this budget';
                this.period = trigger.getAttribute('data-budget-period') ?? '-';
                this.isActivation = action === 'Activate';
                this.actionText = action.toLowerCase();
                this.title = `${action} budget`;
                this.eyebrow = this.isActivation ? 'Budget activation' : 'Budget deactivation';
                this.description = this.isActivation
                    ? 'This budget will apply again to current and future periods.'
                    : 'This budget will stop applying to future periods.';
                this.submitText = action;

                const modalEl = document.getElementById('budgetStatusModal');
                if (modalEl && typeof mdb !== 'undefined') {
                    const modal = mdb.Modal.getInstance(modalEl) || new mdb.Modal(modalEl);
                    modal.show();
                }
            }
        }));
    });
</script>
