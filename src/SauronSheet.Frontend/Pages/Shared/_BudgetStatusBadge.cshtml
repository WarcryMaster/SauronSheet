@* Budget status badge partial view.
   Model: string StatusLevel (Green, Yellow, Red, Overage). *@
@model string

@{
    var (badgeClass, label) = Model switch
    {
        "Green"   => ("badge bg-success", "On Track"),
        "Yellow"  => ("badge bg-warning text-dark", "Warning"),
        "Red"     => ("badge bg-danger", "Near Limit"),
        "Overage" => ("badge bg-danger", "Over Budget"),
        _         => ("badge bg-secondary", "Unknown")
    };
}

<span class="@badgeClass" role="status" aria-label="@label">@label</span>
