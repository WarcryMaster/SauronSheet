@page "/budgets"
@model SauronSheet.Frontend.Pages.Budgets.IndexModel
@{
    ViewData["Title"] = "Budgets";
}

<div class="d-flex flex-column gap-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2 class="h3 fw-bold mb-0">Budgets</h2>
        <a href="/budgets/create" class="btn btn-brand btn-sm">+ Create Budget</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success" role="alert">@Model.SuccessMessage</div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" role="alert">@TempData["SuccessMessage"]</div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
    }

    @* Filters *@
    <form method="get" action="/budgets" class="card border-0 shadow-sm p-3">
        <div class="d-flex flex-wrap align-items-center gap-3">
            @* Active only toggle *@
            <div class="form-check">
                <input type="checkbox" class="form-check-input" id="ShowActiveOnly"
                       name="ShowActiveOnly" value="true" @(Model.ShowActiveOnly ? "checked" : "") />
                <label class="form-check-label small fw-semibold text-muted text-uppercase" for="ShowActiveOnly">Active Only</label>
            </div>

            @* Category filter *@
            <div>
                <select id="CategoryFilter" name="CategoryFilter" class="form-select form-select-sm" style="width:auto">
                    <option value="">All Categories</option>
                    @foreach (var cat in Model.Categories)
                    {
                        bool selected = Model.CategoryFilter.HasValue && Model.CategoryFilter.Value == cat.Id;
                        <option value="@cat.Id" selected="@selected">@cat.Name</option>
                    }
                </select>
            </div>

            <button type="submit" class="btn btn-brand btn-sm">Filter</button>
        </div>
    </form>

    @if (Model.Budgets.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" aria-label="Budgets list">
                    <thead class="table-light">
                        <tr>
                            <th class="text-uppercase small fw-semibold text-muted">Category</th>
                            <th class="text-uppercase small fw-semibold text-muted">Granularity</th>
                            <th class="text-uppercase small fw-semibold text-muted text-end">Limit</th>
                            <th class="text-uppercase small fw-semibold text-muted">Validity</th>
                            <th class="text-uppercase small fw-semibold text-muted text-center">Status</th>
                            <th class="text-uppercase small fw-semibold text-muted text-center budget-actions-column">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var budget in Model.Budgets)
                        {
                            bool isActive = budget.EffectiveUntil == null
                                || budget.EffectiveUntil.Value >= DateOnly.FromDateTime(DateTime.UtcNow);

                            <tr>
                                <td>
                                    <span class="fw-medium">@budget.CategoryName</span>
                                </td>
                                <td>
                                    <span class="small">@budget.PeriodGranularity</span>
                                </td>
                                <td class="text-end small fw-medium">&euro;@budget.Limit.ToString("N2")</td>
                                <td>
                                    <span class="small text-muted">
                                        @budget.EffectiveFrom.ToString("yyyy-MM-dd")
                                        &mdash;
                                        @(budget.EffectiveUntil?.ToString("yyyy-MM-dd") ?? "Permanent")
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="badge @(isActive ? "bg-success" : "bg-secondary")" role="status">
                                        @(isActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="budget-actions-group">
                                        <a href="/budgets/edit/@budget.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger"
                                                data-budget-deactivate-trigger="true"
                                                data-budget-id="@budget.Id"
                                                data-budget-name="@budget.CategoryName"
                                                data-budget-period="@budget.PeriodGranularity">
                                            Deactivate
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm p-5 text-center" role="status" aria-live="polite">
            <p class="h5 text-muted mb-3">No budgets found.</p>
            <p class="text-muted mb-4">Create one to start tracking your spending.</p>
            <div><a href="/budgets/create" class="btn btn-brand">+ Create Budget</a></div>
        </div>
    }
</div>

@if (Model.Budgets.Any())
{
    <div class="modal fade" id="deactivateBudgetModal" tabindex="-1" aria-labelledby="deactivateBudgetModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <form method="post" asp-page-handler="Deactivate">
                    @Html.AntiForgeryToken()
                    <div class="modal-header border-0 pb-0">
                        <div>
                            <p class="text-uppercase small fw-semibold text-danger mb-1">Budget action</p>
                            <h5 class="modal-title" id="deactivateBudgetModalLabel">Deactivate budget</h5>
                        </div>
                        <button type="button" class="btn-close" data-mdb-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body pt-3">
                        <input type="hidden" name="BudgetId" id="deactivateBudgetId" />

                        <p class="mb-2">
                            Are you sure you want to deactivate
                            <strong id="deactivateBudgetName">this budget</strong>?
                        </p>
                        <p class="text-muted small mb-0">
                            Granularity: <span id="deactivateBudgetPeriod">—</span>. This budget will stop applying to future periods.
                        </p>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-outline-secondary" data-mdb-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger" data-mdb-ripple-init>Deactivate</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<style>
    .budget-actions-column {
        width: 15rem;
        min-width: 15rem;
    }

    .budget-actions-group {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.5rem;
        width: min(100%, 15rem);
        margin-inline: auto;
    }

    .budget-actions-group .btn {
        width: 100%;
        white-space: nowrap;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        min-height: 2.375rem;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const deactivateBudgetModalElement = document.getElementById('deactivateBudgetModal');
        const deactivateBudgetIdInput = document.getElementById('deactivateBudgetId');
        const deactivateBudgetName = document.getElementById('deactivateBudgetName');
        const deactivateBudgetPeriod = document.getElementById('deactivateBudgetPeriod');
        const deactivateTriggers = document.querySelectorAll('[data-budget-deactivate-trigger="true"]');
        const deactivateBudgetModal = deactivateBudgetModalElement !== null && typeof mdb !== 'undefined'
            ? new mdb.Modal(deactivateBudgetModalElement)
            : null;

        deactivateTriggers.forEach((trigger) => {
            trigger.addEventListener('click', function () {
                const budgetId = trigger.getAttribute('data-budget-id');
                const budgetName = trigger.getAttribute('data-budget-name');
                const budgetPeriod = trigger.getAttribute('data-budget-period');

                if (deactivateBudgetIdInput !== null) {
                    deactivateBudgetIdInput.value = budgetId ?? '';
                }

                if (deactivateBudgetName !== null) {
                    deactivateBudgetName.textContent = budgetName ?? 'this budget';
                }

                if (deactivateBudgetPeriod !== null) {
                    deactivateBudgetPeriod.textContent = budgetPeriod ?? '—';
                }

                deactivateBudgetModal?.show();
            });
        });
    });
</script>
