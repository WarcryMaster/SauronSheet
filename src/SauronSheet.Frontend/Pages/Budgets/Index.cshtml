@page "/Budgets"
@model SauronSheet.Frontend.Pages.Budgets.IndexModel
@{
    ViewData["Title"] = "Budgets";
    var currentYear = Model.Year ?? DateTime.UtcNow.Year;
    var currentMonth = Model.Month ?? DateTime.UtcNow.Month;
    var monthName = new DateTime(currentYear, currentMonth, 1).ToString("MMMM yyyy");
}

<div class="space-y-6">
    <div class="flex justify-between items-center">
        <h2 class="text-2xl font-bold text-gray-900">💰 Budgets</h2>
        <a href="/Budgets/Create" class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-semibold text-white bg-brand-600 rounded-lg hover:bg-brand-700 transition-colors shadow-sm">
            + Create Budget
        </a>
    </div>

    <!-- Month Filter -->
    <form method="get" action="/Budgets" class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
        <div class="flex flex-wrap items-center gap-4">
            <label class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Month:</label>
            <input type="month"
                   name="month"
                   value="@($"{currentYear:D4}-{currentMonth:D2}")"
                   class="rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500"
                   id="monthPicker" />
            <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-brand-600 rounded-lg hover:bg-brand-700 transition-colors">
                Filter
            </button>
        </div>
    </form>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="rounded-xl bg-brand-50 border border-brand-200 p-4">
            <p class="text-sm text-brand-700">@Model.SuccessMessage</p>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="rounded-xl bg-red-50 border border-red-200 p-4">
            <p class="text-sm text-red-700">@Model.ErrorMessage</p>
        </div>
    }

    @if (Model.Budgets.Any())
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <table class="min-w-full divide-y divide-gray-100">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Category</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Limit</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Spent</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Remaining</th>
                        <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Progress</th>
                        <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Status</th>
                        <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-100">
                    @foreach (var budget in Model.Budgets)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <a href="/Budgets/Detail/@budget.Id" class="text-brand-600 hover:text-brand-700 hover:underline font-medium">
                                    @if (!string.IsNullOrEmpty(budget.CategoryColor))
                                    {
                                        <span class="inline-block w-3 h-3 rounded-full mr-2" style="background-color: @budget.CategoryColor"></span>
                                    }
                                    @budget.CategoryName
                                </a>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                €@budget.LimitAmount.ToString("N2")
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm @(budget.CurrentSpend > budget.LimitAmount ? "text-red-600 font-bold" : "text-gray-700")">
                                €@budget.CurrentSpend.ToString("N2")
                            </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm @(budget.RemainingAmount >= 0 ? "text-brand-600" : "text-red-600")">
                                €@budget.RemainingAmount.ToString("N2")
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap" style="min-width: 150px;">
                                <partial name="Shared/_BudgetProgressBar" model="budget" />
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-center">
                                <partial name="Shared/_BudgetStatusBadge" model="budget.StatusLevel" />
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-center">
                                <div class="flex justify-center gap-2">
                                    <a href="/Budgets/Edit/@budget.Id" class="text-brand-600 hover:text-brand-700 text-sm font-medium">Edit</a>
                                    <form method="post" asp-page-handler="Delete" class="inline"
                                          x-data x-on:submit.prevent="if(confirm('Delete this budget?')) $el.submit()">
                                        <input type="hidden" name="budgetId" value="@budget.Id" />
                                        <button type="submit" class="text-red-600 hover:underline text-sm">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="bg-white rounded-lg shadow p-8 text-center" role="status" aria-live="polite">
            <p class="text-xl text-gray-500 mb-4">No budgets set for @monthName.</p>
            <p class="text-gray-400 mb-6">Create one to start tracking your spending.</p>
            <a href="/Budgets/Create" class="bg-blue-600 text-white px-4 py-2 rounded font-semibold hover:bg-blue-700">+ Create Budget</a>
        </div>
    }
</div>

<script>
    // Parse month picker value into Year/Month query params
    document.getElementById('monthPicker')?.closest('form')?.addEventListener('submit', function(e) {
        e.preventDefault();
        var val = document.getElementById('monthPicker').value;
        if (val) {
            var parts = val.split('-');
            window.location.href = '/Budgets?Year=' + parts[0] + '&Month=' + parseInt(parts[1]);
        } else {
            window.location.href = '/Budgets';
        }
    });
</script>
