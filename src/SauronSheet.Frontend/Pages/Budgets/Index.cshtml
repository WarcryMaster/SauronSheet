@page "/budgets"
@model SauronSheet.Frontend.Pages.Budgets.IndexModel
@using Microsoft.Extensions.Localization
@using SauronSheet.Application.Resources
@inject IStringLocalizer<SharedResources> Localizer
@{
    ViewData["Title"] = Localizer["Budgets.Index.Title"];

    Dictionary<string, string> systemCategoryDisplayByName = Model.Categories
        .Where(c => c.IsSystemDefault && !string.IsNullOrWhiteSpace(c.SystemSlug))
        .ToDictionary(
            c => c.Name,
            c =>
            {
                string key = $"category.system.{c.SystemSlug}";
                LocalizedString localized = Localizer[key];
                return localized.ResourceNotFound ? c.Name : localized.Value;
            });

    string GetDisplayByName(string categoryName)
    {
        return systemCategoryDisplayByName.GetValueOrDefault(categoryName, categoryName);
    }
}

<div class="d-flex flex-column gap-4">
    <div class="d-flex justify-content-between align-items-center">
        <h3 class="h3 fw-bold mb-0">@Localizer["Budgets.Index.Title"]</h3>
        <a href="/budgets/create" class="btn btn-brand btn-sm" data-testid="create-budget-link">+ @Localizer["Budgets.Index.CreateBudget"]</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success rounded-3" role="alert" x-transition.opacity>@Model.SuccessMessage</div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success rounded-3" role="alert" x-transition.opacity>@TempData["SuccessMessage"]</div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger rounded-3" role="alert" x-transition.opacity>@Model.ErrorMessage</div>
    }

    @* Filters *@
    <form method="get" action="/budgets" class="card border-0 shadow-sm p-3"
          x-data="{ showActiveOnly: @Model.ShowActiveOnly.ToString().ToLower(), categoryFilter: '@(Model.CategoryFilter?.ToString() ?? "")' }">
        <div class="d-flex flex-wrap align-items-center gap-3">
            @* Active only toggle *@
            <div class="form-check">
                <input type="checkbox" class="form-check-input" id="ShowActiveOnly"
                       name="ShowActiveOnly" value="true" x-model="showActiveOnly"
                       data-testid="show-active-only" />
                <label class="form-check-label small fw-semibold text-muted text-uppercase" for="ShowActiveOnly">@Localizer["Budgets.Index.ActiveOnly"]</label>
            </div>

            @* Category filter *@
            <div>
                <select id="CategoryFilter" name="CategoryFilter" class="form-select form-select-sm" style="width:auto"
                        x-model="categoryFilter" data-testid="category-filter">
                    <option value="">@Localizer["Budgets.Index.AllCategories"]</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat.Id">@GetDisplayByName(cat.Name)</option>
                    }
                </select>
            </div>

            <button type="submit" class="btn btn-brand btn-sm" data-testid="budget-filter-btn">@Localizer["Budgets.Index.Filter"]</button>
        </div>
    </form>

    @if (Model.Budgets.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" aria-label="@Localizer["Budgets.Index.Title"]" data-testid="budgets-table">
                    <thead class="table-light">
                        <tr>
                            <th class="text-uppercase small fw-semibold text-muted">@Localizer["Budgets.Index.Table.Category"]</th>
                            <th class="text-uppercase small fw-semibold text-muted">@Localizer["Budgets.Index.Table.Granularity"]</th>
                            <th class="text-uppercase small fw-semibold text-muted text-end">@Localizer["Budgets.Index.Table.Limit"]</th>
                            <th class="text-uppercase small fw-semibold text-muted">@Localizer["Budgets.Index.Table.Validity"]</th>
                            <th class="text-uppercase small fw-semibold text-muted text-center">@Localizer["Budgets.Index.Table.Status"]</th>
                            <th class="text-uppercase small fw-semibold text-muted text-center budget-actions-column">@Localizer["Budgets.Index.Table.Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var budget in Model.Budgets)
                        {
                            bool isActive = budget.EffectiveUntil == null
                                || budget.EffectiveUntil.Value >= DateOnly.FromDateTime(DateTime.UtcNow);

                            <tr>
                                <td>
                                    <span class="fw-medium">@GetDisplayByName(budget.CategoryName)</span>
                                </td>
                                <td>
                                    <span class="small">@budget.PeriodGranularity</span>
                                </td>
                                <td class="text-end small fw-medium">&euro;@budget.Limit.ToString("N2")</td>
                                <td>
                                    <span class="small text-muted">
                                        @budget.EffectiveFrom.ToString("yyyy-MM-dd")
                                        &mdash;
                                        @(budget.EffectiveUntil?.ToString("yyyy-MM-dd") ?? Localizer["Budgets.Index.Permanent"])
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="badge @(isActive ? "bg-success" : "bg-secondary")" role="status" data-testid="budget-status-badge">
                                        @(isActive ? Localizer["Budgets.Index.Status.Active"] : Localizer["Budgets.Index.Status.Inactive"])
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="budget-actions-group">
                                        <a href="/budgets/edit/@budget.Id" class="btn btn-sm btn-outline-secondary" data-testid="edit-budget-btn">@Localizer["Budgets.Index.Edit"]</a>
                                        <button type="button"
                                                class="btn btn-sm @(isActive ? "btn-outline-danger" : "btn-outline-success")"
                                                data-budget-status-trigger="true"
                                                data-budget-id="@budget.Id"
                                                data-budget-name="@GetDisplayByName(budget.CategoryName)"
                                                data-budget-period="@budget.PeriodGranularity"
                                                data-budget-action="@(isActive ? Localizer["Budgets.Index.Deactivate"] : Localizer["Budgets.Index.Activate"])"
                                                data-testid="budget-status-btn">
                                            @(isActive ? Localizer["Budgets.Index.Deactivate"] : Localizer["Budgets.Index.Activate"])
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm p-5 text-center" role="status" aria-live="polite" data-testid="budgets-empty-state">
            <p class="h5 text-muted mb-3">@Localizer["Budgets.Index.EmptyTitle"]</p>
            <p class="text-muted mb-4">@Localizer["Budgets.Index.EmptyDescription"]</p>
            <div><a href="/budgets/create" class="btn btn-brand" data-testid="empty-create-budget-link">+ @Localizer["Budgets.Index.CreateBudget"]</a></div>
        </div>
    }
</div>

@if (Model.Budgets.Any())
{
    <partial name="Shared/Components/_BudgetStatusModal" />
}

<style>
    .budget-actions-column {
        width: 15rem;
        min-width: 15rem;
    }

    .budget-actions-group {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.5rem;
        width: min(100%, 15rem);
        margin-inline: auto;
    }

    .budget-actions-group .btn {
        width: 100%;
        white-space: nowrap;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        min-height: 2.375rem;
    }
</style>
