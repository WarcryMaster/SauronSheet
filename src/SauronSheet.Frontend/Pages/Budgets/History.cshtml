@page "/budgets/history"
@model SauronSheet.Frontend.Pages.Budgets.HistoryModel
@using Microsoft.Extensions.Localization
@using SauronSheet.Application.Resources
@inject IStringLocalizer<SharedResources> Localizer
@{
    ViewData["Title"] = Localizer["Budgets.History.Title"];
    var currentYear = DateTime.UtcNow.Year;
    var years = Enumerable.Range(currentYear - 3, 7).Reverse().ToList();
}

<div class="d-flex flex-column gap-4">
    <div class="d-flex justify-content-between align-items-center">
        <h3 class="h3 fw-bold mb-0" data-testid="history-heading">@Localizer["Budgets.History.Title"]</h3>
        <a href="/budgets" class="small text-brand text-decoration-none" data-testid="back-link">&larr; @Localizer["Budgets.History.Back"]</a>
    </div>

    <!-- Year Selector -->
    <form method="get" action="/budgets/history" class="card border-0 shadow-sm p-3">
        <div class="d-flex flex-wrap align-items-center gap-3">
            <label for="Year" class="small fw-semibold text-muted text-uppercase mb-0">@Localizer["Budgets.History.YearLabel"]</label>
            <select id="Year" name="Year" class="form-select form-select-sm" style="width:auto" data-testid="year-selector">
                @foreach (var y in years)
                {
                    bool selected = y == Model.Year;
                    <option value="@y" selected="@selected">@y</option>
                }
            </select>
            <button type="submit" class="btn btn-brand btn-sm" data-testid="view-year-btn">@Localizer["Budgets.History.View"]</button>
        </div>
    </form>

    @if (Model.History.Any())
    {
        <!-- Year Summary Cards -->
        <div class="row row-cols-1 row-cols-sm-3 g-3">
            <div class="col">
                <div class="card border-0 shadow-sm p-3 text-center">
                    <p class="small fw-semibold text-muted text-uppercase mb-1">@Localizer["Budgets.History.TotalLimit"]</p>
                    <p class="h5 fw-bold text-brand mb-0">&euro;@Model.TotalAccumulatedLimit.ToString("N2")</p>
                </div>
            </div>
            <div class="col">
                <div class="card border-0 shadow-sm p-3 text-center">
                    <p class="small fw-semibold text-muted text-uppercase mb-1">@Localizer["Budgets.History.TotalSpent"]</p>
                    <p class="h5 fw-bold mb-0">&euro;@Model.TotalSpent.ToString("N2")</p>
                </div>
            </div>
            <div class="col">
                <div class="card border-0 shadow-sm p-3 text-center">
                    <p class="small fw-semibold text-muted text-uppercase mb-1">@Localizer["Budgets.History.Remaining"]</p>
                    <p class="h5 fw-bold mb-0 @(Model.TotalRemaining >= 0 ? "text-success" : "text-danger")">
                        &euro;@Model.TotalRemaining.ToString("N2")
                    </p>
                </div>
            </div>
        </div>

        <!-- Monthly History Table -->
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" aria-label="@string.Format(Localizer["Budgets.History.TableAriaLabel"], Model.Year)">
                    <thead class="table-light">
                        <tr>
                            <th class="text-uppercase small fw-semibold text-muted" data-testid="history-period-header">@Localizer["Budgets.History.Period"]</th>
                            <th class="text-uppercase small fw-semibold text-muted text-end">@Localizer["Budgets.History.AccumulatedLimit"]</th>
                            <th class="text-uppercase small fw-semibold text-muted text-end">@Localizer["Budgets.History.Spent"]</th>
                            <th class="text-uppercase small fw-semibold text-muted text-end">@Localizer["Budgets.History.Remaining"]</th>
                            <th class="text-uppercase small fw-semibold text-muted text-center">@Localizer["Budgets.History.Status"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.History)
                        {
                            var statusLabel = item.StatusLevel switch
                            {
                                "Green" => Localizer["Budgets.Badge.OnTrack"],
                                "Yellow" => Localizer["Budgets.Badge.Warning"],
                                "Red" => Localizer["Budgets.Badge.NearLimit"],
                                "Overage" => Localizer["Budgets.Badge.OverBudget"],
                                _ => Localizer["Budgets.Badge.Unknown"]
                            };

                            var rowClass = item.StatusLevel switch
                            {
                                "Overage" => "table-danger",
                                "Red" => "table-danger",
                                "Yellow" => "table-warning",
                                _ => ""
                            };

                            <tr class="@rowClass">
                                <td class="small fw-medium">@item.Period</td>
                                <td class="text-end small fw-medium">&euro;@item.AccumulatedLimit.ToString("N2")</td>
                                <td class="text-end small fw-medium">&euro;@item.Spent.ToString("N2")</td>
                                <td class="text-end small @(item.Remaining >= 0 ? "text-success" : "text-danger") fw-medium">
                                    &euro;@item.Remaining.ToString("N2")
                                </td>
                                <td class="text-center">
                                    <partial name="Shared/_BudgetStatusBadge" model="item.StatusLevel" />
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light fw-bold">
                        <tr>
                            <td class="small" data-testid="history-total-year">@string.Format(Localizer["Budgets.History.TotalYear"], Model.Year)</td>
                            <td class="text-end small">&euro;@Model.TotalAccumulatedLimit.ToString("N2")</td>
                            <td class="text-end small">&euro;@Model.TotalSpent.ToString("N2")</td>
                            <td class="text-end small @(Model.TotalRemaining >= 0 ? "text-success" : "text-danger")">
                                &euro;@Model.TotalRemaining.ToString("N2")
                            </td>
                            <td class="text-center small">&mdash;</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm p-5 text-center" role="status" aria-live="polite" x-transition.opacity data-testid="history-empty-state">
            <p class="h5 text-muted mb-3">@string.Format(Localizer["Budgets.History.NoDataTitle"], Model.Year)</p>
            <p class="text-muted mb-4">@Localizer["Budgets.History.NoDataDescription"]</p>
            <div><a href="/budgets/create" class="btn btn-brand" data-testid="empty-create-budget-link">+ @Localizer["Budgets.Index.CreateBudget"]</a></div>
        </div>
    }
</div>
