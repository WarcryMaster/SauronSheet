@page "/budgets/detail/{id:guid}"
@model SauronSheet.Frontend.Pages.Budgets.DetailModel
@{
    ViewData["Title"] = "Budget Detail";
}

<div class="d-flex flex-column gap-4">
    <div class="d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-3">
            <a href="/budgets" class="text-muted text-decoration-none small">&larr; Back to Budgets</a>
            <h2 class="h4 fw-bold mb-0">Budget Detail</h2>
        </div>
        @if (Model.Budget != null)
        {
            <a href="/budgets/edit/@Model.Budget.Id" class="btn btn-brand btn-sm">Edit Budget</a>
        }
    </div>

    @if (Model.Budget != null)
    {
        <!-- Budget Header Card -->
        <div class="card border-0 shadow-sm p-4">
            <div class="d-flex align-items-start justify-content-between mb-3">
                <div>
                    <h3 class="h5 fw-bold mb-1">
                        @if (!string.IsNullOrEmpty(Model.Budget.CategoryColor))
                        {
                            <span class="d-inline-block rounded-circle me-2" style="width:16px;height:16px;background-color:@Model.Budget.CategoryColor"></span>
                        }
                        @Model.Budget.CategoryName
                    </h3>
                    <p class="text-muted small mb-0">@Model.Budget.PeriodStart.ToString("MMMM yyyy")</p>
                </div>
                <partial name="Shared/_BudgetStatusBadge" model="Model.Budget.StatusLevel" />
            </div>

            <!-- Progress Bar -->
            <div class="mb-4">
                <partial name="Shared/_BudgetProgressBar" model="Model.Budget" />
            </div>

            <!-- Summary Stats -->
            <div class="row g-3 text-center">
                <div class="col-6 col-sm-3">
                    <div class="bg-light rounded-3 p-3">
                        <p class="small fw-semibold text-muted text-uppercase mb-1">Budget Limit</p>
                        <p class="h5 fw-bold mb-0">&euro;@Model.Budget.LimitAmount.ToString("N2")</p>
                    </div>
                </div>
                <div class="col-6 col-sm-3">
                    <div class="bg-light rounded-3 p-3">
                        <p class="small fw-semibold text-muted text-uppercase mb-1">Current Spend</p>
                        <p class="h5 fw-bold mb-0 @(Model.Budget.CurrentSpend > Model.Budget.LimitAmount ? "text-danger" : "")">&euro;@Model.Budget.CurrentSpend.ToString("N2")</p>
                    </div>
                </div>
                <div class="col-6 col-sm-3">
                    <div class="bg-light rounded-3 p-3">
                        <p class="small fw-semibold text-muted text-uppercase mb-1">Remaining</p>
                        <p class="h5 fw-bold mb-0 @(Model.Budget.RemainingAmount >= 0 ? "text-brand" : "text-danger")">&euro;@Model.Budget.RemainingAmount.ToString("N2")</p>
                    </div>
                </div>
                <div class="col-6 col-sm-3">
                    <div class="bg-light rounded-3 p-3">
                        <p class="small fw-semibold text-muted text-uppercase mb-1">Usage</p>
                        <p class="h5 fw-bold mb-0">@((Model.Budget.PercentageUsed * 100).ToString("N0"))%</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Transactions List -->
        <div class="card border-0 shadow-sm p-4">
            <h3 class="h6 fw-semibold mb-3">Transactions (@Model.Transactions.Count)</h3>

            @if (Model.Transactions.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="text-uppercase small fw-semibold text-muted">Date</th>
                                <th class="text-uppercase small fw-semibold text-muted">Description</th>
                                <th class="text-uppercase small fw-semibold text-muted text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tx in Model.Transactions.OrderByDescending(t => t.Date))
                            {
                                <tr>
                                    <td class="small text-muted">@tx.Date.ToString("dd/MM/yyyy")</td>
                                    <td class="small">@tx.Description</td>
                                    <td class="small text-end fw-medium @(tx.Amount >= 0 ? "text-brand" : "text-danger")">&euro;@tx.Amount.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted text-center py-3">No transactions for this category in the selected period.</p>
            }
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm p-5 text-center">
            <p class="text-muted mb-3">Budget not found.</p>
            <a href="/budgets" class="btn btn-outline-secondary btn-sm">Back to Budgets</a>
        </div>
    }
</div>
