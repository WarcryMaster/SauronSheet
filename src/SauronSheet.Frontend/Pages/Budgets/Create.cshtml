@page "/Budgets/Create"
@model SauronSheet.Frontend.Pages.Budgets.CreateModel
@{
    ViewData["Title"] = "Create Budget";
}

<div class="max-w-lg mx-auto space-y-6">
    <div class="flex items-center gap-4">
        <a href="/Budgets" class="text-gray-500 hover:text-gray-700">&larr; Back to Budgets</a>
        <h2 class="text-2xl font-bold text-gray-900">Create Budget</h2>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
            @Model.ErrorMessage
        </div>
    }

    <form method="post" class="bg-white rounded-lg shadow p-6 space-y-4">
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
            <select asp-for="CategoryId" class="w-full border rounded px-3 py-2">
                <option value="">-- Select Category --</option>
                @foreach (var cat in Model.Categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            </select>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Month</label>
            <input type="month" asp-for="Month" class="w-full border rounded px-3 py-2" />
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Spending Limit</label>
            <div class="flex items-center gap-2">
                <span class="text-gray-500">€</span>
                <input type="number" asp-for="LimitAmount" step="0.01" min="0.01"
                       class="w-full border rounded px-3 py-2" placeholder="500.00" />
                <span class="text-sm text-gray-500">EUR</span>
            </div>
        </div>

        <div class="flex justify-end gap-3 pt-4">
            <a href="/Budgets" class="px-4 py-2 bg-gray-200 text-gray-700 rounded hover:bg-gray-300">Cancel</a>
            <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
                Create Budget
            </button>
        </div>
    </form>
</div>
