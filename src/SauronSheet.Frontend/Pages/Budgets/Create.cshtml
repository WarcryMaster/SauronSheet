@page "/Budgets/Create"
@model SauronSheet.Frontend.Pages.Budgets.CreateModel
@{
    ViewData["Title"] = "Create Budget";
}

<div class="mx-auto d-flex flex-column gap-4" style="max-width:520px">
    <div class="d-flex align-items-center gap-3">
        <a href="/Budgets" class="text-muted text-decoration-none small">&larr; Back to Budgets</a>
        <h2 class="h4 fw-bold mb-0">Create Budget</h2>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
    }

    <form method="post" class="card border-0 shadow-sm p-4 d-flex flex-column gap-4">
        <div>
            <label class="form-label small fw-semibold text-muted text-uppercase">Category</label>
            <select asp-for="CategoryId" class="form-select form-select-sm">
                <option value="">-- Select Category --</option>
                @foreach (var cat in Model.Categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            </select>
        </div>

        <div>
            <label class="form-label small fw-semibold text-muted text-uppercase">Month</label>
            <input type="month" asp-for="Month" class="form-control form-control-sm" />
        </div>

        <div>
            <label class="form-label small fw-semibold text-muted text-uppercase">Spending Limit</label>
            <div class="input-group input-group-sm">
                <span class="input-group-text">&euro;</span>
                <input type="number" asp-for="LimitAmount" step="0.01" min="0.01"
                       class="form-control" placeholder="500.00" />
                <span class="input-group-text">EUR</span>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-3">
            <a href="/Budgets" class="btn btn-outline-secondary btn-sm">Cancel</a>
            <button type="submit" class="btn btn-brand btn-sm">Create Budget</button>
        </div>
    </form>
</div>
