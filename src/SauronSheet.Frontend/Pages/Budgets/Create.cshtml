@page "/budgets/create"
@model SauronSheet.Frontend.Pages.Budgets.CreateModel
@{
    ViewData["Title"] = "Create Budget";
}

<div class="mx-auto d-flex flex-column gap-4" style="max-width:640px">
    <div class="d-flex align-items-center gap-3">
        <a href="/budgets" class="btn btn-link btn-sm text-muted text-decoration-none">&larr; Back to Budgets</a>
        <h3 class="h3 fw-bold mb-0">Create Budget</h3>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger rounded-3" role="alert" x-transition.opacity>@Model.ErrorMessage</div>
    }

    <div class="card shadow-sm p-4">
        <form method="post" class="d-flex flex-column gap-4"
              x-data='{
                  budgetType: "@Model.BudgetType",
                  categoryId: "@Model.CategoryId.ToString()",
                  categories: @Json.Serialize(Model.Categories.Select(c => new { c.Id, c.Name, c.Type })),
                  limitLabel: "@(Model.BudgetType == "Income" ? "Income Target" : "Spending Limit")",
                  limitHint: "@(Model.BudgetType == "Income" ? "Minimum earnings expected per period." : "Maximum spending allowed per period.")",
                  init() {
                      this.rebuildOptions();
                      if (this.budgetType) {
                          this.updateLabels();
                      }
                  },
                  get filteredCategories() {
                      if (!this.budgetType) return this.categories;
                      return this.categories.filter(c => c.type === this.budgetType);
                  },
                  rebuildOptions() {
                      const sel = document.getElementById("CategoryId");
                      if (!sel) return;
                      const current = sel.value;
                      while (sel.options.length > 1) sel.remove(1);
                      this.filteredCategories.forEach(cat => {
                          const opt = document.createElement("option");
                          opt.value = cat.id;
                          opt.textContent = cat.name;
                          sel.appendChild(opt);
                      });
                      if (current && [...sel.options].some(o => o.value === current)) {
                          sel.value = current;
                      } else {
                          sel.value = "";
                      }
                  },
                  updateLabels() {
                      if (this.budgetType === "Income") {
                          this.limitLabel = "Income Target";
                          this.limitHint = "Minimum earnings expected per period.";
                      } else {
                          this.limitLabel = "Spending Limit";
                          this.limitHint = "Maximum spending allowed per period.";
                      }
                  },
                  validateForm(e) {
                      const limit = parseFloat(this.$refs.limitInput?.value ?? "");
                      if (isNaN(limit) || limit <= 0) {
                          e.preventDefault();
                          const errSpan = this.$refs.limitInput?.closest("div")?.querySelector(".text-danger");
                          if (errSpan) errSpan.textContent = "Limit must be a positive number.";
                          return;
                      }
                      const fromVal = this.$refs.fromInput?.value;
                      const untilVal = this.$refs.untilInput?.value;
                      if (fromVal && untilVal && new Date(untilVal) < new Date(fromVal)) {
                          e.preventDefault();
                          const errSpan = this.$refs.untilInput?.closest("div")?.querySelector(".text-danger");
                          if (errSpan) errSpan.textContent = "Effective Until must be on or after Effective From.";
                      }
                  }
              }'
              x-effect="rebuildOptions()"
              @@submit="validateForm">

            @* ── Budget Type ── *@
            <fieldset class="border-0 p-0 m-0">
                <legend class="form-label fw-semibold mb-3">What is this budget for?</legend>
                <div class="d-flex gap-3" role="radiogroup" aria-label="Budget type">
                    <label class="budget-type-card flex-fill" id="label-income">
                        <input type="radio" name="BudgetType" value="Income"
                               x-model="budgetType"
                               class="budget-type-radio" required
                               @@change="updateLabels()" />
                        <span class="budget-type-content text-center p-3 rounded-3 border d-flex flex-column align-items-center gap-2">
                            <span class="budget-type-icon">&#x1F4C8;</span>
                            <span>
                                <span class="d-block fw-semibold">Income</span>
                                <span class="d-block small text-muted">Earnings target</span>
                            </span>
                        </span>
                    </label>
                    <label class="budget-type-card flex-fill" id="label-expense" data-toggle-accent="danger">
                        <input type="radio" name="BudgetType" value="Expense"
                               x-model="budgetType"
                               class="budget-type-radio" required
                               @@change="updateLabels()" />
                        <span class="budget-type-content text-center p-3 rounded-3 border d-flex flex-column align-items-center gap-2">
                            <span class="budget-type-icon">&#x1F4C9;</span>
                            <span>
                                <span class="d-block fw-semibold">Expense</span>
                                <span class="d-block small text-muted">Spending limit</span>
                            </span>
                        </span>
                    </label>
                </div>
                <span asp-validation-for="BudgetType" class="text-danger small"></span>
            </fieldset>

            @* ── Visual separator ── *@
            <hr class="my-0" />

            @* ── Category ── *@
            <div id="category-section" x-show="budgetType" x-transition.opacity>
                <label asp-for="CategoryId" class="form-label fw-semibold">
                    <span id="category-label-text">Category</span>
                </label>
                <select asp-for="CategoryId" id="CategoryId" class="form-select" required
                        x-model="categoryId" x-init="categoryId = '@Model.CategoryId.ToString()'">
                    <option value="">-- Select a category --</option>
                </select>
                <div class="form-text" id="category-hint">Choose the category this budget applies to.</div>
                <span asp-validation-for="CategoryId" class="text-danger small"></span>
            </div>

            @* ── Limit ── *@
            <div id="limit-section" x-show="budgetType" x-transition.opacity>
                <label asp-for="LimitAmount" class="form-label fw-semibold">
                    <span id="limit-label-text" x-text="limitLabel">@(Model.BudgetType == "Income" ? "Income Target" : "Spending Limit")</span>
                </label>
                <div class="input-group">
                    <span class="input-group-text">&euro;</span>
                    <input type="number" asp-for="LimitAmount" step="0.01" min="0.01"
                           x-ref="limitInput"
                           class="form-control" placeholder="500.00" required />
                    <span class="input-group-text">EUR</span>
                </div>
                <div class="form-text" id="limit-hint" x-text="limitHint">@(Model.BudgetType == "Income" ? "Minimum earnings expected per period." : "Maximum spending allowed per period.")</div>
                <span asp-validation-for="LimitAmount" class="text-danger small"></span>
            </div>

            @* ── Dates ── *@
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="EffectiveFrom" class="form-label fw-semibold">Effective From</label>
                    <input x-data x-init="flatpickr($el, { dateFormat: 'Y-m-d', altInput: true, altFormat: 'd/m/Y', allowInput: true })"
                           type="text" asp-for="EffectiveFrom"
                           x-ref="fromInput"
                           class="form-control" required placeholder="DD/MM/AAAA" autocomplete="off" />
                    <span asp-validation-for="EffectiveFrom" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="EffectiveUntil" class="form-label fw-semibold">Effective Until</label>
                    <input x-data x-init="flatpickr($el, { dateFormat: 'Y-m-d', altInput: true, altFormat: 'd/m/Y', allowInput: true })"
                           type="text" asp-for="EffectiveUntil"
                           x-ref="untilInput"
                           class="form-control" placeholder="DD/MM/AAAA" autocomplete="off" />
                    <div class="form-text">Leave empty for a permanent budget.</div>
                    <span asp-validation-for="EffectiveUntil" class="text-danger small"></span>
                </div>
            </div>

            @* ── Period Granularity ── *@
            <div>
                <label asp-for="PeriodGranularity" class="form-label fw-semibold">Period Granularity</label>
                <select asp-for="PeriodGranularity" class="form-select" required>
                    <option value="">-- Select Granularity --</option>
                    <option value="Monthly">Monthly</option>
                    <option value="Quarterly">Quarterly</option>
                    <option value="Semester">Semester</option>
                    <option value="Annual">Annual</option>
                </select>
                <div class="form-text">How often the limit resets.</div>
                <span asp-validation-for="PeriodGranularity" class="text-danger small"></span>
            </div>

            @* ── Actions ── *@
            <div class="d-flex justify-content-end gap-2 pt-2">
                <a href="/budgets" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" id="submit-btn" data-mdb-ripple-init
                        class="btn btn-brand" :disabled="!budgetType">Create Budget</button>
            </div>
        </form>
    </div>
</div>

@* ── Styles live in wwwroot/css/site.css (.budget-type-*) ── *@
