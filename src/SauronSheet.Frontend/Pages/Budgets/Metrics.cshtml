@page "/budgets/metrics"
@model SauronSheet.Frontend.Pages.Budgets.MetricsModel
@using SauronSheet.Frontend.Helpers
@{
    ViewData["Title"] = "Budget Metrics";
}

<div class="d-flex flex-column gap-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2 class="h3 fw-bold mb-0">Budget Metrics</h2>
        <a href="/budgets" class="small text-brand text-decoration-none">&larr; Back to Budgets</a>
    </div>

    <!-- View Tabs -->
    <div class="card border-0 shadow-sm">
        <div class="d-flex flex-wrap gap-2 p-3">
            <a href="/budgets/metrics?View=Month"
               class="btn @(Model.View == "Month" ? "btn-brand" : "btn-outline-secondary") btn-sm">
                Current Month
            </a>
            <a href="/budgets/metrics?View=Period"
               class="btn @(Model.View == "Period" ? "btn-brand" : "btn-outline-secondary") btn-sm">
                Current Period
            </a>
            <a href="/budgets/metrics?View=Year"
               class="btn @(Model.View == "Year" ? "btn-brand" : "btn-outline-secondary") btn-sm">
                Current Year
            </a>
        </div>
    </div>

    @if (Model.Metrics.Any())
    {
        <!-- Overall Summary Cards -->
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-3">
            <div class="col">
                <div class="card border-0 shadow-sm p-3 text-center h-100">
                    <p class="small fw-semibold text-muted text-uppercase mb-1">Accumulated Limit</p>
                    <p class="h4 fw-bold text-brand mb-0">&euro;@Model.TotalAccumulatedLimit.ToString("N2")</p>
                </div>
            </div>
            <div class="col">
                <div class="card border-0 shadow-sm p-3 text-center h-100">
                    <p class="small fw-semibold text-muted text-uppercase mb-1">Spent</p>
                    <p class="h4 fw-bold mb-0">&euro;@Model.TotalSpent.ToString("N2")</p>
                </div>
            </div>
            <div class="col">
                <div class="card border-0 shadow-sm p-3 text-center h-100">
                    <p class="small fw-semibold text-muted text-uppercase mb-1">Remaining</p>
                    <p class="h4 fw-bold mb-0 @(Model.TotalRemaining >= 0 ? "text-success" : "text-danger")">
                        &euro;@Model.TotalRemaining.ToString("N2")
                    </p>
                </div>
            </div>
            <div class="col">
                <div class="card border-0 shadow-sm p-3 text-center h-100">
                    <p class="small fw-semibold text-muted text-uppercase mb-1">Consumed</p>
                    <p class="h4 fw-bold mb-0 @(Model.OverallPercentageUsed > 100 ? "text-danger" : Model.OverallPercentageUsed >= 75 ? "text-warning" : "text-success")">
                        @Model.OverallPercentageUsed.ToString("N1")%
                    </p>
                </div>
            </div>
        </div>

        <!-- Per-Budget Metric Cards -->
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
            @foreach (var metric in Model.Metrics)
            {
                var statusColor = metric.StatusLevel switch
                {
                    "Green" => "border-success",
                    "Yellow" => "border-warning",
                    "Red" => "border-danger",
                    "Overage" => "border-danger",
                    _ => "border-secondary"
                };

                var trafficLight = metric.StatusLevel switch
                {
                    "Green" => "🟢",
                    "Yellow" => "🟡",
                    "Red" => "🔴",
                    "Overage" => "🔴",
                    _ => "⚪"
                };

                var pctDisplay = Math.Min(metric.PercentageUsed, 100);
                var pctClass = metric.PercentageUsed > 100 ? "text-danger" :
                               metric.PercentageUsed >= 75 ? "text-warning" : "text-success";

                <div class="col">
                    <div class="card border-0 shadow-sm metric-card border-start border-3 @statusColor h-100">
                        <div class="card-body p-3">
                            <!-- Category header -->
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h6 class="fw-semibold mb-0">@metric.CategoryName</h6>
                                <span class="fs-5">@trafficLight</span>
                            </div>

                            <!-- Periods info -->
                            <p class="small text-muted mb-2">
                                @metric.PeriodsElapsed period(s) elapsed
                            </p>

                            <!-- Progress bar -->
                            <div class="progress rounded-pill mb-2" style="height:10px" role="progressbar"
                                 aria-valuenow="@((int)Math.Min(metric.PercentageUsed, 100))" aria-valuemin="0" aria-valuemax="100">
                                <div class="progress-bar @(metric.StatusLevel switch { "Green" => "bg-success", "Yellow" => "bg-warning", "Red" => "bg-danger", "Overage" => "bg-danger", _ => "bg-secondary" })"
                                     style="width:@(pctDisplay)%">
                                </div>
                            </div>

                            <p class="small @pctClass fw-semibold mb-3">
                                @Math.Round(metric.PercentageUsed, 1)% consumed
                            </p>

                            <!-- Numbers grid -->
                            <div class="row g-1 text-center small">
                                <div class="col-4">
                                    <p class="text-muted mb-0">Limit</p>
                                    <p class="fw-medium mb-0">&euro;@metric.AccumulatedLimit.ToString("N0")</p>
                                </div>
                                <div class="col-4">
                                    <p class="text-muted mb-0">Spent</p>
                                    <p class="fw-medium mb-0">&euro;@metric.Spent.ToString("N0")</p>
                                </div>
                                <div class="col-4">
                                    <p class="text-muted mb-0">Left</p>
                                    <p class="fw-medium mb-0 @(metric.Remaining >= 0 ? "text-success" : "text-danger")">
                                        &euro;@metric.Remaining.ToString("N0")
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm p-5 text-center" role="status" aria-live="polite">
            <p class="h5 text-muted mb-3">No budget data for the current @Model.View.ToLowerInvariant().</p>
            <p class="text-muted mb-4">Create budgets to see your spending metrics.</p>
            <div><a href="/budgets/create" class="btn btn-brand">+ Create Budget</a></div>
        </div>
    }
</div>
