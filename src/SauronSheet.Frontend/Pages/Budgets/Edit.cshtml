@page "/Budgets/Edit/{id:guid}"
@model SauronSheet.Frontend.Pages.Budgets.EditModel
@{
    ViewData["Title"] = "Edit Budget";
}

<div class="max-w-lg mx-auto space-y-6">
    <div class="flex items-center gap-4">
        <a href="/Budgets" class="text-gray-500 hover:text-gray-700">&larr; Back to Budgets</a>
        <h2 class="text-2xl font-bold text-gray-900">Edit Budget</h2>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="rounded-xl bg-red-50 border border-red-200 p-4">
            <p class="text-sm text-red-700">@Model.ErrorMessage</p>
        </div>
    }

    @if (Model.Budget != null)
    {
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 space-y-5">
            <!-- Read-only info -->
            <div class="grid grid-cols-2 gap-4 pb-4 border-b border-gray-100">
                <div>
                    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Category</p>
                    <p class="font-medium text-gray-900">
                        @if (!string.IsNullOrEmpty(Model.Budget.CategoryColor))
                        {
                            <span class="inline-block w-3 h-3 rounded-full mr-2"
                                  style="background-color: @Model.Budget.CategoryColor"></span>
                        }
                        @Model.Budget.CategoryName
                    </p>
                </div>
                <div>
                    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Period</p>
                    <p class="font-medium text-gray-900">@Model.Budget.PeriodStart.ToString("MMMM yyyy")</p>
                </div>
            </div>

            <!-- Current status display -->
            <div class="grid grid-cols-3 gap-4 pb-4">
                <div>
                    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Current Spend</p>
                    <p class="text-lg font-semibold @(Model.Budget.CurrentSpend > Model.Budget.LimitAmount ? "text-red-600" : "text-gray-900")">
                        &euro;@Model.Budget.CurrentSpend.ToString("N2")
                    </p>
                </div>
                <div>
                    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Remaining</p>
                    <p class="text-lg font-semibold @(Model.Budget.RemainingAmount >= 0 ? "text-brand-600" : "text-red-600")">
                        &euro;@Model.Budget.RemainingAmount.ToString("N2")
                    </p>
                </div>
                <div>
                    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Status</p>
                    <partial name="Shared/_BudgetStatusBadge" model="Model.Budget.StatusLevel" />
                </div>
            </div>

            <!-- Edit form -->
            <form method="post">
                <input type="hidden" asp-for="BudgetId" />

                <div class="mb-5">
                    <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Spending Limit</label>
                    <div class="flex items-center gap-2">
                        <span class="text-gray-500">&euro;</span>
                        <input type="number" asp-for="NewLimitAmount" step="0.01" min="0.01"
                               class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500" />
                        <span class="text-sm text-gray-500">EUR</span>
                    </div>
                </div>

                <div class="flex justify-end gap-3">
                    <a href="/Budgets" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Cancel</a>
                    <button type="submit" class="px-5 py-2 text-sm font-semibold text-white bg-brand-600 rounded-lg hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500 transition-colors shadow-sm">
                        Save Changes
                    </button>
                </div>
            </form>
        </div>
    }
    else
    {
        <div class="bg-white rounded-lg shadow p-6 text-center">
            <p class="text-gray-500">Budget not found.</p>
            <a href="/Budgets" class="text-blue-600 hover:underline">Back to Budgets</a>
        </div>
    }
</div>
