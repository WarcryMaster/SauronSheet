@page "/budgets/edit/{id:guid}"
@model SauronSheet.Frontend.Pages.Budgets.EditModel
@using Microsoft.Extensions.Localization
@using SauronSheet.Application.Resources
@inject IStringLocalizer<SharedResources> Localizer
@{
    ViewData["Title"] = Localizer["Budgets.Edit.Title"];
}

<div class="mx-auto d-flex flex-column gap-4" style="max-width:560px">
    <div class="d-flex align-items-center gap-3">
        <a href="/budgets" class="text-muted text-decoration-none small" data-testid="back-link">&larr; @Localizer["Budgets.Edit.Back"]</a>
        <h3 class="h3 fw-bold mb-0">@Localizer["Budgets.Edit.Title"]</h3>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger rounded-3" role="alert" x-transition.opacity>@Model.ErrorMessage</div>
    }

    @if (Model.Budget != null)
    {
        <div class="card border-0 shadow-sm p-4 d-flex flex-column gap-4">
            @* Read-only info *@
            <div class="row g-3 pb-3 border-bottom">
                <div class="col-6">
                    <p class="small fw-semibold text-muted text-uppercase mb-1">@Localizer["Budgets.Edit.Label.Category"]</p>
                    <p class="fw-medium mb-0">@Model.Budget.CategoryName</p>
                </div>
                <div class="col-6">
                    <p class="small fw-semibold text-muted text-uppercase mb-1">@Localizer["Budgets.Edit.Label.Status"]</p>
                    <p class="fw-medium mb-0">
                        @{
                            bool isActive = Model.Budget.EffectiveUntil == null
                                || Model.Budget.EffectiveUntil.Value >= DateOnly.FromDateTime(DateTime.UtcNow);
                        }
                        <span class="badge @(isActive ? "bg-success" : "bg-secondary")">@(isActive ? Localizer["Budgets.Edit.Status.Active"] : Localizer["Budgets.Edit.Status.Inactive"])</span>
                    </p>
                </div>
                <div class="col-6">
                    <p class="small fw-semibold text-muted text-uppercase mb-1">@Localizer["Budgets.Edit.Label.EffectiveFrom"]</p>
                    <p class="fw-medium mb-0">@Model.Budget.EffectiveFrom.ToString("yyyy-MM-dd")</p>
                </div>
                <div class="col-6">
                    <p class="small fw-semibold text-muted text-uppercase mb-1">@Localizer["Budgets.Edit.Label.EffectiveUntil"]</p>
                    <p class="fw-medium mb-0">@(Model.Budget.EffectiveUntil?.ToString("yyyy-MM-dd") ?? Localizer["Budgets.Edit.Permanent"])</p>
                </div>
            </div>

            @* Edit form *@
            <form method="post" asp-page-handler="Update" class="d-flex flex-column gap-4"
                  x-data="{ 
                      loading: false,
                      openDeleteModal() {
                          new mdb.Modal(document.getElementById('budgetDeleteConfirmModal')).show();
                      }
                  }" @@submit="loading = true">
                <input type="hidden" asp-for="BudgetId" />

                @* Spending limit *@
                <div>
                    <label asp-for="NewLimitAmount" class="form-label small fw-semibold text-muted text-uppercase mb-1">@Localizer["Budgets.Edit.Label.SpendingLimit"]</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text">&euro;</span>
                        <input type="number" asp-for="NewLimitAmount" step="0.01" min="0.01"
                               class="form-control" required />
                        <span class="input-group-text">EUR</span>
                    </div>
                </div>

                @* Period granularity *@
                <div>
                    <label asp-for="PeriodGranularity" class="form-label small fw-semibold text-muted text-uppercase mb-1">@Localizer["Budgets.Edit.Label.PeriodGranularity"]</label>
                    <select asp-for="PeriodGranularity" class="form-select form-select-sm" required>
                        <option value="Monthly">@Localizer["Budgets.Create.Granularity.Monthly"]</option>
                        <option value="Quarterly">@Localizer["Budgets.Create.Granularity.Quarterly"]</option>
                        <option value="Semester">@Localizer["Budgets.Create.Granularity.Semester"]</option>
                        <option value="Annual">@Localizer["Budgets.Create.Granularity.Annual"]</option>
                    </select>
                </div>

                @* Effective dates *@
                <div class="row g-3">
                    <div class="col-6">
                        <label asp-for="EffectiveFrom" class="form-label small fw-semibold text-muted text-uppercase mb-1">@Localizer["Budgets.Edit.Label.EffectiveFrom"]</label>
                        <input x-data x-init="flatpickr($el, { dateFormat: 'Y-m-d', altInput: true, altFormat: 'd/m/Y', allowInput: true })"
                               type="text" asp-for="EffectiveFrom" class="form-control form-control-sm" required placeholder="@Localizer["Transactions.Add.Placeholder.Date"]" autocomplete="off" />
                    </div>
                    <div class="col-6">
                        <label asp-for="EffectiveUntil" class="form-label small fw-semibold text-muted text-uppercase mb-1">@Localizer["Budgets.Edit.Label.EffectiveUntil"]</label>
                        <input x-data x-init="flatpickr($el, { dateFormat: 'Y-m-d', altInput: true, altFormat: 'd/m/Y', allowInput: true })"
                               type="text" asp-for="EffectiveUntil" class="form-control form-control-sm" placeholder="@Localizer["Transactions.Add.Placeholder.Date"]" autocomplete="off" />
                        <small class="text-muted">@Localizer["Budgets.Edit.Hint.Permanent"]</small>
                    </div>
                </div>

                @* Buttons *@
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                    <div class="d-flex flex-wrap gap-2">
                        <button type="button"
                                id="budgetStatusActionButton"
                                data-budget-status-trigger="true"
                                data-budget-id="@Model.Budget.Id"
                                data-budget-action="@(isActive ? Localizer["Budgets.Edit.Action.Deactivate"] : Localizer["Budgets.Edit.Action.Activate"])"
                                data-budget-name="@Model.Budget.CategoryName"
                                data-budget-period="@Model.Budget.PeriodGranularity"
                                class="btn btn-sm @(isActive ? "btn-outline-danger" : "btn-outline-success")"
                                data-testid="budget-status-btn">@(isActive ? Localizer["Budgets.Edit.Action.Deactivate"] : Localizer["Budgets.Edit.Action.Activate"])</button>
                        <button type="button"
                                id="deleteBudgetButton"
                                @@click="openDeleteModal()"
                                class="btn btn-outline-danger btn-sm"
                                data-testid="delete-budget-btn">@Localizer["Budgets.Edit.Action.Delete"]</button>
                    </div>
                    <div class="d-flex flex-wrap gap-3">
                        <a href="/budgets" class="btn btn-outline-secondary btn-sm" data-testid="cancel-link">@Localizer["Common.Cancel"]</a>
                        <button type="submit" data-mdb-ripple-init class="btn btn-brand btn-sm" :disabled="loading" data-testid="submit-btn">
                            <span x-show="!loading">@Localizer["Budgets.Edit.Submit"]</span>
                            <span x-show="loading">@Localizer["Budgets.Edit.SubmitLoading"]</span>
                            <span x-show="loading" class="spinner-border spinner-border-sm ms-1" role="status" aria-hidden="true"></span>
                        </button>
                    </div>
                </div>
            </form>
        </div>
        <!-- Hidden form for delete submission (outside x-data — modal cannot reach Alpine @@click) -->
        <form id="budgetDeleteForm" method="post" action="?handler=Delete" style="display:none">
            @Html.AntiForgeryToken()
            <input type="hidden" name="BudgetId" value="@Model.Budget.Id" />
        </form>

        <!-- Delete Confirmation Modal (outside x-data — use onclick instead of @@click via Alpine) -->
        <div class="modal fade" id="budgetDeleteConfirmModal" tabindex="-1" aria-labelledby="budgetDeleteConfirmLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title text-danger fs-6" id="budgetDeleteConfirmLabel">
                            ⚠️ @Localizer["Budgets.Edit.Modal.DeleteTitle"]
                        </h5>
                        <button type="button" class="btn-close" data-mdb-dismiss="modal" aria-label="@Localizer["Common.Close"]"></button>
                    </div>
                    <div class="modal-body">
                        <p class="mb-2">@Localizer["Budgets.Edit.Modal.DeleteConfirm"]</p>
                        <p class="text-muted small mb-0">@Localizer["Budgets.Edit.Modal.DeleteWarning"]</p>
                    </div>
                    <div class="modal-footer border-top gap-2">
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-mdb-dismiss="modal">
                            ← @Localizer["Common.Cancel"]
                        </button>
                        <button type="button" class="btn btn-danger btn-sm"
                                data-testid="confirm-delete-budget-btn"
                                onclick="document.getElementById('budgetDeleteForm').submit()">
                            🗑️ @Localizer["Common.Delete"]
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm p-5 text-center">
            <p class="text-muted mb-3">@Localizer["Budgets.Edit.NotFound"]</p>
            <a href="/budgets" class="btn btn-outline-secondary btn-sm" data-testid="back-link">@Localizer["Budgets.Edit.Back"]</a>
        </div>
    }
</div>

@if (Model.Budget != null)
{
    <partial name="Shared/Components/_BudgetStatusModal" />
}
