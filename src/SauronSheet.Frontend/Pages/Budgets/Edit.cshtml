@page "/budgets/edit/{id:guid}"
@model SauronSheet.Frontend.Pages.Budgets.EditModel
@using SauronSheet.Frontend.Helpers
@{
    ViewData["Title"] = "Edit Budget";
}

<div class="mx-auto d-flex flex-column gap-4" style="max-width:520px">
    <div class="d-flex align-items-center gap-3">
        <a href="/budgets" class="text-muted text-decoration-none small">&larr; Back to Budgets</a>
        <h2 class="h4 fw-bold mb-0">Edit Budget</h2>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
    }

    @if (Model.Budget != null)
    {
        <div class="card border-0 shadow-sm p-4 d-flex flex-column gap-4">
            <!-- Read-only info -->
            <div class="row g-3 pb-3 border-bottom">
                <div class="col-6">
                    <p class="small fw-semibold text-muted text-uppercase mb-1">Category</p>
                    <div class="fw-medium mb-0 d-inline-flex">
                        <partial name="Shared/_CategoryBadge" model="new CategoryBadgeDisplay(Model.Budget.CategoryName, AccentColor: Model.Budget.CategoryColor)" />
                    </div>
                </div>
                <div class="col-6">
                    <p class="small fw-semibold text-muted text-uppercase mb-1">Period</p>
                    <p class="fw-medium mb-0">@Model.Budget.PeriodStart.ToString("MMMM yyyy")</p>
                </div>
            </div>

            <!-- Current status display -->
            <div class="row g-3 pb-3">
                <div class="col-4">
                    <p class="small fw-semibold text-muted text-uppercase mb-1">Current Spend</p>
                    <p class="h5 fw-semibold mb-0 @(Model.Budget.CurrentSpend > Model.Budget.LimitAmount ? "text-danger" : "")">
                        &euro;@Model.Budget.CurrentSpend.ToString("N2")
                    </p>
                </div>
                <div class="col-4">
                    <p class="small fw-semibold text-muted text-uppercase mb-1">Remaining</p>
                    <p class="h5 fw-semibold mb-0 @(Model.Budget.RemainingAmount >= 0 ? "text-brand" : "text-danger")">
                        &euro;@Model.Budget.RemainingAmount.ToString("N2")
                    </p>
                </div>
                <div class="col-4">
                    <p class="small fw-semibold text-muted text-uppercase mb-1">Status</p>
                    <partial name="Shared/_BudgetStatusBadge" model="Model.Budget.StatusLevel" />
                </div>
            </div>

            <!-- Edit form -->
            <form method="post">
                <input type="hidden" asp-for="BudgetId" />
                <div class="mb-4">
                    <label class="form-label small fw-semibold text-muted text-uppercase">Spending Limit</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text">&euro;</span>
                        <input type="number" asp-for="NewLimitAmount" step="0.01" min="0.01" class="form-control" />
                        <span class="input-group-text">EUR</span>
                    </div>
                </div>
                <div class="d-flex justify-content-end gap-3">
                    <a href="/budgets" class="btn btn-outline-secondary btn-sm">Cancel</a>
                    <button type="submit" class="btn btn-brand btn-sm">Save Changes</button>
                </div>
            </form>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm p-5 text-center">
            <p class="text-muted mb-3">Budget not found.</p>
            <a href="/budgets" class="btn btn-outline-secondary btn-sm">Back to Budgets</a>
        </div>
    }
</div>
