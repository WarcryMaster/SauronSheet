@page "/budgets/comparison"
@model SauronSheet.Frontend.Pages.Budgets.ComparisonModel
@using SauronSheet.Frontend.Helpers
@using System.Text.Json
@{
    ViewData["Title"] = "Budget vs Actual";
    var currentYear = Model.Year ?? DateTime.UtcNow.Year;
    var currentMonth = Model.Month ?? DateTime.UtcNow.Month;
    var monthName = new DateTime(currentYear, currentMonth, 1).ToString("MMMM yyyy");
}

<div class="d-flex flex-column gap-4">
    <div class="d-flex justify-content-between align-items-center">
        <h3 class="h3 fw-bold mb-0">📊 Budget vs Actual</h3>
        <a href="/budgets" class="small text-brand text-decoration-none">&larr; Back to Budgets</a>
    </div>

    <!-- Month Filter -->
    <form method="get" action="/budgets/comparison" class="card border-0 shadow-sm p-3"
          x-data @@submit.prevent="const val = $refs.monthPicker.value; if (val) { const [y, m] = val.split('-'); window.location.href = '/budgets/comparison?Year=' + y + '&Month=' + parseInt(m); } else { window.location.href = '/budgets/comparison'; }">
        <div class="d-flex flex-wrap align-items-center gap-3">
            <label class="small fw-semibold text-muted text-uppercase mb-0">Month:</label>
            <input type="month" name="month" id="monthPicker"
                   x-ref="monthPicker"
                   value="@($"{currentYear:D4}-{currentMonth:D2}")"
                   class="form-control form-control-sm" style="width:auto" />
            <button type="submit" class="btn btn-brand btn-sm">Filter</button>
        </div>
    </form>

    @if (Model.Comparison.Any())
    {
        <!-- Summary Cards -->
        <div class="row g-3">
            <div class="col-12 col-sm-4">
                <div class="card border-0 shadow-sm p-4 text-center">
                    <p class="small fw-semibold text-muted text-uppercase mb-1">Total Budgeted</p>
                    <p class="h4 fw-bold text-brand mb-0">&euro;@Model.TotalBudgeted.ToString("N2")</p>
                </div>
            </div>
            <div class="col-12 col-sm-4">
                <div class="card border-0 shadow-sm p-4 text-center">
                    <p class="small fw-semibold text-muted text-uppercase mb-1">Total Actual</p>
                    <p class="h4 fw-bold mb-0">&euro;@Model.TotalActual.ToString("N2")</p>
                </div>
            </div>
            <div class="col-12 col-sm-4">
                <div class="card border-0 shadow-sm p-4 text-center">
                    <p class="small fw-semibold text-muted text-uppercase mb-1">Difference</p>
                    <p class="h4 fw-bold mb-0 @(Model.TotalDifference >= 0 ? "text-brand" : "text-danger")">&euro;@Model.TotalDifference.ToString("N2")</p>
                </div>
            </div>
        </div>

        <!-- Horizontal Bar Chart -->
        <div class="card border-0 shadow-sm p-4"
             x-data="{
                 init() {
                     const el = document.getElementById('budgets-comparison-data');
                     const chartData = el ? JSON.parse(el.textContent) : null;
                     const canvas = $refs.comparisonCanvas;
                     if (!canvas || !chartData || chartData.length === 0) return;
                     const rootStyle = getComputedStyle(document.documentElement);
                     const brand = rootStyle.getPropertyValue('--brand').trim();
                     const danger = rootStyle.getPropertyValue('--semantic-danger').trim();
                     new Chart(canvas, {
                         type: 'bar',
                         data: {
                             labels: chartData.map(d => d.categoryName),
                             datasets: [
                                 {
                                     label: 'Budget',
                                     data: chartData.map(d => d.budgetLimit || 0),
                                     backgroundColor: 'color-mix(in srgb, ' + brand + ' 60%, transparent)',
                                     borderColor: brand,
                                     borderWidth: 1
                                 },
                                 {
                                     label: 'Actual',
                                     data: chartData.map(d => d.actualSpend),
                                     backgroundColor: 'color-mix(in srgb, ' + danger + ' 60%, transparent)',
                                     borderColor: danger,
                                     borderWidth: 1
                                 }
                             ]
                         },
                         options: {
                             indexAxis: 'y',
                             responsive: true,
                             maintainAspectRatio: false,
                             plugins: { legend: { position: 'top' } },
                             scales: {
                                 x: {
                                     beginAtZero: true,
                                     ticks: { callback: value => '\u20AC' + value }
                                 }
                             }
                         }
                     });
                 }
             }">
            <h3 class="h6 fw-semibold mb-3">Budget vs Actual by Category</h3>
            <canvas x-ref="comparisonCanvas" style="height: 300px;"></canvas>
        </div>

        <!-- Comparison Table -->
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="text-uppercase small fw-semibold text-muted">Category</th>
                            <th class="text-uppercase small fw-semibold text-muted text-end">Budget</th>
                            <th class="text-uppercase small fw-semibold text-muted text-end">Actual</th>
                            <th class="text-uppercase small fw-semibold text-muted text-end">Difference</th>
                            <th class="text-uppercase small fw-semibold text-muted text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Comparison)
                        {
                            <tr>
                                <td class="small">
                                    <partial name="Shared/_CategoryBadge" model="new CategoryBadgeDisplay(item.CategoryName, AccentColor: item.CategoryColor)" />
                                </td>
                                <td class="text-end small fw-medium">
                                    @if (item.BudgetLimit.HasValue)
                                    {
                                        <span>&euro;@item.BudgetLimit.Value.ToString("N2")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Sin presupuesto</span>
                                    }
                                </td>
                                <td class="text-end small fw-medium">&euro;@item.ActualSpend.ToString("N2")</td>
                                <td class="text-end small">
                                    @if (item.Difference.HasValue)
                                    {
                                        <span class="fw-medium @(item.Difference.Value >= 0 ? "text-success" : "text-danger")">&euro;@item.Difference.Value.ToString("N2")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">&mdash;</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(item.StatusLevel))
                                    {
                                        <partial name="Shared/_BudgetStatusBadge" model="item.StatusLevel" />
                                    }
                                    else
                                    {
                                        <span class="text-muted small">&mdash;</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light fw-bold">
                        <tr>
                            <td class="small">Total</td>
                            <td class="text-end small">&euro;@Model.TotalBudgeted.ToString("N2")</td>
                            <td class="text-end small">&euro;@Model.TotalActual.ToString("N2")</td>
                            <td class="text-end small @(Model.TotalDifference >= 0 ? "text-success" : "text-danger")">&euro;@Model.TotalDifference.ToString("N2")</td>
                            <td class="text-center small">&mdash;</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm p-5 text-center" role="status" aria-live="polite">
            <p class="h5 text-muted mb-3">No budget data for @monthName.</p>
            <p class="text-muted mb-4">Create budgets to compare them against actual spending.</p>
            <div><a href="/budgets/create" class="btn btn-brand">+ Create Budget</a></div>
        </div>
    }
</div>

<script type="application/json" id="budgets-comparison-data">
    @Json.Serialize(Model.Comparison)
</script>
