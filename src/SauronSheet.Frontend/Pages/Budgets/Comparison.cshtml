@page "/Budgets/Comparison"
@model SauronSheet.Frontend.Pages.Budgets.ComparisonModel
@using System.Text.Json
@{
    ViewData["Title"] = "Budget vs Actual";
    var currentYear = Model.Year ?? DateTime.UtcNow.Year;
    var currentMonth = Model.Month ?? DateTime.UtcNow.Month;
    var monthName = new DateTime(currentYear, currentMonth, 1).ToString("MMMM yyyy");
}

<div class="space-y-6">
    <div class="flex justify-between items-center">
        <h2 class="text-2xl font-bold text-gray-900">📊 Budget vs Actual</h2>
        <a href="/Budgets" class="text-blue-600 hover:underline">&larr; Back to Budgets</a>
    </div>

    <!-- Month Filter -->
    <form method="get" action="/Budgets/Comparison" class="bg-white rounded-lg shadow p-4">
        <div class="flex items-center gap-4">
            <label class="text-sm font-medium text-gray-700">Month:</label>
            <input type="month"
                   name="month"
                   value="@($"{currentYear:D4}-{currentMonth:D2}")"
                   class="border rounded px-3 py-2 text-sm"
                   id="monthPicker" />
            <button type="submit" class="px-4 py-2 bg-gray-600 text-white rounded hover:bg-gray-700 text-sm">
                Filter
            </button>
        </div>
    </form>

    @if (Model.Comparison.Any())
    {
        <!-- Summary Cards -->
        <div class="grid grid-cols-3 gap-4">
            <div class="bg-white rounded-lg shadow p-4 text-center">
                <p class="text-sm text-gray-500">Total Budgeted</p>
                <p class="text-2xl font-bold text-blue-600">€@Model.TotalBudgeted.ToString("N2")</p>
            </div>
            <div class="bg-white rounded-lg shadow p-4 text-center">
                <p class="text-sm text-gray-500">Total Actual</p>
                <p class="text-2xl font-bold text-gray-900">€@Model.TotalActual.ToString("N2")</p>
            </div>
            <div class="bg-white rounded-lg shadow p-4 text-center">
                <p class="text-sm text-gray-500">Difference</p>
                <p class="text-2xl font-bold @(Model.TotalDifference >= 0 ? "text-green-600" : "text-red-600")">
                    €@Model.TotalDifference.ToString("N2")
                </p>
            </div>
        </div>

        <!-- Horizontal Bar Chart -->
        <div class="bg-white rounded-lg shadow p-6">
            <h3 class="text-lg font-semibold mb-4">Budget vs Actual by Category</h3>
            <canvas id="comparisonChart" style="height: 300px;"></canvas>
        </div>

        <!-- Comparison Table -->
        <div class="bg-white rounded-lg shadow overflow-hidden">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Category</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Budget</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actual</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Difference</th>
                        <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Status</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @foreach (var item in Model.Comparison)
                    {
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap">
                                @if (!string.IsNullOrEmpty(item.CategoryColor))
                                {
                                    <span class="inline-block w-3 h-3 rounded-full mr-2"
                                          style="background-color: @item.CategoryColor"></span>
                                }
                                @item.CategoryName
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                @if (item.BudgetLimit.HasValue)
                                {
                                    <span>€@item.BudgetLimit.Value.ToString("N2")</span>
                                }
                                else
                                {
                                    <span class="text-gray-400">No budget</span>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                €@item.ActualSpend.ToString("N2")
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                                @if (item.Difference.HasValue)
                                {
                                    <span class="@(item.Difference.Value >= 0 ? "text-green-600" : "text-red-600") font-medium">
                                        €@item.Difference.Value.ToString("N2")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-gray-400">—</span>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-center">
                                @if (!string.IsNullOrEmpty(item.StatusLevel))
                                {
                                    <partial name="Shared/_BudgetStatusBadge" model="item.StatusLevel" />
                                }
                                else
                                {
                                    <span class="text-gray-400 text-xs">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="bg-gray-50 font-bold">
                    <tr>
                        <td class="px-6 py-4">Total</td>
                        <td class="px-6 py-4 text-right">€@Model.TotalBudgeted.ToString("N2")</td>
                        <td class="px-6 py-4 text-right">€@Model.TotalActual.ToString("N2")</td>
                        <td class="px-6 py-4 text-right @(Model.TotalDifference >= 0 ? "text-green-600" : "text-red-600")">
                            €@Model.TotalDifference.ToString("N2")
                        </td>
                        <td class="px-6 py-4 text-center">—</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
    else
    {
        <div class="bg-white rounded-lg shadow p-8 text-center">
            <p class="text-xl text-gray-500 mb-4">No budget data for @monthName.</p>
            <p class="text-gray-400 mb-6">Create budgets to compare them against actual spending.</p>
            <a href="/Budgets/Create" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
                + Create Budget
            </a>
        </div>
    }
</div>

<script>
    // Parse month picker value into Year/Month query params
    document.getElementById('monthPicker')?.closest('form')?.addEventListener('submit', function(e) {
        e.preventDefault();
        var val = document.getElementById('monthPicker').value;
        if (val) {
            var parts = val.split('-');
            window.location.href = '/Budgets/Comparison?Year=' + parts[0] + '&Month=' + parseInt(parts[1]);
        } else {
            window.location.href = '/Budgets/Comparison';
        }
    });

    // Chart.js horizontal bar chart
    document.addEventListener('DOMContentLoaded', function() {
        var chartData = @Html.Raw(Json.Serialize(Model.Comparison));
        var ctx = document.getElementById('comparisonChart');
        if (ctx && chartData && chartData.length > 0) {
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: chartData.map(function(d) { return d.categoryName; }),
                    datasets: [
                        {
                            label: 'Budget',
                            data: chartData.map(function(d) { return d.budgetLimit || 0; }),
                            backgroundColor: 'rgba(59, 130, 246, 0.6)',
                            borderColor: 'rgb(59, 130, 246)',
                            borderWidth: 1
                        },
                        {
                            label: 'Actual',
                            data: chartData.map(function(d) { return d.actualSpend; }),
                            backgroundColor: 'rgba(239, 68, 68, 0.6)',
                            borderColor: 'rgb(239, 68, 68)',
                            borderWidth: 1
                        }
                    ]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'top'
                        }
                    },
                    scales: {
                        x: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) { return '€' + value; }
                            }
                        }
                    }
                }
            });
        }
    });
</script>
