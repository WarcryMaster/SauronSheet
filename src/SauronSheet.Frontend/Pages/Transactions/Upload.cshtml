@page
@model SauronSheet.Frontend.Pages.Transactions.UploadModel
@{
    ViewData["Title"] = "Upload Bank Statement";
}

<div class="mx-auto d-flex flex-column gap-4" style="max-width: 640px;">
    <div class="d-flex align-items-center gap-3">
        <a href="/transactions" class="btn btn-link btn-sm text-muted text-decoration-none">&larr; Back</a>
        <h3 class="h3 fw-bold mb-0">Upload Bank Statement</h3>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger d-flex align-items-start gap-2 rounded-3" role="alert" x-transition.opacity>
            <span class="fw-bold">!</span>
            <p class="mb-0 small">@Model.ErrorMessage</p>
        </div>
    }

    @if (Model.ImportResult != null)
    {
        <div class="alert alert-success rounded-3" x-transition.opacity>
            <p class="fw-semibold mb-1">
                ✅ Import Complete: @Model.ImportResult.ImportedCount imported, @Model.ImportResult.SkippedCount skipped
            </p>
            @if (Model.ImportResult.Errors.Any())
            {
                <details class="mt-2">
                    <summary class="small">Show errors (@Model.ImportResult.Errors.Count)</summary>
                    <ul class="mt-2 mb-0">
                        @foreach (var error in Model.ImportResult.Errors)
                        {
                            <li class="small text-danger">Row @error.RowNumber: @error.ErrorMessage</li>
                        }
                    </ul>
                </details>
            }
            <a href="/transactions" class="d-block mt-2 small fw-semibold">View imported transactions →</a>
        </div>
    }

    <!-- Excel Format Guide — ESP-4b: visible above the fold -->
    <div class="card border-0 bg-light p-3 rounded-3" data-testid="excel-format-guide">
        <h2 class="h6 fw-semibold mb-2">📋 Required Excel Format (ING Bank)</h2>
        <ul class="mb-2 small ps-3">
            <li>Sheet name: <strong>Movimientos</strong></li>
            <li>Row 4 must contain this exact header:</li>
        </ul>
        <code class="small d-block bg-white border rounded p-2 mb-2" style="overflow-x: auto; white-space: nowrap;">
            F. VALOR | CATEGORÍA | SUBCATEGORÍA | DESCRIPCIÓN | COMENTARIO | IMPORTE (€) | SALDO (€)
        </code>
        <p class="small text-muted mb-0">Transaction data starts at row 5. Only <strong>.xls</strong> and <strong>.xlsx</strong> files are accepted.</p>
    </div>

    <div class="card border-0 shadow-sm p-4">
        <form method="post" enctype="multipart/form-data" class="d-flex flex-column gap-4"
              x-data="{ fileName: '', uploading: false }" @@submit="uploading = true">
            <div>
                <label for="excelFile" class="form-label fw-semibold">Select Excel Bank Statement</label>
                <div class="border border-2 border-dashed rounded-3 p-5 text-center"
                     style="cursor: pointer; border-color: #ced4da !important;"
                     @@click="$refs.fileInput.click()">
                    <div class="fs-1 mb-2">📊</div>
                    <p class="mb-1 small">
                        <label for="excelFile" class="fw-semibold text-brand" style="cursor: pointer;">
                            Choose Excel file
                        </label>
                        <span class="text-muted"> or drag and drop</span>
                    </p>
                    <p class="text-muted small mb-2">Excel (.xls / .xlsx) up to 10MB</p>
                    <input x-ref="fileInput" id="excelFile" name="ExcelFile" type="file" accept=".xls,.xlsx" class="visually-hidden"
                           @@change="fileName = $event.target.files[0]?.name ?? ''" />
                    <p class="text-muted small mb-0" x-text="fileName || 'No file selected'" x-show="true"></p>
                </div>
            </div>
            <button type="submit" class="btn btn-brand w-100 rounded-3 fw-bold" :disabled="uploading">
                <span x-show="!uploading">Upload and Import</span>
                <span x-show="uploading" class="spinner-border spinner-border-sm" role="status">
                    <span class="visually-hidden">Uploading...</span>
                </span>
            </button>
        </form>
    </div>
</div>
