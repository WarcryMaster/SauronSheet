@page
@model SauronSheet.Frontend.Pages.Transactions.UploadModel
@{
    ViewData["Title"] = "Upload Bank Statement";
}

<div class="mx-auto d-flex flex-column gap-4" style="max-width: 640px;">
    <div class="d-flex align-items-center gap-3">
        <a href="/transactions" class="btn btn-link btn-sm text-muted text-decoration-none">&larr; Back</a>
        <h3 class="h3 fw-bold mb-0">Upload Bank Statement</h3>
    </div>

    @if (Model.FileErrors.Any())
    {
        <div class="alert alert-danger d-flex flex-column gap-2 rounded-3" role="alert" x-transition.opacity>
            <p class="fw-semibold mb-0">⚠️ Some files could not be processed:</p>
            <ul class="mb-0 small">
                @foreach (var error in Model.FileErrors)
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }

    @if (Model.ImportResults.Any())
    {
        var totalImported = Model.ImportResults.Sum(r => r.ImportedCount);
        var totalSkipped = Model.ImportResults.Sum(r => r.SkippedCount);
        <div class="alert alert-success rounded-3" x-transition.opacity>
            <p class="fw-semibold mb-1">
                ✅ Import Complete: @totalImported imported, @totalSkipped skipped
                across @Model.ImportResults.Count file(s)
            </p>
            @foreach (var result in Model.ImportResults)
            {
                <div class="mt-2 ps-2 border-start border-2 border-success-subtle">
                    <p class="small mb-1 fw-medium">@result.Filename — @result.ImportedCount imported, @result.SkippedCount skipped</p>
                    @if (result.Errors.Any())
                    {
                        <details>
                            <summary class="small">Errors (@result.Errors.Count)</summary>
                            <ul class="mt-1 mb-0">
                                @foreach (var error in result.Errors)
                                {
                                    <li class="small text-danger">Row @error.RowNumber: @error.ErrorMessage</li>
                                }
                            </ul>
                        </details>
                    }
                </div>
            }
            <a href="/transactions" class="d-block mt-2 small fw-semibold">View imported transactions →</a>
        </div>
    }

    <!-- Excel Format Guide — ESP-4b: visible above the fold -->
    <div class="card border-0 bg-light p-3 rounded-3" data-testid="excel-format-guide">
        <h2 class="h6 fw-semibold mb-2">📋 Required Excel Format (ING Bank)</h2>
        <ul class="mb-2 small ps-3">
            <li>Sheet name: <strong>Movimientos</strong></li>
            <li>Row 4 must contain this exact header:</li>
        </ul>
        <code class="small d-block bg-white border rounded p-2 mb-2" style="overflow-x: auto; white-space: nowrap;">
            F. VALOR | CATEGORÍA | SUBCATEGORÍA | DESCRIPCIÓN | COMENTARIO | IMPORTE (€) | SALDO (€)
        </code>
        <p class="small text-muted mb-0">Transaction data starts at row 5. Only <strong>.xls</strong> and <strong>.xlsx</strong> files are accepted.</p>
    </div>

    <div class="card border-0 shadow-sm p-4">
        <form method="post" enctype="multipart/form-data" class="d-flex flex-column gap-4"
              x-ref="uploadForm"
              x-data="{
                  files: [],
                  dragging: false,
                  uploading: false,
                  progressVisible: false,
                  progressUploadId: null,
                  errorMessage: null,
                  stopPollingHandler: null,

                  // Read a File into a plain object (name, size, type, lastModified, buffer).
                  // This sidesteps Alpine's deep proxy which would break the native File object
                  // and prevent FormData.append() from recognising it as a Blob.
                  readFile(rawFile) {
                      return new Promise(resolve => {
                          const reader = new FileReader();
                          reader.onload = e => resolve({
                              name: rawFile.name,
                              size: rawFile.size,
                              type: rawFile.type,
                              lastModified: rawFile.lastModified,
                              buffer: e.target.result
                          });
                          reader.readAsArrayBuffer(rawFile);
                      });
                  },

                  async handleFileSelect(event) {
                      const selectedFiles = Array.from(event.target.files);
                      event.target.value = '';
                      await this.addFiles(selectedFiles);
                  },

                  async handleDrop(event) {
                      await this.addFiles(event.dataTransfer.files);
                      this.dragging = false;
                  },

                  async addFiles(newFiles) {
                      const fileInfos = await Promise.all(
                          Array.from(newFiles).map(f => this.readFile(f))
                      );
                      for (const fi of fileInfos) {
                          if (this.files.some(e => e.name === fi.name && e.size === fi.size)) continue;
                          this.files.push(fi);
                      }
                      this.syncInput();
                  },

                  removeFile(idx) {
                      this.files.splice(idx, 1);
                      this.syncInput();
                  },

                  syncInput() {
                      // NOTE: input[type=file].files is READONLY in Chrome.
                      // This call is kept as best-effort for older browsers;
                      // FormData is built manually from this.files in handleUpload.
                  },

                  formatSize(bytes) {
                      if (bytes < 1024) return bytes + ' B';
                      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
                      return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
                  },

                  async handleUpload() {
                      if (this.files.length === 0) return;

                      this.uploading = true;
                      this.progressVisible = true;
                      this.errorMessage = null;

                      // Build FormData from the stored buffers + antiforgery token.
                      // Recreate native File objects from plain buffers so FormData.append()
                      // recognises them as Blobs regardless of Alpine's proxy.
                      const formData = new FormData();
                      const tokenInput = this.$refs.uploadForm.querySelector('input[name=__RequestVerificationToken]');
                      if (tokenInput) {
                          formData.append('__RequestVerificationToken', tokenInput.value);
                      }
                      this.files.forEach(f => {
                          const rawFile = new File([f.buffer], f.name, { type: f.type, lastModified: f.lastModified });
                          formData.append('ExcelFiles', rawFile);
                      });

                      try {
                          const response = await fetch('/Transactions/Upload?handler=Upload', {
                              method: 'POST',
                              body: formData
                          });

                          // Guard: ensure the server returned JSON, not HTML
                          const contentType = response.headers.get('content-type') || '';
                          if (!contentType.includes('application/json')) {
                              const text = await response.text();
                              throw new Error('Server returned ' + response.status + ' ' + contentType + ': ' + text.substring(0, 200));
                          }

                          const result = await response.json();
                          if (result.success) {
                              this.progressUploadId = result.uploadId;
                              const progressEl = document.getElementById('upload-progress');
                              const url = '/Transactions/Upload?handler=Progress&id=' + result.uploadId;

                              // Register stopPolling listener BEFORE first HTMX request
                              if (this.stopPollingHandler) {
                                  document.body.removeEventListener('stopPolling', this.stopPollingHandler);
                              }
                              this.stopPollingHandler = () => {
                                  progressEl.removeAttribute('hx-trigger');
                                  htmx.process(progressEl);
                                  this.uploading = false;
                              };
                              document.body.addEventListener('stopPolling', this.stopPollingHandler);

                              // Load initial progress snippet
                              await htmx.ajax('GET', url, { target: '#upload-progress', swap: 'innerHTML' });

                              // Start polling only if processing is still ongoing
                              if (this.uploading) {
                                  progressEl.setAttribute('hx-get', url);
                                  progressEl.setAttribute('hx-trigger', 'every 1s');
                                  htmx.process(progressEl);
                              }
                          } else {
                              this.uploading = false;
                              this.progressVisible = false;
                              this.errorMessage = result.error || 'Upload failed';
                          }
                      } catch (error) {
                          this.uploading = false;
                          this.progressVisible = false;
                          this.errorMessage = 'Network error. Please try again.';
                          if (typeof Sentry !== 'undefined') {
                              Sentry.captureException(error);
                          }
                      }
                  }
              }"
              @@submit.prevent="handleUpload()">

            <div>
                <label class="form-label fw-semibold">Select Excel Bank Statement(s)</label>
                <div class="border border-2 rounded-3 p-5 text-center"
                     :class="dragging ? 'border-brand bg-brand-subtle' : ''"
                     :style="'cursor: pointer; border-style: dashed; border-color: ' + (dragging ? 'var(--mdb-brand)' : '#ced4da') + ' !important;'"
                     @@click="$refs.fileInput.click()"
                     @@dragenter.prevent="dragging = true"
                     @@dragover.prevent="dragging = true"
                     @@dragleave.prevent="dragging = false"
                     @@drop.prevent="handleDrop($event)">
                    <div class="fs-1 mb-2">📊</div>
                    <p class="mb-1 small">
                        <span class="fw-semibold text-brand" style="cursor: pointer;">
                            Choose Excel files
                        </span>
                        <span class="text-muted"> or drag and drop</span>
                    </p>
                    <p class="text-muted small mb-2">Excel (.xls / .xlsx) up to 10MB each — multiple files allowed</p>
                    <input x-ref="fileInput" name="ExcelFiles" type="file" accept=".xls,.xlsx" multiple class="visually-hidden"
                           @@change="handleFileSelect($event)" />
                </div>
            </div>

            <!-- File list -->
            <div x-show="files.length > 0" x-transition x-cloak class="upload-flex-col">
                <p class="small fw-semibold mb-0 text-muted">
                    <span x-text="files.length"></span> file(s) selected:
                </p>
                <template x-for="(file, idx) in files" :key="idx">
                    <div class="d-flex align-items-center gap-2 bg-light rounded-2 px-3 py-2">
                        <span class="small text-truncate flex-grow-1" x-text="file.name"></span>
                        <span class="small text-muted flex-shrink-0" x-text="formatSize(file.size)"></span>
                        <button type="button" class="btn btn-sm btn-link text-danger p-0 flex-shrink-0"
                                @@click="removeFile(idx)" title="Remove file">
                            ✕
                        </button>
                    </div>
                </template>
            </div>

            <!-- Async upload error message -->
            <div x-show="errorMessage" x-transition x-cloak class="alert alert-danger rounded-3" role="alert">
                <p class="fw-semibold mb-1">⚠️ Upload failed</p>
                <p class="small mb-0" x-text="errorMessage"></p>
            </div>

            <!-- Real-time progress container (HTMX attributes set dynamically in handleUpload) -->
            <div id="upload-progress" x-show="progressVisible" x-transition x-cloak></div>

            <button type="submit" class="btn btn-brand w-100 rounded-3 fw-bold"
                    :disabled="uploading || files.length === 0">
                <span x-show="!uploading">Upload and Import</span>
                <span x-show="uploading" class="spinner-border spinner-border-sm" role="status">
                    <span class="visually-hidden">Uploading...</span>
                </span>
            </button>
        </form>
    </div>
</div>
