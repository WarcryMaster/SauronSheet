@page
@model SauronSheet.Frontend.Pages.Transactions.UploadModel
@{
    ViewData["Title"] = "Upload PDF";
}

<div class="max-w-2xl mx-auto space-y-6">
    <div class="flex items-center gap-3">
        <a href="/Transactions" class="text-sm text-gray-400 hover:text-gray-600">&larr; Back</a>
        <h1 class="text-2xl font-bold text-gray-900">Upload Bank Statement</h1>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="rounded-xl bg-red-50 border border-red-200 p-4 flex items-start gap-3">
            <svg class="h-5 w-5 text-red-500 flex-shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-10.707a1 1 0 00-1.414-1.414L10 8.586 7.707 6.293a1 1 0 00-1.414 1.414L8.586 10l-2.293 2.293a1 1 0 001.414 1.414L10 11.414l2.293 2.293a1 1 0 001.414-1.414L11.414 10l2.293-2.293z" clip-rule="evenodd"/></svg>
            <p class="text-sm text-red-700">@Model.ErrorMessage</p>
        </div>
    }

    @if (Model.ImportResult != null)
    {
        <div class="rounded-xl bg-brand-50 border border-brand-200 p-5">
            <p class="text-base font-semibold text-brand-800">
                ✅ Import Complete: @Model.ImportResult.ImportedCount imported, @Model.ImportResult.SkippedCount skipped
            </p>
            @if (Model.ImportResult.Errors.Any())
            {
                <details class="mt-4">
                    <summary class="cursor-pointer text-sm text-brand-700">Show errors (@Model.ImportResult.Errors.Count)</summary>
                    <ul class="mt-2 space-y-1">
                        @foreach (var error in Model.ImportResult.Errors)
                        {
                            <li class="text-sm text-red-600">Row @error.RowNumber: @error.ErrorMessage</li>
                        }
                    </ul>
                </details>
            }
            <a href="/Transactions" class="mt-3 inline-block text-sm font-medium text-brand-700 hover:text-brand-800">
                View imported transactions →
            </a>
        </div>
    }

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8">
        <form method="post" enctype="multipart/form-data" class="space-y-6">
            <div>
                <label for="pdfFile" class="block text-sm font-medium text-gray-700 mb-1">Select PDF Bank Statement</label>
                <div class="mt-1 flex justify-center px-6 pt-8 pb-8 border-2 border-gray-200 border-dashed rounded-xl hover:border-brand-400 transition-colors duration-200">
                    <div class="text-center">
                        <div class="text-4xl mb-3">📄</div>
                        <div class="flex text-sm text-gray-600 justify-center">
                            <label for="pdfFile" class="cursor-pointer font-medium text-brand-600 hover:text-brand-700">
                                Choose PDF file
                            </label>
                            <p class="pl-1">or drag and drop</p>
                        </div>
                        <p class="text-xs text-gray-400 mt-1">PDF up to 10MB</p>
                        <input id="pdfFile" name="PdfFile" type="file" accept=".pdf" class="sr-only" />
                        <p class="text-xs text-gray-500 mt-2" id="fileNameDisplay"></p>
                    </div>
                </div>
            </div>
            <button type="submit" class="w-full flex justify-center py-3 px-4 rounded-lg text-sm font-semibold text-white bg-brand-600 hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 transition duration-200 shadow-sm">
                Upload and Import
            </button>
        </form>
    </div>
</div>
<script>
    document.getElementById('pdfFile')?.addEventListener('change', function() {
        document.getElementById('fileNameDisplay').textContent = this.files[0]?.name ?? '';
    });
</script>


