@page
@model SauronSheet.Frontend.Pages.Transactions.UploadModel
@{
    ViewData["Title"] = "Upload PDF";
}

<div class="mx-auto d-flex flex-column gap-4" style="max-width: 640px;">
    <div class="d-flex align-items-center gap-3">
        <a href="/transactions" class="btn btn-link btn-sm text-muted text-decoration-none">&larr; Back</a>
        <h1 class="h3 fw-bold mb-0">Upload Bank Statement</h1>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger d-flex align-items-start gap-2 rounded-3" role="alert">
            <span class="fw-bold">!</span>
            <p class="mb-0 small">@Model.ErrorMessage</p>
        </div>
    }

    @if (Model.ImportResult != null)
    {
        <div class="alert alert-success rounded-3">
            <p class="fw-semibold mb-1">
                ✅ Import Complete: @Model.ImportResult.ImportedCount imported, @Model.ImportResult.SkippedCount skipped
            </p>
            @if (Model.ImportResult.Errors.Any())
            {
                <details class="mt-2">
                    <summary class="small">Show errors (@Model.ImportResult.Errors.Count)</summary>
                    <ul class="mt-2 mb-0">
                        @foreach (var error in Model.ImportResult.Errors)
                        {
                            <li class="small text-danger">Row @error.RowNumber: @error.ErrorMessage</li>
                        }
                    </ul>
                </details>
            }
            <a href="/transactions" class="d-block mt-2 small fw-semibold">View imported transactions →</a>
        </div>
    }

    <div class="card border-0 shadow-sm p-4">
        <form method="post" enctype="multipart/form-data" class="d-flex flex-column gap-4">
            <div>
                <label for="pdfFile" class="form-label fw-semibold">Select PDF Bank Statement</label>
                <div class="border border-2 border-dashed rounded-3 p-5 text-center" id="dropZone"
                     style="cursor: pointer; border-color: #ced4da !important;">
                    <div class="fs-1 mb-2">📄</div>
                    <p class="mb-1 small">
                        <label for="pdfFile" class="fw-semibold text-brand" style="cursor: pointer;">
                            Choose PDF file
                        </label>
                        <span class="text-muted"> or drag and drop</span>
                    </p>
                    <p class="text-muted small mb-2">PDF up to 10MB</p>
                    <input id="pdfFile" name="PdfFile" type="file" accept=".pdf" class="visually-hidden" />
                    <p class="text-muted small mb-0" id="fileNameDisplay"></p>
                </div>
            </div>
            <button type="submit" class="btn btn-brand w-100 rounded-3 fw-bold">
                Upload and Import
            </button>
        </form>
    </div>
</div>

<script>
    document.getElementById('pdfFile')?.addEventListener('change', function() {
        document.getElementById('fileNameDisplay').textContent = this.files[0]?.name ?? '';
    });
    document.getElementById('dropZone')?.addEventListener('click', function(e) {
        if (e.target.tagName !== 'LABEL') document.getElementById('pdfFile').click();
    });
</script>
