@page
@model SauronSheet.Frontend.Pages.Transactions.IndexModel
@using SauronSheet.Frontend.Helpers
@using Microsoft.Extensions.Localization
@using SauronSheet.Application.Resources
@inject IStringLocalizer<SharedResources> Localizer
@{
    ViewData["Title"] = Localizer["Transactions.Index.Title"];
}

<div class="d-flex flex-column gap-4"
     x-data='{
         selectedIds: [],
         maxSelections: @Math.Min(Model.Transactions.TotalCount, 1000),
         countdown: 2,
         countdownInterval: null,
         canConfirm: false,
         transactionI18n: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
             sourceSummaryNone = Localizer["Transactions.Index.SourceSummaryNone"].Value,
             sourceSummary = Localizer["Transactions.Index.SourceSummary"].Value,
             sourceRemove = Localizer["Transactions.Index.SourceRemove"].Value,
             sourceSearchPlaceholder = Localizer["Transactions.Index.SourceSearchPlaceholder"].Value,
             selectedCount = Localizer["Transactions.Index.SelectedCount"].Value,
             selectionLimitWarning = Localizer["Transactions.Index.SelectionLimitWarning"].Value,
             paginationShowing = Localizer["Transactions.Index.PaginationShowing"].Value,
             bulkDeleteConfirm = Localizer["Transactions.Modal.BulkDeleteConfirm"].Value,
             countdownTemplate = Localizer["Transactions.Modal.Countdown"].Value,
             delete = Localizer["Common.Delete"].Value,
             cancel = Localizer["Common.Cancel"].Value
         })),

         get selectionCount() { return this.selectedIds.length; },
         get canDelete() { return this.selectionCount > 0; },
         get pluralS() { return this.selectionCount === 1 ? "" : "s"; },
         get countdownWidth() { return (this.countdown / 2) * 100; },

         toggleAll(checked) {
             const checkboxes = document.querySelectorAll(".transaction-checkbox");
             if (checked) {
                 this.selectedIds = Array.from(checkboxes).slice(0, this.maxSelections).map(cb => cb.value);
             } else {
                 this.selectedIds = [];
             }
             this.$nextTick(() => {
                 checkboxes.forEach(cb => { cb.checked = this.selectedIds.includes(cb.value); });
             });
         },

         toggleOne(id, checked, el) {
             if (checked) {
                 if (this.selectedIds.length < this.maxSelections) {
                     if (!this.selectedIds.includes(id)) this.selectedIds = [...this.selectedIds, id];
                 } else {
                     el.checked = false;
                     return;
                 }
             } else {
                 this.selectedIds = this.selectedIds.filter(sid => sid !== id);
             }
         },

         isSelected(id) { return this.selectedIds.includes(id); },

         openDeleteModal() {
             this.countdown = 2;
             this.canConfirm = false;
             try {
                 new mdb.Modal(document.getElementById("confirmDeleteModal")).show();
             } catch(e) { return; }
             this.countdownInterval = setInterval(() => {
                 this.countdown--;
                 if (this.countdown <= 0) {
                     clearInterval(this.countdownInterval);
                     this.canConfirm = true;
                 }
             }, 1000);
         },

         cancelDelete() {
             if (this.countdownInterval) clearInterval(this.countdownInterval);
             const instance = mdb.Modal.getInstance(document.getElementById("confirmDeleteModal"));
             if (instance) instance.hide();
         },

         submitBulkDelete() {
             document.getElementById("selectedIds").value = JSON.stringify(this.selectedIds);
             document.getElementById("bulkDeleteForm").submit();
         },

         deleteFormId: null,

         openSingleDeleteModal(formId) {
             this.deleteFormId = formId;
             new mdb.Modal(document.getElementById("singleDeleteConfirmModal")).show();
         },

         confirmSingleDelete() {
             if (this.deleteFormId) {
                 mdb.Modal.getInstance(document.getElementById("singleDeleteConfirmModal"))?.hide();
                 document.getElementById(this.deleteFormId).submit();
             }
         }
     }'>
    <div class="d-flex justify-content-between align-items-center">
        <h3 class="h3 fw-bold mb-0" data-testid="transactions-heading">@Localizer["Transactions.Index.Title"]</h3>
        <div class="d-flex gap-2">
            <a href="/transactions/upload" class="btn btn-brand btn-sm" data-testid="upload-statement-link">📊 @Localizer["Transactions.Index.UploadStatement"]</a>
            <a href="/transactions/add" class="btn btn-outline-secondary btn-sm" data-testid="add-transaction-link">➕ @Localizer["Transactions.Index.AddTransaction"]</a>
        </div>
    </div>

    <!-- Filters -->
    <form method="get" class="card border-0 shadow-sm p-4">
        <div class="row g-3 align-items-end">
            <div class="col-12 col-md-3">
                <label for="StartDate" class="form-label small fw-semibold text-muted text-uppercase mb-1">@Localizer["Common.From"]</label>
                <input x-data x-init="flatpickr($el, { dateFormat: 'Y-m-d', altInput: true, altFormat: 'd/m/Y', allowInput: true, maxDate: 'today' })"
                       type="text" name="StartDate" id="StartDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")"
                       class="form-control form-control-sm" placeholder="@Localizer["Transactions.Add.Placeholder.Date"]" autocomplete="off" />
            </div>
            <div class="col-12 col-md-3">
                <label for="EndDate" class="form-label small fw-semibold text-muted text-uppercase mb-1">@Localizer["Common.To"]</label>
                <input x-data x-init="flatpickr($el, { dateFormat: 'Y-m-d', altInput: true, altFormat: 'd/m/Y', allowInput: true, maxDate: 'today' })"
                       type="text" name="EndDate" id="EndDate" value="@Model.EndDate?.ToString("yyyy-MM-dd")"
                       class="form-control form-control-sm" placeholder="@Localizer["Transactions.Add.Placeholder.Date"]" autocomplete="off" />
            </div>
            <div class="col-12 col-md-auto ms-md-auto d-flex gap-2">
                <button type="submit" class="btn btn-brand btn-sm" data-testid="apply-filters-btn">@Localizer["Common.Apply"]</button>
                <a href="/transactions" class="btn btn-link btn-sm text-muted text-decoration-none" data-testid="clear-filters-link">@Localizer["Transactions.Index.ClearFilters"]</a>
            </div>
            <div class="col-12">
                <div class="source-filter-panel"
                     x-data='{
                         selectedSources: @Json.Serialize(Model.SelectedSources),
                         sourceInput: "",
                         availableSources: @Json.Serialize(Model.AvailableSources),
                         i18n: transactionI18n,
                         addSource() {
                             const s = this.sourceInput.trim();
                             if (!s || !this.availableSources.includes(s) || this.selectedSources.includes(s)) {
                                 this.sourceInput = "";
                                 return;
                             }
                             this.selectedSources = [...this.selectedSources, s];
                             this.sourceInput = "";
                         },
                         removeSource(source) {
                             this.selectedSources = this.selectedSources.filter(s => s !== source);
                         },
                         get summaryText() {
                             const count = this.selectedSources.length;
                             return count === 0
                                 ? this.i18n.sourceSummaryNone
                                 : this.i18n.sourceSummary.replace("{0}", count);
                         }
                     }'>
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-2">
                        <div>
                            <label class="form-label small fw-semibold text-muted text-uppercase mb-1 d-block">@Localizer["Transactions.Index.Source"]</label>
                            <span x-text="summaryText"
                                  :class="selectedSources.length === 0 ? 'small text-muted' : 'badge rounded-pill bg-brand-light border border-brand text-brand px-3 py-2'"
                                  x-cloak>@(Model.SelectedSources.Any() ? string.Format(Localizer["Transactions.Index.SourceSummary"], Model.SelectedSources.Count) : Localizer["Transactions.Index.SourceSummaryNone"])</span>
                        </div>
                    </div>
                    <div class="source-picker">
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            <template x-for="source in selectedSources" :key="source">
                                <div class="d-flex gap-2 align-items-center">
                                    <span class="badge rounded-pill bg-brand-light border border-brand text-brand px-3 py-2 source-chip-selected">
                                        <span x-text="source"></span>
                                        <button type="button"
                                                class="source-chip-remove"
                                                @@click="removeSource(source)"
                                                :aria-label="i18n.sourceRemove.replace('{0}', source)">
                                            ×
                                        </button>
                                    </span>
                                    <input type="hidden" name="SelectedSources" :value="source" />
                                </div>
                            </template>
                        </div>

                        <div class="position-relative">
                            <input type="text"
                                   x-model="sourceInput"
                                   list="availableSourcesList"
                                   class="form-control form-control-sm"
                                   :placeholder="i18n.sourceSearchPlaceholder"
                                   autocomplete="off"
                                   @@change="addSource()"
                                   @@keydown.enter.prevent="addSource()" />
                            <datalist id="availableSourcesList">
                                @foreach (string source in Model.AvailableSources)
                                {
                                    <option value="@source"></option>
                                }
                            </datalist>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>

    @if (Model.Transactions.Items.Count == 0)
    {
        <div class="card border-0 shadow-sm p-5 text-center" role="status" aria-live="polite">
            <div class="fs-1 mb-3">💳</div>
            <p class="h5 fw-semibold mb-2">@Localizer["Transactions.Index.EmptyTitle"]</p>
            <p class="text-muted mb-4">@Localizer["Transactions.Index.EmptyDescription"]</p>
            <div class="d-flex justify-content-center gap-3">
                <a href="/transactions/upload" class="btn btn-brand" data-testid="empty-import-link">📊 @Localizer["Transactions.Index.ImportStatement"]</a>
                <a href="/transactions/add" class="btn btn-outline-secondary" data-testid="empty-add-link">➕ @Localizer["Transactions.Index.AddTransaction"]</a>
            </div>
        </div>
    }
    else
    {
        <!-- Bulk Delete Toolbar -->
        <div class="d-flex justify-content-between align-items-center">
            <div class="small text-muted">
                <span x-text="transactionI18n.selectedCount.replace('{0}', selectionCount).replace('{1}', maxSelections)">@string.Format(Localizer["Transactions.Index.SelectedCount"], 0, Math.Min(Model.Transactions.TotalCount, 1000))</span>
                @if (Model.Transactions.TotalCount > 1000)
                {
                    <span class="badge bg-warning text-dark ms-2">⚠️ @Localizer["Transactions.Index.SelectionLimitWarning"]</span>
                }
            </div>
            <button type="button" id="deleteSelectedBtn" class="btn btn-danger btn-sm"
                    :disabled="!canDelete" @@click="openDeleteModal()" data-testid="delete-selected-btn">
                🗑️ @Localizer["Transactions.Index.DeleteSelected"]
            </button>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="transactionsTable">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 40px;">
                                <div class="form-check m-0">
                                    <input class="form-check-input" type="checkbox" id="selectAllCheckbox" @@change="toggleAll($el.checked)" data-testid="select-all-checkbox" />
                                    <label class="form-check-label" for="selectAllCheckbox" title="@Localizer["Transactions.Index.SelectAll"]"></label>
                                </div>
                            </th>
                            <th class="text-uppercase small fw-semibold text-muted">@Localizer["Common.Date"]</th>
                            <th class="text-uppercase small fw-semibold text-muted">@Localizer["Common.Description"]</th>
                            <th class="text-uppercase small fw-semibold text-muted">@Localizer["Common.Amount"]</th>
                            <th class="text-uppercase small fw-semibold text-muted">@Localizer["Common.Category"]</th>
                            <th class="text-uppercase small fw-semibold text-muted">@Localizer["Common.Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var transaction in Model.Transactions.Items)
                        {
                            <tr>
                                <td style="width: 40px;">
                                    <div class="form-check m-0">
                                        <input class="form-check-input transaction-checkbox" type="checkbox"
                                               value="@transaction.Id" id="cb_@transaction.Id"
                                               @@change="toggleOne('@transaction.Id', $el.checked, $el)"
                                               :checked="isSelected('@transaction.Id')" />
                                        <label class="form-check-label" for="cb_@transaction.Id"></label>
                                    </div>
                                </td>
                                <td class="small text-muted">@transaction.Date.ToString("dd/MM/yyyy")</td>
                                <td class="small">
                                    @transaction.Description
                                    @if (!string.IsNullOrEmpty(transaction.ImportedFrom))
                                    {
                                        <span class="text-muted small">(from @transaction.ImportedFrom)</span>
                                    }
                                </td>
                                <td class="small fw-semibold @(transaction.Amount >= 0 ? "text-success" : "text-danger")">
                                    @transaction.Amount.ToString("F2") @transaction.Currency
                                </td>
                                <td>
                                    <partial name="Shared/_CategoryBadge" model="TransactionCategoryDisplayHelper.BuildBadge(transaction)" />
                                </td>
                                <td>
                                    <div class="d-flex gap-1 align-items-center">
                                        <a href="/transactions/edit/@transaction.Id"
                                           class="btn btn-sm btn-outline-primary rounded-2"
                                           title="@Localizer["Transactions.Index.EditTransaction"]"
                                           data-testid="edit-transaction-btn">
                                            <i class="fas fa-pencil-alt"></i>
                                        </a>
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@transaction.Id" class="d-inline m-0" id="deleteForm_@transaction.Id">
                                            <button type="button" class="btn btn-link btn-sm text-danger p-0"
                                                    @@click="openSingleDeleteModal('deleteForm_@transaction.Id')"
                                                    data-testid="delete-transaction-btn">
                                                🗑️ @Localizer["Common.Delete"]
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (Model.Transactions.TotalPages > 1)
            {
                <div class="card-footer bg-transparent d-flex align-items-center justify-content-between gap-2 flex-wrap">
                    <p class="small text-muted mb-0">
                        @Localizer["Transactions.Index.PaginationShowing", (Model.Transactions.PageNumber - 1) * Model.Transactions.PageSize + 1, Math.Min(Model.Transactions.PageNumber * Model.Transactions.PageSize, Model.Transactions.TotalCount), Model.Transactions.TotalCount]
                    </p>
                    <nav aria-label="Pagination">
                        <ul class="pagination pagination-sm mb-0">
                            @for (int i = 1; i <= Model.Transactions.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.Transactions.PageNumber ? "active" : "")">
                                    <a class="page-link" href="?PageNumber=@i">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            }
        </div>
    }

    <!-- Include Confirmation Modal Partial for bulk delete (inside x-data scope) -->
    @await Html.PartialAsync("~/Shared/Modals/_ConfirmDeleteModal.cshtml")

    <!-- Single Delete Confirmation Modal -->
    <div class="modal fade" id="singleDeleteConfirmModal" tabindex="-1" aria-labelledby="singleDeleteConfirmLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-danger fs-6" id="singleDeleteConfirmLabel">
                        ⚠️ @Localizer["Transactions.Modal.SingleDeleteTitle"]
                    </h5>
                    <button type="button" class="btn-close" data-mdb-dismiss="modal" aria-label="@Localizer["Common.Close"]"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2">@Localizer["Transactions.Modal.SingleDeleteConfirm"]</p>
                    <p class="text-muted small mb-0">@Localizer["Transactions.Modal.SingleDeleteWarning"]</p>
                </div>
                <div class="modal-footer border-top gap-2">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-mdb-dismiss="modal">
                        ← @Localizer["Common.Cancel"]
                    </button>
                    <button type="button" class="btn btn-danger btn-sm" @@click="confirmSingleDelete()">
                        🗑️ @Localizer["Common.Delete"]
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
