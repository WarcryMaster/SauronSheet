@page
@model SauronSheet.Frontend.Pages.Transactions.IndexModel
@using SauronSheet.Frontend.Helpers
@{
    ViewData["Title"] = "Transactions";
}

<div class="d-flex flex-column gap-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1 class="h3 fw-bold mb-0">Transactions</h1>
        <div class="d-flex gap-2">
            <a href="/transactions/upload" class="btn btn-brand btn-sm">📊 Upload Statement</a>
            <a href="/transactions/add" class="btn btn-outline-secondary btn-sm">➕ Add Transaction</a>
        </div>
    </div>

    <!-- Filters -->
    <form method="get" class="card border-0 shadow-sm p-4">
        <div class="row g-3 align-items-end">
            <div class="col-12 col-md-3">
                <label for="StartDate" class="form-label small fw-semibold text-muted text-uppercase mb-1">From</label>
                <input type="date" name="StartDate" id="StartDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")"
                       class="form-control form-control-sm" />
            </div>
            <div class="col-12 col-md-3">
                <label for="EndDate" class="form-label small fw-semibold text-muted text-uppercase mb-1">To</label>
                <input type="date" name="EndDate" id="EndDate" value="@Model.EndDate?.ToString("yyyy-MM-dd")"
                       class="form-control form-control-sm" />
            </div>
            <div class="col-12 col-md-auto ms-md-auto d-flex gap-2">
                <button type="submit" class="btn btn-brand btn-sm">Apply</button>
                <a href="/transactions" class="btn btn-link btn-sm text-muted text-decoration-none">Clear</a>
            </div>
            <div class="col-12">
                <div class="source-filter-panel">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-2">
                        <div>
                            <label class="form-label small fw-semibold text-muted text-uppercase mb-1 d-block">Source</label>
                            <span id="selectedSourcesSummary"
                                  class="@(Model.SelectedSources.Any() ? "badge rounded-pill bg-brand-light border border-brand text-brand px-3 py-2" : "small text-muted")"
                                  data-empty-text="Search and add one or more sources. If none are selected, all sources are shown.">
                                @(Model.SelectedSources.Any()
                                    ? $"{Model.SelectedSources.Count} selected source(s)"
                                    : "Search and add one or more sources. If none are selected, all sources are shown.")
                            </span>
                        </div>
                    </div>
                    <div class="source-picker">
                        <div id="selectedSourcesContainer" class="d-flex flex-wrap gap-2 mb-3">
                            @foreach (string source in Model.SelectedSources)
                            {
                                <span class="badge rounded-pill bg-brand-light border border-brand text-brand px-3 py-2 source-chip-selected">
                                    <span>@source</span>
                                    <button type="button"
                                            class="source-chip-remove"
                                            data-source="@source"
                                            aria-label="Remove source @source">
                                        ×
                                    </button>
                                </span>
                                <input type="hidden" name="SelectedSources" value="@source" data-selected-source="@source" />
                            }
                        </div>

                        <div class="position-relative">
                            <input type="text"
                                   id="SourceAutocomplete"
                                   list="availableSourcesList"
                                   class="form-control form-control-sm"
                                   placeholder="Search source and select it..."
                                   autocomplete="off" />
                            <datalist id="availableSourcesList">
                                @foreach (string source in Model.AvailableSources)
                                {
                                    <option value="@source"></option>
                                }
                            </datalist>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>

    @if (Model.Transactions.Items.Count == 0)
    {
        <div class="card border-0 shadow-sm p-5 text-center" role="status" aria-live="polite">
            <div class="fs-1 mb-3">💳</div>
            <p class="h5 fw-semibold mb-2">No transactions yet</p>
            <p class="text-muted mb-4">Import a bank statement or add a transaction to get started.</p>
            <div class="d-flex justify-content-center gap-3">
                <a href="/transactions/upload" class="btn btn-brand">📊 Import Statement</a>
                <a href="/transactions/add" class="btn btn-outline-secondary">➕ Add Transaction</a>
            </div>
        </div>
    }
    else
    {
        <!-- Bulk Delete Toolbar -->
        <div class="d-flex justify-content-between align-items-center">
            <div class="small text-muted">
                <span id="selectionCounter">0 / @Math.Min(Model.Transactions.TotalCount, 1000) selected</span>
                @if (Model.Transactions.TotalCount > 1000)
                {
                    <span class="badge bg-warning text-dark ms-2">⚠️ Limited to 1000 per transaction</span>
                }
            </div>
            <button type="button" id="deleteSelectedBtn" class="btn btn-danger btn-sm" disabled
                    data-mdb-toggle="modal" data-mdb-target="#confirmDeleteModal">
                🗑️ Delete Selected
            </button>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="transactionsTable">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 40px;">
                                <div class="form-check m-0">
                                    <input class="form-check-input" type="checkbox" id="selectAllCheckbox" />
                                    <label class="form-check-label" for="selectAllCheckbox" title="Select all"></label>
                                </div>
                            </th>
                            <th class="text-uppercase small fw-semibold text-muted">Date</th>
                            <th class="text-uppercase small fw-semibold text-muted">Description</th>
                            <th class="text-uppercase small fw-semibold text-muted">Amount</th>
                            <th class="text-uppercase small fw-semibold text-muted">Category</th>
                            <th class="text-uppercase small fw-semibold text-muted">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var transaction in Model.Transactions.Items)
                        {
                            <tr>
                                <td style="width: 40px;">
                                    <div class="form-check m-0">
                                        <input class="form-check-input transaction-checkbox" type="checkbox"
                                               value="@transaction.Id" id="cb_@transaction.Id" />
                                        <label class="form-check-label" for="cb_@transaction.Id"></label>
                                    </div>
                                </td>
                                <td class="small text-muted">@transaction.Date.ToString("dd/MM/yyyy")</td>
                                <td class="small">
                                    @transaction.Description
                                    @if (!string.IsNullOrEmpty(transaction.ImportedFrom))
                                    {
                                        <span class="text-muted small">(from @transaction.ImportedFrom)</span>
                                    }
                                </td>
                                <td class="small fw-semibold @(transaction.Amount >= 0 ? "text-success" : "text-danger")">
                                    @transaction.Amount.ToString("F2") @transaction.Currency
                                </td>
                                <td>
                                    <partial name="Shared/_CategoryBadge" model="TransactionCategoryDisplayHelper.BuildBadge(transaction)" />
                                </td>
                                <td>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@transaction.Id" class="d-inline">
                                        <button type="submit" class="btn btn-link btn-sm text-danger p-0"
                                                onclick="return confirm('Are you sure you want to delete this transaction?')">
                                            🗑️ Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (Model.Transactions.TotalPages > 1)
            {
                <div class="card-footer bg-transparent d-flex align-items-center justify-content-between gap-2 flex-wrap">
                    <p class="small text-muted mb-0">
                        Showing <strong>@((Model.Transactions.PageNumber - 1) * Model.Transactions.PageSize + 1)</strong>
                        to <strong>@Math.Min(Model.Transactions.PageNumber * Model.Transactions.PageSize, Model.Transactions.TotalCount)</strong>
                        of <strong>@Model.Transactions.TotalCount</strong> results
                    </p>
                    <nav aria-label="Pagination">
                        <ul class="pagination pagination-sm mb-0">
                            @for (int i = 1; i <= Model.Transactions.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.Transactions.PageNumber ? "active" : "")">
                                    <a class="page-link" href="?PageNumber=@i">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            }
        </div>
    }
</div>

<!-- Include Confirmation Modal Partial -->
@await Html.PartialAsync("~/Shared/Modals/_ConfirmDeleteModal.cshtml")

@section Scripts {
    <script src="~/js/bulk-delete.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const sourceInput = document.getElementById('SourceAutocomplete');
            const selectedContainer = document.getElementById('selectedSourcesContainer');
            const summary = document.getElementById('selectedSourcesSummary');
            const form = sourceInput?.closest('form');

            if (!sourceInput || !selectedContainer || !form || !summary) {
                return;
            }

            const availableSources = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AvailableSources));

            function getSelectedSources() {
                return Array.from(form.querySelectorAll('input[name="SelectedSources"]'))
                    .map(input => input.value);
            }

            function updateSummary() {
                const count = getSelectedSources().length;
                if (count === 0) {
                    summary.className = 'small text-muted';
                    summary.textContent = summary.dataset.emptyText || 'All sources are shown.';
                    return;
                }

                summary.className = 'badge rounded-pill bg-brand-light border border-brand text-brand px-3 py-2';
                summary.textContent = `${count} selected source(s)`;
            }

            function addSource(source) {
                const normalized = source?.trim();
                if (!normalized) {
                    return;
                }

                const existsInAvailable = availableSources.includes(normalized);
                const alreadySelected = getSelectedSources().includes(normalized);

                if (!existsInAvailable || alreadySelected) {
                    sourceInput.value = '';
                    return;
                }

                const chip = document.createElement('span');
                chip.className = 'badge rounded-pill bg-brand-light border border-brand text-brand px-3 py-2 source-chip-selected';

                const chipText = document.createElement('span');
                chipText.textContent = normalized;

                const removeButton = document.createElement('button');
                removeButton.type = 'button';
                removeButton.className = 'source-chip-remove';
                removeButton.setAttribute('data-source', normalized);
                removeButton.setAttribute('aria-label', `Remove source ${normalized}`);
                removeButton.textContent = '×';

                chip.appendChild(chipText);
                chip.appendChild(removeButton);

                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = 'SelectedSources';
                hidden.value = normalized;
                hidden.setAttribute('data-selected-source', normalized);

                selectedContainer.appendChild(chip);
                selectedContainer.appendChild(hidden);
                sourceInput.value = '';
                updateSummary();
            }

            sourceInput.addEventListener('change', function () {
                addSource(sourceInput.value);
            });

            sourceInput.addEventListener('keydown', function (event) {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    addSource(sourceInput.value);
                }
            });

            selectedContainer.addEventListener('click', function (event) {
                const button = event.target.closest('.source-chip-remove');
                if (!button) {
                    return;
                }

                const source = button.getAttribute('data-source');
                const hiddenInput = Array.from(form.querySelectorAll('input[name="SelectedSources"]'))
                    .find(input => input.getAttribute('data-selected-source') === source);
                const chip = button.closest('.source-chip-selected');

                hiddenInput?.remove();
                chip?.remove();
                updateSummary();
            });

            updateSummary();
        });
    </script>
}
