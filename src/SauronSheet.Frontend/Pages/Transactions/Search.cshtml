@page "/transactions/search"
@model SauronSheet.Frontend.Pages.Transactions.SearchModel
@using SauronSheet.Frontend.Helpers

@{
    ViewData["Title"] = "Search Transactions";
}

<div class="d-flex flex-column gap-4">
    <h3 class="h3 fw-bold mb-0">🔍 Search Transactions</h3>

    <!-- Filter Panel -->
    <form method="get" action="/transactions/search" class="card border-0 shadow-sm p-4">
        <div class="row g-3 mb-3">
            <div class="col-12 col-sm-6 col-lg-4">
                <label for="Keyword" class="form-label small fw-semibold text-muted text-uppercase mb-1">Keyword</label>
                <input type="text" name="Keyword" id="Keyword" value="@Model.Keyword"
                       placeholder="Search descriptions..."
                       class="form-control form-control-sm" />
            </div>
            <div class="col-12 col-sm-6 col-lg-4">
                <label for="FromDate" class="form-label small fw-semibold text-muted text-uppercase mb-1">From Date</label>
                <input type="date" name="FromDate" id="FromDate" value="@Model.FromDate?.ToString("yyyy-MM-dd")"
                       class="form-control form-control-sm" />
            </div>
            <div class="col-12 col-sm-6 col-lg-4">
                <label for="ToDate" class="form-label small fw-semibold text-muted text-uppercase mb-1">To Date</label>
                <input type="date" name="ToDate" id="ToDate" value="@Model.ToDate?.ToString("yyyy-MM-dd")"
                       class="form-control form-control-sm" />
            </div>
            <div class="col-12 col-sm-6 col-lg-4">
                <label for="CategoryId" class="form-label small fw-semibold text-muted text-uppercase mb-1">Category</label>
                <select name="CategoryId" id="CategoryId" class="form-select form-select-sm">
                    <option value="">All Categories</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat.Id" selected="@(Model.CategoryId == cat.Id ? "selected" : null)">@cat.Name</option>
                    }
                </select>
            </div>
            <div class="col-12 col-sm-6 col-lg-4">
                <label for="MinAmount" class="form-label small fw-semibold text-muted text-uppercase mb-1">Min Amount</label>
                <input type="number" step="0.01" name="MinAmount" id="MinAmount" value="@Model.MinAmount"
                       placeholder="€0.00" class="form-control form-control-sm" />
            </div>
            <div class="col-12 col-sm-6 col-lg-4">
                <label for="MaxAmount" class="form-label small fw-semibold text-muted text-uppercase mb-1">Max Amount</label>
                <input type="number" step="0.01" name="MaxAmount" id="MaxAmount" value="@Model.MaxAmount"
                       placeholder="€9999.99" class="form-control form-control-sm" />
            </div>
        </div>
        <div class="d-flex align-items-center gap-3">
            <button type="submit" class="btn btn-brand btn-sm">Search</button>
            <a href="/transactions/search" class="btn btn-link btn-sm text-muted text-decoration-none">Clear all filters</a>
        </div>
    </form>

    @if (Model.Results != null)
    {
        <!-- Results Summary -->
        <p class="small text-muted">
            Showing @Model.Results.Items.Count of @Model.Results.TotalCount transactions
            @if (!string.IsNullOrEmpty(Model.Keyword) || Model.FromDate.HasValue || Model.ToDate.HasValue || Model.CategoryId.HasValue || Model.MinAmount.HasValue || Model.MaxAmount.HasValue)
            {
                <span>matching filters</span>
            }
        </p>

        @if (Model.Results.Items.Any())
        {
            <!-- Results Table -->
            <div class="card border-0 shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="text-uppercase small fw-semibold text-muted">Date</th>
                                <th class="text-uppercase small fw-semibold text-muted">Description</th>
                                <th class="text-uppercase small fw-semibold text-muted text-end">Amount</th>
                                <th class="text-uppercase small fw-semibold text-muted">Category</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tx in Model.Results.Items)
                            {
                                <tr>
                                    <td class="small text-muted">@tx.Date.ToString("dd/MM/yyyy")</td>
                                    <td class="small">@tx.Description</td>
                                    <td class="small text-end fw-semibold @(tx.Amount >= 0 ? "text-brand" : "text-danger")">
                                        &euro;@tx.Amount.ToString("N2")
                                    </td>
                                    <td>
                                        <partial name="Shared/_CategoryBadge" model="TransactionCategoryDisplayHelper.BuildBadge(tx)" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                @if (Model.Results.TotalPages > 1)
                {
                    <div class="card-footer bg-transparent d-flex align-items-center justify-content-between gap-2 flex-wrap">
                        <span class="small text-muted">Page @Model.Results.PageNumber of @Model.Results.TotalPages</span>
                        <div class="d-flex gap-2">
                            @if (Model.Results.PageNumber > 1)
                            {
                                <a href="/transactions/search?PageNumber=@(Model.Results.PageNumber - 1)&Keyword=@Model.Keyword&FromDate=@Model.FromDate?.ToString("yyyy-MM-dd")&ToDate=@Model.ToDate?.ToString("yyyy-MM-dd")&CategoryId=@Model.CategoryId&MinAmount=@Model.MinAmount&MaxAmount=@Model.MaxAmount"
                                   class="btn btn-outline-secondary btn-sm">&larr; Previous</a>
                            }
                            @if (Model.Results.PageNumber < Model.Results.TotalPages)
                            {
                                <a href="/transactions/search?PageNumber=@(Model.Results.PageNumber + 1)&Keyword=@Model.Keyword&FromDate=@Model.FromDate?.ToString("yyyy-MM-dd")&ToDate=@Model.ToDate?.ToString("yyyy-MM-dd")&CategoryId=@Model.CategoryId&MinAmount=@Model.MinAmount&MaxAmount=@Model.MaxAmount"
                                   class="btn btn-brand btn-sm">Next &rarr;</a>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <!-- Empty State -->
            <div class="card border-0 shadow-sm p-5 text-center" role="status" aria-live="polite">
                <div class="fs-1 mb-3">🔍</div>
                <p class="h5 fw-semibold mb-2">No results found</p>
                <p class="text-muted">Try adjusting your filters or search terms.</p>
            </div>
        }
    }
</div>
