@page
@model SauronSheet.Frontend.Pages.Transactions.AddModel
@{
    ViewData["Title"] = "Add Transaction";
}

<div class="mx-auto d-flex flex-column gap-4" style="max-width: 640px;">
    <div class="d-flex align-items-center gap-3">
        <a href="/transactions" class="btn btn-link btn-sm text-muted text-decoration-none">&larr; Back</a>
        <h1 class="h3 fw-bold mb-0">Add Transaction</h1>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger rounded-3" role="alert">@Model.ErrorMessage</div>
    }

    <div class="card border-0 shadow-sm p-4">
        <form method="post" class="d-flex flex-column gap-3">
            <div>
                <label for="Date" class="form-label fw-semibold">Date</label>
                <input type="date" id="Date" name="Input.Date" asp-for="Input.Date"
                       class="form-control" required aria-required="true" />
            </div>

            <div>
                <label for="Description" class="form-label fw-semibold">Description</label>
                <input type="text" id="Description" name="Input.Description" asp-for="Input.Description"
                       class="form-control" placeholder="e.g., Coffee at Starbucks"
                       required aria-required="true" />
            </div>

            <div>
                <label for="Amount" class="form-label fw-semibold">Amount</label>
                <input type="number" id="Amount" name="Input.Amount" asp-for="Input.Amount" step="0.01"
                       class="form-control" placeholder="0.00" required aria-required="true" />
                <div class="form-text">Use negative values for expenses, positive for income</div>
            </div>

            <div>
                <label for="Currency" class="form-label fw-semibold">Currency</label>
                <select id="Currency" name="Input.Currency" asp-for="Input.Currency" class="form-select">
                    <option value="EUR">EUR (&euro;)</option>
                    <option value="USD">USD ($)</option>
                    <option value="GBP">GBP (&pound;)</option>
                </select>
            </div>

            <div>
                <label for="CategoryName" class="form-label fw-semibold">Category <span class="text-muted fw-normal">(optional — type to search or create)</span></label>
                <input type="text" id="CategoryName" name="Input.CategoryName"
                       list="categories" asp-for="Input.CategoryName"
                       class="form-control" placeholder="Search existing or type new category..." />
                <datalist id="categories">
                    <option value="" />
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.Name" />
                    }
                </datalist>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-2">
                <a href="/transactions" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-brand">Add Transaction</button>
            </div>
        </form>
    </div>
</div>
