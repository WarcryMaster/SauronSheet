@page "/Analysis/Annual"
@using System.Globalization
@using SauronSheet.Application.Features.Analytics.DTOs
@model SauronSheet.Frontend.Pages.Analysis.AnnualModel
@{
    ViewData["Title"] = "Annual Analysis";
    int currentYear = DateTime.UtcNow.Year;
    int startYear = currentYear - 5;
    int endYear = currentYear + 1;

    AnnualAnalysisSummaryDto? summary = Model.Result?.Summary;
    YearOverYearVariationDto? variation = summary?.Variation;
    object? variationObject = variation;
    bool hasVariation = variation?.HasPreviousYearData == true;
    int monthsWithData = summary?.MonthsWithData ?? 0;
}

<style>
    .kpi-card { border-left-width: 4px !important; }
    .mini-bar { height: 20px; border-radius: 4px; transition: width 0.3s; }
    .mini-bar-income { background: var(--mdb-success); }
    .mini-bar-expense { background: var(--mdb-danger); }
    .chart-wrapper { position: relative; height: 380px; }
</style>

<div class="d-flex flex-column gap-4"
     x-data='{
         hasData: @(Model.HasData.ToString().ToLowerInvariant()),
         showDetail: false,
         incomeRows: @Json.Serialize(Model.IncomeRows.Select(r => new { movement = r.Movement, typeLabel = r.TypeLabel, average = r.Average, totalAnnual = r.MonthlyAmounts.Sum(), monthlyAmounts = r.MonthlyAmounts, expanded = false, isIncome = r.IsIncome })),
         expenseRows: @Json.Serialize(Model.ExpenseRows.Select(r => new { movement = r.Movement, typeLabel = r.TypeLabel, average = r.Average, totalAnnual = r.MonthlyAmounts.Sum(), monthlyAmounts = r.MonthlyAmounts, expanded = false, isIncome = r.IsIncome })),
         variation: @Json.Serialize(variationObject),
         hasVariation: @(hasVariation.ToString().ToLowerInvariant()),

         init() {
             if (this.hasData) {
                 this.$nextTick(() => {
                      const trendData = JSON.parse((document.getElementById("annual-trend-data")?.textContent || "{}").trim());
                      const distData = JSON.parse((document.getElementById("annual-distribution-data")?.textContent || "{}").trim());
                     initAnnualTrendChart(this.$refs.trendCanvas, trendData);
                     initAnnualDistributionChart(this.$refs.distCanvas, distData);
                 });
             }
         },

         toggleDetail() { this.showDetail = !this.showDetail; },

         toggleRow(row) { row.expanded = !row.expanded; },

         getBarWidth(amount, max) {
             return max > 0 ? (amount / max * 100).toFixed(1) : 0;
         },

         getRowMax(row) {
             return Math.max(...row.monthlyAmounts, 1);
         },

         formatCurrency(value) {
             return "€" + Number(value).toFixed(2);
         },

         getPreviousYearValue(current, pct) {
             if (!this.hasVariation || pct === null || pct === undefined) return null;
             const factor = 1 + (Number(pct) / 100);
             return factor !== 0 ? current / factor : 0;
         }
     }'>

    <div class="d-flex justify-content-between align-items-center">
        <h3 class="h3 fw-bold mb-0">Annual Analysis</h3>
    </div>

    @* Year selector *@
    <form method="get" action="/Analysis/Annual" class="card border-0 shadow-sm p-3">
        <div class="d-flex align-items-center gap-3">
            <label for="Year" class="form-label small fw-semibold text-muted text-uppercase mb-0">Year</label>
            <select id="Year" name="Year" class="form-select form-select-sm" style="width:auto"
                    x-data="{ year: '@Model.Year.GetValueOrDefault(currentYear)' }"
                    x-model="year"
                    @@change="$el.form.submit()">
                @for (int year = startYear; year <= endYear; year++)
                {
                    <option value="@year" selected="@(year == Model.Year.GetValueOrDefault(currentYear) ? "selected" : null)">@year</option>
                }
            </select>
        </div>
    </form>

    @* Empty state *@
    <template x-if="!hasData">
        <div>
            <div x-show="!hasData" x-transition.opacity
                 class="card border-0 shadow-sm p-5 text-center" role="status" aria-live="polite"
                 data-testid="annual-empty-state">
                <div class="fs-1 mb-3">📊</div>
                <p class="h5 fw-semibold mb-2">Sin datos para este año</p>
                <p class="text-muted mb-4">Add transactions to see the annual breakdown.</p>
            </div>
        </div>
    </template>

    @* Data state *@
    @if (Model.HasData)
    {
        <div x-show="hasData" x-transition.opacity class="d-flex flex-column gap-4">

                @* ── KPI Row ── *@
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-3">
                    @* Income KPI *@
                    <div class="col">
                        <div class="card border-0 shadow-sm h-100 p-3 kpi-card border-start border-success"
                             data-testid="annual-kpi-income"
                             x-data="{ display: 0, target: @((summary?.IncomeTotal ?? 0m).ToString(CultureInfo.InvariantCulture)), init() { const duration = 800; const start = performance.now(); const animate = (now) => { const elapsed = now - start; const progress = Math.min(elapsed / duration, 1); const eased = 1 - (1 - progress) * (1 - progress); this.display = Math.round(eased * this.target * 100) / 100; if (progress < 1) requestAnimationFrame(animate); else this.display = this.target; }; requestAnimationFrame(animate); } }">
                            <div class="small fw-semibold text-muted text-uppercase mb-1">Ingresos Total</div>
                            <div class="h4 fw-bold text-success mb-0">
                                <span x-text="'€' + display.toFixed(2)"></span>
                            </div>
                            @if (hasVariation)
                            {
                                <span class="badge @AnnualModel.GetVariationBadgeClass(variation!.IncomeTotalPct, true) mt-2">
                                    @AnnualModel.GetVariationArrow(variation.IncomeTotalPct) @AnnualModel.FormatVariationPct(variation.IncomeTotalPct)
                                </span>
                            }
                        </div>
                    </div>

                    @* Expense KPI *@
                    <div class="col">
                        <div class="card border-0 shadow-sm h-100 p-3 kpi-card border-start border-danger"
                             data-testid="annual-kpi-expense"
                             x-data="{ display: 0, target: @((summary?.ExpenseTotal ?? 0m).ToString(CultureInfo.InvariantCulture)), init() { const duration = 800; const start = performance.now(); const animate = (now) => { const elapsed = now - start; const progress = Math.min(elapsed / duration, 1); const eased = 1 - (1 - progress) * (1 - progress); this.display = Math.round(eased * this.target * 100) / 100; if (progress < 1) requestAnimationFrame(animate); else this.display = this.target; }; requestAnimationFrame(animate); } }">
                            <div class="small fw-semibold text-muted text-uppercase mb-1">Gastos Total</div>
                            <div class="h4 fw-bold text-danger mb-0">
                                <span x-text="'€' + display.toFixed(2)"></span>
                            </div>
                            @if (hasVariation)
                            {
                                <span class="badge @AnnualModel.GetVariationBadgeClass(variation!.ExpenseTotalPct, false) mt-2">
                                    @AnnualModel.GetVariationArrow(variation.ExpenseTotalPct) @AnnualModel.FormatVariationPct(variation.ExpenseTotalPct)
                                </span>
                            }
                        </div>
                    </div>

                    @* Net KPI *@
                    <div class="col">
                        <div class="card border-0 shadow-sm h-100 p-3 kpi-card border-start border-primary"
                             data-testid="annual-kpi-net"
                             x-data="{ display: 0, target: @((summary?.Net ?? 0m).ToString(CultureInfo.InvariantCulture)), init() { const duration = 800; const start = performance.now(); const animate = (now) => { const elapsed = now - start; const progress = Math.min(elapsed / duration, 1); const eased = 1 - (1 - progress) * (1 - progress); this.display = Math.round(eased * this.target * 100) / 100; if (progress < 1) requestAnimationFrame(animate); else this.display = this.target; }; requestAnimationFrame(animate); } }">
                            <div class="small fw-semibold text-muted text-uppercase mb-1">Neto</div>
                            <div class="h4 fw-bold @(summary?.Net >= 0 ? "text-success" : "text-danger") mb-0">
                                <span x-text="'€' + display.toFixed(2)"></span>
                            </div>
                            @if (hasVariation)
                            {
                                <span class="badge @AnnualModel.GetVariationBadgeClass(variation!.NetPct, true) mt-2">
                                    @AnnualModel.GetVariationArrow(variation.NetPct) @AnnualModel.FormatVariationPct(variation.NetPct)
                                </span>
                            }
                        </div>
                    </div>

                    @* Fixed Cost % KPI *@
                    <div class="col">
                        <div class="card border-0 shadow-sm h-100 p-3 kpi-card border-start border-warning"
                             data-testid="annual-kpi-fixed-pct"
                             x-data="{ display: 0, target: @Model.FixedCostPercentage.ToString(CultureInfo.InvariantCulture), init() { const duration = 800; const start = performance.now(); const animate = (now) => { const elapsed = now - start; const progress = Math.min(elapsed / duration, 1); const eased = 1 - (1 - progress) * (1 - progress); this.display = Math.round(eased * this.target * 100) / 100; if (progress < 1) requestAnimationFrame(animate); else this.display = this.target; }; requestAnimationFrame(animate); } }">
                            <div class="small fw-semibold text-muted text-uppercase mb-1">% Coste Fijo</div>
                            <div class="h4 fw-bold text-warning mb-0">
                                <span x-text="display.toFixed(1) + '%'"></span>
                            </div>
                        </div>
                    </div>
                </div>

                @* ── Months with data card (kept existing testid) ── *@
                <div data-testid="annual-months-card" class="card border-0 shadow-sm p-3 text-center">
                    <div class="small fw-semibold text-muted text-uppercase mb-1">
                        📅 Meses con datos
                    </div>
                    <div class="h4 fw-bold mb-0">
                        @if (monthsWithData >= 12)
                        {
                            <span data-testid="months-full-year" class="text-success">Año completo</span>
                        }
                        else
                        {
                            <span>@monthsWithData / 12 meses con datos</span>
                        }
                    </div>
                </div>

                @* ── Charts Row ── *@
                <div class="row g-4">
                    <div class="col-12 col-lg-6">
                        <div class="card border-0 shadow-sm p-3 h-100 d-flex flex-column">
                            <h4 class="h6 fw-semibold mb-3">Monthly Trend</h4>
                            <div class="chart-wrapper flex-grow-1">
                                <canvas x-ref="trendCanvas"
                                        id="annual-trend-chart"
                                        data-testid="annual-trend-chart"
                                        role="img"
                                        aria-label="Monthly trend chart showing income and expenses for each month of the year"></canvas>
                            </div>
                            <table class="visually-hidden" aria-hidden="true">
                                <caption>Monthly trend (fallback table)</caption>
                                <thead>
                                    <tr><th>Month</th><th>Income</th><th>Expenses</th></tr>
                                </thead>
                                <tbody>
                                    @for (int m = 0; m < 12; m++)
                                    {
                                        <tr>
                                            <td>@(new[] { "Ene", "Feb", "Mar", "Abr", "May", "Jun", "Jul", "Ago", "Sep", "Oct", "Nov", "Dic" }[m])</td>
                                            <td>€@Model.MonthlyIncomeTotals[m].ToString("N2", CultureInfo.InvariantCulture)</td>
                                            <td>€@Model.MonthlyExpenseTotals[m].ToString("N2", CultureInfo.InvariantCulture)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6">
                        <div class="card border-0 shadow-sm p-3 h-100 d-flex flex-column">
                            <h4 class="h6 fw-semibold mb-3">Fixed / Variable Distribution</h4>
                            <div class="chart-wrapper flex-grow-1">
                                <canvas x-ref="distCanvas"
                                        id="annual-distribution-chart"
                                        data-testid="annual-distribution-chart"
                                        role="img"
                                        aria-label="Donut chart showing fixed versus variable income and expenses"></canvas>
                            </div>
                            <table class="visually-hidden" aria-hidden="true">
                                <caption>Fixed / variable distribution (fallback table)</caption>
                                <thead>
                                    <tr><th>Category</th><th>Amount</th></tr>
                                </thead>
                                <tbody>
                                    @if (summary is not null)
                                    {
                                        <tr><td>Income Fixed</td><td>€@summary.IncomeFixed.ToString("N2", CultureInfo.InvariantCulture)</td></tr>
                                        <tr><td>Income Variable</td><td>€@summary.IncomeVariable.ToString("N2", CultureInfo.InvariantCulture)</td></tr>
                                        <tr><td>Expense Fixed</td><td>€@summary.ExpenseFixed.ToString("N2", CultureInfo.InvariantCulture)</td></tr>
                                        <tr><td>Expense Variable</td><td>€@summary.ExpenseVariable.ToString("N2", CultureInfo.InvariantCulture)</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                @* ── YoY Comparison Section ── *@
                <div data-testid="annual-yoy-section">
                    <h4 class="h6 fw-semibold mb-3">Year over Year</h4>

                    <template x-if="!hasVariation">
                        <div class="card border-0 shadow-sm p-3 text-center text-muted"
                             data-testid="annual-yoy-no-data">
                            Sin datos del año anterior
                        </div>
                    </template>

                    <template x-if="hasVariation">
                        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-2">
                            @* Income Fixed *@
                            <div class="col">
                                <div class="card border-0 shadow-sm h-100 p-3 kpi-card border-start @AnnualModel.GetVariationBadgeClass(variation?.IncomeFixedPct, true).Replace("bg-", "border-")">
                                    <div class="small fw-semibold text-muted text-uppercase mb-1">Income Fixed</div>
                                    <div class="h5 fw-bold mb-0">€@summary!.IncomeFixed.ToString("N2")</div>
                                    @if (hasVariation)
                                    {
                                        <span class="badge @AnnualModel.GetVariationBadgeClass(variation!.IncomeFixedPct, true) mt-2">
                                            @AnnualModel.GetVariationArrow(variation.IncomeFixedPct) @AnnualModel.FormatVariationPct(variation.IncomeFixedPct)
                                        </span>
                                    }
                                </div>
                            </div>

                            @* Income Variable *@
                            <div class="col">
                                <div class="card border-0 shadow-sm h-100 p-3 kpi-card border-start @AnnualModel.GetVariationBadgeClass(variation?.IncomeVariablePct, true).Replace("bg-", "border-")">
                                    <div class="small fw-semibold text-muted text-uppercase mb-1">Income Variable</div>
                                    <div class="h5 fw-bold mb-0">€@summary.IncomeVariable.ToString("N2")</div>
                                    @if (hasVariation)
                                    {
                                        <span class="badge @AnnualModel.GetVariationBadgeClass(variation!.IncomeVariablePct, true) mt-2">
                                            @AnnualModel.GetVariationArrow(variation.IncomeVariablePct) @AnnualModel.FormatVariationPct(variation.IncomeVariablePct)
                                        </span>
                                    }
                                </div>
                            </div>

                            @* Expense Fixed *@
                            <div class="col">
                                <div class="card border-0 shadow-sm h-100 p-3 kpi-card border-start @AnnualModel.GetVariationBadgeClass(variation?.ExpenseFixedPct, false).Replace("bg-", "border-")">
                                    <div class="small fw-semibold text-muted text-uppercase mb-1">Expense Fixed</div>
                                    <div class="h5 fw-bold mb-0">€@summary.ExpenseFixed.ToString("N2")</div>
                                    @if (hasVariation)
                                    {
                                        <span class="badge @AnnualModel.GetVariationBadgeClass(variation!.ExpenseFixedPct, false) mt-2">
                                            @AnnualModel.GetVariationArrow(variation.ExpenseFixedPct) @AnnualModel.FormatVariationPct(variation.ExpenseFixedPct)
                                        </span>
                                    }
                                </div>
                            </div>

                            @* Expense Variable *@
                            <div class="col">
                                <div class="card border-0 shadow-sm h-100 p-3 kpi-card border-start @AnnualModel.GetVariationBadgeClass(variation?.ExpenseVariablePct, false).Replace("bg-", "border-")">
                                    <div class="small fw-semibold text-muted text-uppercase mb-1">Expense Variable</div>
                                    <div class="h5 fw-bold mb-0">€@summary.ExpenseVariable.ToString("N2")</div>
                                    @if (hasVariation)
                                    {
                                        <span class="badge @AnnualModel.GetVariationBadgeClass(variation!.ExpenseVariablePct, false) mt-2">
                                            @AnnualModel.GetVariationArrow(variation.ExpenseVariablePct) @AnnualModel.FormatVariationPct(variation.ExpenseVariablePct)
                                        </span>
                                    }
                                </div>
                            </div>

                            @* Net *@
                            <div class="col">
                                <div class="card border-0 shadow-sm h-100 p-3 kpi-card border-start @AnnualModel.GetVariationBadgeClass(variation?.NetPct, true).Replace("bg-", "border-")">
<div class="small fw-semibold text-muted text-uppercase mb-1">Neto</div>
                                    <div class="h5 fw-bold mb-0">€@summary.Net.ToString("N2")</div>
                                    @if (hasVariation)
                                    {
                                        <span class="badge @AnnualModel.GetVariationBadgeClass(variation!.NetPct, true) mt-2">
                                            @AnnualModel.GetVariationArrow(variation.NetPct) @AnnualModel.FormatVariationPct(variation.NetPct)
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                    </template>
                </div>

                @* ── Detail Toggle ── *@
                <div class="d-flex justify-content-center">
                    <button type="button"
                            class="btn btn-outline-secondary"
                            data-testid="annual-detail-toggle"
                            @@click="toggleDetail()"
                            @@keydown.enter="toggleDetail()"
                            @@keydown.space.prevent="toggleDetail()"
                            tabindex="0"
                            :aria-expanded="showDetail">
                        <span x-show="!showDetail">📂 Mostrar detalle</span>
                        <span x-show="showDetail">📁 Ocultar detalle</span>
                    </button>
                </div>

                @* ── Detail Tables ── *@
                <div x-show="showDetail" x-transition.opacity>
                    <div class="d-flex flex-column gap-4">

                        @* Income Table *@
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <h5 class="h6 fw-semibold mb-3 text-success">Income Detail</h5>
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle mb-0"
                                           aria-label="Annual income detail"
                                           data-testid="annual-income-table">
                                        <thead class="table-light">
                                            <tr>
                                                <th class="text-uppercase small fw-semibold text-muted">Movimiento</th>
                                                <th class="text-uppercase small fw-semibold text-muted">Tipo</th>
                                                <th class="text-uppercase small fw-semibold text-muted text-end">Total Anual</th>
                                                <th class="text-uppercase small fw-semibold text-muted text-end">Media Mensual</th>
                                                <th class="text-uppercase small fw-semibold text-muted text-end">Variación YoY</th>
                                            </tr>
                                        </thead>
                                        <template x-for="row in incomeRows" :key="row.movement">
                                            <tbody>
                                                <tr role="button" tabindex="0"
                                                    @@click="toggleRow(row)"
                                                    @@keydown.enter="toggleRow(row)"
                                                    @@keydown.space.prevent="toggleRow(row)"
                                                    class="cursor-pointer"
                                                    :aria-expanded="row.expanded">
                                                    <td class="fw-medium">
                                                        <span x-text="row.expanded ? '▼' : '▶'" class="me-2"></span>
                                                        <span x-text="row.movement"></span>
                                                    </td>
                                                    <td>
                                                        <span class="badge"
                                                              :class="row.typeLabel.includes('Fijo') ? 'bg-success' : 'bg-warning'"
                                                              x-text="row.typeLabel"></span>
                                                    </td>
                                                    <td class="text-end fw-medium" x-text="formatCurrency(row.totalAnnual)"></td>
                                                    <td class="text-end" x-text="formatCurrency(row.average)"></td>
                                                    <td class="text-end">
                                                        @if (hasVariation)
                                                        {
                                                            <span class="badge @AnnualModel.GetVariationBadgeClass(variation!.IncomeTotalPct, true)">
                                                                @AnnualModel.GetVariationArrow(variation.IncomeTotalPct) @AnnualModel.FormatVariationPct(variation.IncomeTotalPct)
                                                            </span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-secondary">N/A</span>
                                                        }
                                                    </td>
                                                </tr>
                                                <tr x-show="row.expanded" x-transition>
                                                    <td colspan="5" class="p-3 bg-light">
                                                        <div class="d-flex flex-column gap-1">
                                                            <template x-for="(amount, idx) in row.monthlyAmounts" :key="idx">
                                                                <div class="d-flex align-items-center gap-2">
                                                                    <small class="text-muted" style="width: 24px;"
                                                                           x-text="['E','F','M','A','M','J','J','A','S','O','N','D'][idx]"></small>
                                                                    <div class="flex-grow-1 bg-white rounded">
                                                                        <div class="mini-bar"
                                                                             :class="row.isIncome ? 'mini-bar-income' : 'mini-bar-expense'"
                                                                             :style="'width: ' + getBarWidth(amount, getRowMax(row)) + '%'">
                                                                        </div>
                                                                    </div>
                                                                    <small class="text-muted" style="width: 60px; text-align: right;"
                                                                           x-text="formatCurrency(amount)"></small>
                                                                </div>
                                                            </template>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </template>
                                    </table>
                                </div>
                            </div>
                        </div>

                        @* Expense Table *@
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <h5 class="h6 fw-semibold mb-3 text-danger">Expense Detail</h5>
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle mb-0"
                                           aria-label="Annual expense detail"
                                           data-testid="annual-expense-table">
                                        <thead class="table-light">
                                            <tr>
                                                <th class="text-uppercase small fw-semibold text-muted">Movimiento</th>
                                                <th class="text-uppercase small fw-semibold text-muted">Tipo</th>
                                                <th class="text-uppercase small fw-semibold text-muted text-end">Total Anual</th>
                                                <th class="text-uppercase small fw-semibold text-muted text-end">Media Mensual</th>
                                                <th class="text-uppercase small fw-semibold text-muted text-end">Variación YoY</th>
                                            </tr>
                                        </thead>
                                        <template x-for="row in expenseRows" :key="row.movement">
                                            <tbody>
                                                <tr role="button" tabindex="0"
                                                    @@click="toggleRow(row)"
                                                    @@keydown.enter="toggleRow(row)"
                                                    @@keydown.space.prevent="toggleRow(row)"
                                                    class="cursor-pointer"
                                                    :aria-expanded="row.expanded">
                                                    <td class="fw-medium">
                                                        <span x-text="row.expanded ? '▼' : '▶'" class="me-2"></span>
                                                        <span x-text="row.movement"></span>
                                                    </td>
                                                    <td>
                                                        <span class="badge"
                                                              :class="row.typeLabel.includes('Fijo') ? 'bg-success' : 'bg-warning'"
                                                              x-text="row.typeLabel"></span>
                                                    </td>
                                                    <td class="text-end fw-medium" x-text="formatCurrency(row.totalAnnual)"></td>
                                                    <td class="text-end" x-text="formatCurrency(row.average)"></td>
                                                    <td class="text-end">
                                                        @if (hasVariation)
                                                        {
                                                            <span class="badge @AnnualModel.GetVariationBadgeClass(variation!.ExpenseTotalPct, false)">
                                                                @AnnualModel.GetVariationArrow(variation.ExpenseTotalPct) @AnnualModel.FormatVariationPct(variation.ExpenseTotalPct)
                                                            </span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-secondary">N/A</span>
                                                        }
                                                    </td>
                                                </tr>
                                                <tr x-show="row.expanded" x-transition>
                                                    <td colspan="5" class="p-3 bg-light">
                                                        <div class="d-flex flex-column gap-1">
                                                            <template x-for="(amount, idx) in row.monthlyAmounts" :key="idx">
                                                                <div class="d-flex align-items-center gap-2">
                                                                    <small class="text-muted" style="width: 24px;"
                                                                           x-text="['E','F','M','A','M','J','J','A','S','O','N','D'][idx]"></small>
                                                                    <div class="flex-grow-1 bg-white rounded">
                                                                        <div class="mini-bar"
                                                                             :class="row.isIncome ? 'mini-bar-income' : 'mini-bar-expense'"
                                                                             :style="'width: ' + getBarWidth(amount, getRowMax(row)) + '%'">
                                                                        </div>
                                                                    </div>
                                                                    <small class="text-muted" style="width: 60px; text-align: right;"
                                                                           x-text="formatCurrency(amount)"></small>
                                                                </div>
                                                            </template>
                                                        </div>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </template>
                                    </table>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

            </div>
    }

    @if (Model.HasData)
    {
        <script type="application/json" id="annual-trend-data">@Html.Raw(Model.ChartDataJson)</script>
        <script type="application/json" id="annual-distribution-data">@Html.Raw(Model.FixedVariableChartJson)</script>
    }
</div>

<script src="~/js/charts.js" asp-append-version="true"></script>
