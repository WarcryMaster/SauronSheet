{
  "Logging": {
    "LogLevel": {
      "Default": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Sentry": {
    "Dsn": "YOUR_SENTRY_DSN",
    "TracesSampleRate": 1.0
  },
  "Supabase": {
