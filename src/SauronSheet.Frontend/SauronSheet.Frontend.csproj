<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <!-- Ignore NuGet vulnerability warnings for transitive dependencies of supabase-csharp -->
    <WarningLevel>4</WarningLevel>
    <NoWarn>$(NoWarn);NU1902</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\SauronSheet.Application\SauronSheet.Application.csproj" />
    <ProjectReference Include="..\SauronSheet.Infrastructure\SauronSheet.Infrastructure.csproj" />
  </ItemGroup>

</Project>
