@using Microsoft.Extensions.Localization
@using SauronSheet.Application.Resources
@inject IStringLocalizer<SharedResources> Localizer

<!-- Confirmation Modal for Bulk Delete -->
<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteLabel" aria-hidden="true"
     @@hidden.bs.modal="if (countdownInterval) { clearInterval(countdownInterval); countdownInterval = null; }">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-bottom">
                <h5 class="modal-title" id="confirmDeleteLabel">
                    <span class="text-danger">⚠️ @Localizer["Transactions.Modal.BulkDeleteTitle"]</span>
                </h5>
                <button type="button" class="btn-close" data-mdb-dismiss="modal" aria-label="@Localizer["Common.Close"]"></button>
            </div>

            <div class="modal-body">
                <p class="mb-2">
                    <span x-text="transactionI18n.bulkDeleteConfirm.replace('{0}', selectionCount).replace('{1}', pluralS)">@Localizer["Transactions.Modal.BulkDeleteConfirm", 0, "s"]</span>
                </p>
                <p class="text-muted small mb-4">
                    <span class="d-block">@Localizer["Transactions.Modal.SingleDeleteWarning"]</span>
                    <span class="d-block">@Localizer["Transactions.Modal.BulkDeleteWarning"]</span>
                </p>

                <!-- Countdown Timer -->
                <div class="alert alert-info rounded-3 mb-0" role="status">
                    <div class="d-flex align-items-center justify-content-between">
                        <span x-text="transactionI18n.countdownTemplate.replace('{0}', countdown)">@Localizer["Transactions.Modal.Countdown", 2]</span>
                        <div class="progress" style="width: 80px; height: 6px;">
                            <div class="progress-bar bg-info" role="progressbar"
                                 :style="'width: ' + countdownWidth + '%'"
                                 :aria-valuenow="countdown" aria-valuemin="0" aria-valuemax="2"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer border-top gap-2">
                <button type="button" id="cancelDeleteBtn" class="btn btn-outline-secondary btn-sm" @@click="cancelDelete()">
                    ← @Localizer["Common.Cancel"]
                </button>
                <button type="button" id="confirmDeleteBtn" class="btn btn-danger btn-sm"
                        :disabled="!canConfirm" @@click="submitBulkDelete()">
                    🗑️ <span x-text="transactionI18n.delete">@Localizer["Common.Delete"]</span>
                </button>
            </div>
        </div>
    </div>
</div>

<form id="bulkDeleteForm" method="post" action="/Transactions?handler=BulkDelete" style="display: none;">
    @Html.AntiForgeryToken()
    <input type="hidden" id="selectedIds" name="transactionIds" />
</form>
