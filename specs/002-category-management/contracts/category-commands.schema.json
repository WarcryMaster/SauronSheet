{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Category Commands",
  "description": "CQRS Command contracts for Category management",
  "definitions": {
    "CreateCategoryCommand": {
      "type": "object",
      "title": "CreateCategoryCommand",
      "description": "Create a new custom category for the current user",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50,
          "description": "Category name (must be unique per user)"
        },
        "type": {
          "type": "string",
          "enum": ["Income", "Expense"],
          "description": "Category type classification"
        },
        "color": {
          "type": "string",
          "pattern": "^#[0-9A-F]{6}$",
          "description": "Hex color code (format: #RRGGBB)"
        },
        "iconName": {
          "type": "string",
          "description": "Bootstrap icon name (e.g., 'credit-card', 'home')"
        }
      },
      "required": ["name", "type", "color", "iconName"],
      "additionalProperties": false
    },
    "CreateCategoryCommandResponse": {
      "type": "object",
      "title": "CreateCategoryCommandResponse",
      "description": "Response from CreateCategoryCommand",
      "properties": {
        "categoryId": {
          "type": "string",
          "format": "uuid",
          "description": "Newly created category ID"
        }
      },
      "required": ["categoryId"]
    },
    "UpdateCategoryCommand": {
      "type": "object",
      "title": "UpdateCategoryCommand",
      "description": "Update a custom category (name, color, icon only; Type and IsSystemDefault cannot change)",
      "properties": {
        "categoryId": {
          "type": "string",
          "format": "uuid",
          "description": "ID of category to update"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50,
          "description": "New category name"
        },
        "color": {
          "type": "string",
          "pattern": "^#[0-9A-F]{6}$",
          "description": "New hex color code"
        },
        "iconName": {
          "type": "string",
          "description": "New icon name"
        }
      },
      "required": ["categoryId", "name", "color", "iconName"],
      "additionalProperties": false
    },
    "DeleteCategoryCommand": {
      "type": "object",
      "title": "DeleteCategoryCommand",
      "description": "Delete a custom category (blocked if has transactions or is system default)",
      "properties": {
        "categoryId": {
          "type": "string",
          "format": "uuid",
          "description": "ID of category to delete"
        }
      },
      "required": ["categoryId"],
      "additionalProperties": false
    }
  }
}
