{
    // Configuración de lanzamiento para SauronSheet (.NET 10 Razor Pages)
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run SauronSheet.Frontend",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/SauronSheet.Frontend/bin/Debug/net10.0/SauronSheet.Frontend.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/SauronSheet.Frontend",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/src/SauronSheet.Frontend/Pages"
            }
        },
        {
            "name": "Run All Tests",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/SauronSheet.Domain.Tests/bin/Debug/net10.0/SauronSheet.Domain.Tests.dll",
            "cwd": "${workspaceFolder}/src/SauronSheet.Domain.Tests",
            "stopAtEntry": false
        }
    ]
}