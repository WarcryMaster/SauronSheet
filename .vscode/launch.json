{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Core Launch (SauronSheet.Frontend)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/SauronSheet.Frontend/bin/Debug/net10.0/SauronSheet.Frontend.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/SauronSheet.Frontend",
      "stopAtEntry": false,
      "serverReadyAction": {
        "pattern": "Now listening on:\\s+(https?://\\S+|http://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "console": "internalConsole",
      "justMyCode": true
    }
  ]
}
{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch (Development)",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/src/SauronSheet.Frontend/SauronSheet.Frontend.csproj",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "Attach to Process",
      "type": "dotnet",
      "request": "attach"
    }
  ]
}
